@model WhiteStiches.Admin.Models.PageEditViewModel
@{
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "New page" : $"Edit page — {Model.TitleEn}";
    ViewData["Nav"] = "pages";
}

@section Styles {
    <link rel="stylesheet" href="~/css/modules/content.css" asp-append-version="true" />
}

<section class="adm-panel">
    <header class="adm-panel__head">
        <h2 class="adm-panel__title">@(isNew ? "New page" : "Edit page")</h2>
        <a href="/pages" class="adm-btn">Back to pages</a>
    </header>
    <div class="adm-panel__body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="adm-toast adm-toast--err" role="alert">Please fix the highlighted fields below.</div>
        }

        <form asp-controller="PagesAdmin" asp-action="Save" method="post" class="adm-form-grid">
            <input type="hidden" asp-for="Id" />

            <div class="adm-field">
                <label asp-for="TitleEn">Title (EN)</label>
                <input asp-for="TitleEn" />
                <span asp-validation-for="TitleEn"></span>
            </div>
            <div class="adm-field">
                <label asp-for="TitleAr">Title (AR)</label>
                <input asp-for="TitleAr" dir="rtl" />
            </div>

            <div class="adm-field">
                <label asp-for="Slug">Slug</label>
                <input asp-for="Slug" placeholder="auto-generated from EN title" />
                <span class="cnt-hint">Leave blank to generate from the English title. Collisions get -2, -3…</span>
            </div>
            <div class="adm-field adm-field--check">
                <input asp-for="IsPublished" />
                <label asp-for="IsPublished">Published (visible on the storefront)</label>
            </div>

            <div class="adm-field is-full">
                <label asp-for="BodyEn">Body EN (HTML)</label>
                <textarea asp-for="BodyEn" rows="12" spellcheck="false"></textarea>
                <span class="cnt-hint">Raw HTML — rendered as-is on the storefront.</span>
            </div>
            <div class="adm-field is-full">
                <label asp-for="BodyAr">Body AR (HTML)</label>
                <textarea asp-for="BodyAr" rows="12" dir="rtl" spellcheck="false"></textarea>
            </div>

            <div class="adm-field">
                <label asp-for="SeoTitleEn">SEO title (EN)</label>
                <input asp-for="SeoTitleEn" />
            </div>
            <div class="adm-field">
                <label asp-for="SeoTitleAr">SEO title (AR)</label>
                <input asp-for="SeoTitleAr" dir="rtl" />
            </div>
            <div class="adm-field">
                <label asp-for="SeoDescriptionEn">SEO description (EN)</label>
                <textarea asp-for="SeoDescriptionEn" rows="3"></textarea>
            </div>
            <div class="adm-field">
                <label asp-for="SeoDescriptionAr">SEO description (AR)</label>
                <textarea asp-for="SeoDescriptionAr" rows="3" dir="rtl"></textarea>
            </div>

            <div class="adm-actions is-full">
                <button type="submit" class="adm-btn adm-btn--solid">@(isNew ? "Create page" : "Save changes")</button>
                <a href="/pages" class="adm-btn">Cancel</a>
            </div>
        </form>
    </div>
</section>

@if (!isNew)
{
    <section class="adm-panel cnt-danger">
        <header class="adm-panel__head">
            <h2 class="adm-panel__title">Delete page</h2>
        </header>
        <div class="adm-panel__body">
            <form asp-controller="PagesAdmin" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="adm-actions">
                <label class="adm-field--check">
                    <input type="checkbox" name="confirm" value="yes" />
                    Yes, permanently delete “@Model.TitleEn”
                </label>
                <button type="submit" class="adm-btn">Delete page</button>
            </form>
        </div>
    </section>
}
