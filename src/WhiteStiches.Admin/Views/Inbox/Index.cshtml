@model WhiteStiches.Admin.Models.InboxListViewModel
@{
    ViewData["Title"] = "Inbox";
    ViewData["Nav"] = "inbox";
}

<div class="adm-toolbar">
    <div class="adm-toolbar__filters">
        <a href="/inbox" class="adm-btn @(Model.UnreadOnly ? "adm-btn--solid" : null)">@L["Unread"]</a>
        <a href="/inbox?unreadOnly=false" class="adm-btn @(!Model.UnreadOnly ? "adm-btn--solid" : null)">@L["All messages"]</a>
    </div>
</div>

<section class="adm-panel">
    <header class="adm-panel__head">
        <h2 class="adm-panel__title">@(Model.UnreadOnly ? L["Unread messages"].Value : L["All messages"].Value) (@Model.Messages.TotalCount)</h2>
    </header>

    @if (Model.Messages.Items.Count == 0)
    {
        <div class="adm-panel__body">
            <div class="adm-empty">
                <strong>@(Model.UnreadOnly ? L["Inbox zero"].Value : L["No messages"].Value)</strong>
                @(Model.UnreadOnly ? L["No unread contact messages right now."].Value : L["Nothing has come through the contact form yet."].Value)
            </div>
        </div>
    }
    else
    {
        <table class="adm-table">
            <thead>
                <tr>
                    <th>@L["Name"]</th>
                    <th>@L["Email"]</th>
                    <th>@L["Subject"]</th>
                    <th>@L["Received (UTC)"]</th>
                    <th>@L["Status"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Messages.Items)
                {
                    <tr>
                        <td><a href="/inbox/@m.Id">@m.Name</a></td>
                        <td>@m.Email</td>
                        <td><a href="/inbox/@m.Id">@(string.IsNullOrWhiteSpace(m.Subject) ? L["(no subject)"].Value : m.Subject)</a></td>
                        <td>@m.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (m.IsRead)
                            {
                                <span class="adm-badge">@L["Read"]</span>
                            }
                            else
                            {
                                <span class="adm-badge adm-badge--warn">@L["Unread"]</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<partial name="_Pager" model="PagerInfo.From(Model.Messages)" />
