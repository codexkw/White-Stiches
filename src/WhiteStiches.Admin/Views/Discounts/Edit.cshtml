@model DiscountEditViewModel
@{
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "New discount" : $"Edit {Model.Code}";
    ViewData["Nav"] = "discounts";
}

@section Styles {
    <link rel="stylesheet" href="~/css/modules/discounts.css" asp-append-version="true" />
}

<section class="adm-panel">
    <header class="adm-panel__head">
        <h2 class="adm-panel__title">@(isNew ? L["Create discount code"] : L["Edit discount code"])</h2>
        <a href="/discounts" class="adm-btn">@L["Back to list"]</a>
    </header>
    <div class="adm-panel__body">

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="adm-toast adm-toast--err dsc-summary"></div>
        }

        <form asp-controller="Discounts" asp-action="Save" method="post" class="adm-form-grid">
            <input type="hidden" asp-for="Id" />

            <div class="adm-field">
                <label asp-for="Code">@L["Code"]</label>
                <input asp-for="Code" placeholder="WELCOME10" />
                <span asp-validation-for="Code"></span>
            </div>

            <div class="adm-field">
                <label asp-for="Type">@L["Type"]</label>
                <select asp-for="Type" asp-items="Html.GetEnumSelectList<DiscountType>()"></select>
            </div>

            <div class="adm-field">
                <label asp-for="Value">@L["Value (% for percentage, KWD for fixed amount)"]</label>
                <input asp-for="Value" type="number" step="0.001" min="0" />
                <span asp-validation-for="Value"></span>
            </div>

            <div class="adm-field">
                <label asp-for="MinPurchaseAmount">@L["Minimum purchase (KWD, optional)"]</label>
                <input asp-for="MinPurchaseAmount" type="number" step="0.001" min="0" />
                <span asp-validation-for="MinPurchaseAmount"></span>
            </div>

            <div class="adm-field">
                <label asp-for="MinQuantity">@L["Minimum quantity (optional)"]</label>
                <input asp-for="MinQuantity" type="number" min="0" />
            </div>

            <div class="adm-field">
                <label asp-for="UsageLimitTotal">@L["Usage limit — total (blank = unlimited)"]</label>
                <input asp-for="UsageLimitTotal" type="number" min="0" />
            </div>

            <div class="adm-field">
                <label asp-for="UsageLimitPerCustomer">@L["Usage limit — per customer (blank = unlimited)"]</label>
                <input asp-for="UsageLimitPerCustomer" type="number" min="0" />
            </div>

            <div class="adm-field">
                <label asp-for="StartsAtUtc">@L["Starts at (UTC, optional)"]</label>
                <input asp-for="StartsAtUtc" type="datetime-local" />
            </div>

            <div class="adm-field">
                <label asp-for="EndsAtUtc">@L["Ends at (UTC, optional)"]</label>
                <input asp-for="EndsAtUtc" type="datetime-local" />
                <span asp-validation-for="EndsAtUtc"></span>
            </div>

            <div class="adm-field adm-field--check">
                <input asp-for="IsActive" />
                <label asp-for="IsActive">@L["Active"]</label>
            </div>

            @if (!isNew)
            {
                <div class="is-full">
                    <span class="adm-badge">@L["Used {0} times", Model.TimesUsed]</span>
                </div>
            }

            <div class="adm-actions is-full adm-actions--savebar">
                <button type="submit" class="adm-btn adm-btn--solid">@(isNew ? L["Create discount"] : L["Save changes"])</button>
                <a href="/discounts" class="adm-btn">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</section>

<section class="adm-panel">
    <header class="adm-panel__head">
        <h2 class="adm-panel__title">@L["Eligibility"]</h2>
    </header>
    <div class="adm-panel__body">
        <p class="adm-hint" style="margin-top:0;">
            @L["Leave both empty to apply the discount to the whole cart. Otherwise the discount applies only to the selected products and the products inside the selected collections."]
        </p>

        @if (isNew)
        {
            <p style="color:#6b665c;">@L["Save the discount first, then choose the products and collections it applies to."]</p>
        }
        else
        {
            <h3 class="adm-subhead">@L["Eligible products"] (@Model.EligibleProducts.Count)</h3>

            <form method="get" action="/discounts/@Model.Id/edit" class="adm-toolbar__filters" style="margin-bottom:16px;">
                <div class="adm-field">
                    <label for="eligSearch">@L["Find active products to add"]</label>
                    <input id="eligSearch" name="eligSearch" value="@Model.ProductSearch" placeholder="@L["Title, slug, type, vendor or tag…"]" />
                </div>
                <button type="submit" class="adm-btn">@L["Search"]</button>
            </form>

            @if (Model.ShowSearchResults)
            {
                @if (Model.SearchResults.Count == 0)
                {
                    <p style="color:#6b665c;">@L["No matching active products."]</p>
                }
                else
                {
                    <table class="adm-table" style="margin-bottom:24px;">
                        <thead>
                            <tr><th></th><th>@L["Product"]</th><th>@L["Price"]</th><th></th></tr>
                        </thead>
                        <tbody>
                        @foreach (var p in Model.SearchResults)
                        {
                            <tr>
                                <td>@if (!string.IsNullOrEmpty(p.ImageUrl)) { <img class="adm-thumb" src="@p.ImageUrl" alt="@p.Title" /> }</td>
                                <td>@p.Title <span style="color:#6b665c;">(@p.Slug)</span></td>
                                <td>@(p.Price.HasValue ? "KWD " + p.Price.Value.ToString("0.000") : "—")</td>
                                <td>
                                    <form method="post" action="/discounts/@Model.Id/eligibility/products/add">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@p.ProductId" />
                                        <input type="hidden" name="eligSearch" value="@Model.ProductSearch" />
                                        <button type="submit" class="adm-btn">@L["Add"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            }

            @if (Model.EligibleProducts.Count == 0)
            {
                <p style="color:#6b665c;">@L["No product is selected — add products above, or use collections below."]</p>
            }
            else
            {
                <table class="adm-table" style="margin-bottom:24px;">
                    <tbody>
                    @foreach (var p in Model.EligibleProducts)
                    {
                        <tr>
                            <td style="width:48px;">@if (!string.IsNullOrEmpty(p.ImageUrl)) { <img class="adm-thumb" src="@p.ImageUrl" alt="@p.Title" /> }</td>
                            <td>@p.Title <span style="color:#6b665c;">(@p.Slug)</span></td>
                            <td style="text-align:right;">
                                <form method="post" action="/discounts/@Model.Id/eligibility/products/@p.ProductId/remove">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="adm-btn">@L["Remove"]</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }

            <h3 class="adm-subhead">@L["Eligible collections"]</h3>
            @if (Model.EligibleCollections.Count == 0)
            {
                <p style="color:#6b665c;">@L["No collections exist yet."]</p>
            }
            else
            {
                <form method="post" action="/discounts/@Model.Id/eligibility/collections">
                    @Html.AntiForgeryToken()
                    <div class="dsc-collections" style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">
                        @foreach (var c in Model.EligibleCollections)
                        {
                            <label class="adm-field--check">
                                <input type="checkbox" name="collectionIds" value="@c.Id" checked="@(c.Selected ? "checked" : null)" />
                                <span>@c.Title</span>
                            </label>
                        }
                    </div>
                    <button type="submit" class="adm-btn adm-btn--solid">@L["Save eligible collections"]</button>
                </form>
            }
        }
    </div>
</section>
