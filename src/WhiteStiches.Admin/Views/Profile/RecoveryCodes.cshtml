@model WhiteStiches.Admin.Models.RecoveryCodesViewModel
@{
    ViewData["Title"] = L["Recovery codes"];
    ViewData["Nav"] = "profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/modules/settings.css" asp-append-version="true" />
}

<section class="adm-panel">
    <header class="adm-panel__head">
        <h2 class="adm-panel__title">@L["Save your recovery codes"]</h2>
        <span class="adm-badge adm-badge--warn">@L["Shown once"]</span>
    </header>
    <div class="adm-panel__body">
        <p>
            @L["Store these codes somewhere safe. Each one signs you in"] <strong>@L["once"]</strong> @L["if you lose access to your authenticator app. They will not be shown again."]
        </p>

        <ul class="set-codes">
            @foreach (var code in Model.Codes)
            {
                <li><code>@code</code></li>
            }
        </ul>

        <div class="adm-actions set-actions">
            <a class="adm-btn adm-btn--solid" href="/profile/2fa">@L["I've saved them — done"]</a>
        </div>
    </div>
</section>
