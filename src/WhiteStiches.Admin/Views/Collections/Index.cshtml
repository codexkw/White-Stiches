@model CollectionIndexViewModel
@{
    ViewData["Title"] = "Collections";
    ViewData["Nav"] = "collections";
}

<section class="adm-panel">
    <header class="adm-panel__head">
        <h2 class="adm-panel__title">Collections (@Model.Collections.TotalCount)</h2>
        <a class="adm-btn adm-btn--solid" href="/collections/new">New collection</a>
    </header>

    @if (Model.Collections.Items.Count == 0)
    {
        <div class="adm-panel__body">
            <div class="adm-empty">
                <strong>No collections yet</strong>
                Create a manual collection and curate products, or a smart collection driven by rules.
            </div>
        </div>
    }
    else
    {
        <table class="adm-table">
            <thead>
            <tr>
                <th>Title (EN)</th>
                <th>Slug</th>
                <th>Type</th>
                <th>Products</th>
                <th>Status</th>
                <th>Updated (UTC)</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var c in Model.Collections.Items)
            {
                <tr>
                    <td><a href="/collections/@c.Id/edit">@c.TitleEn</a></td>
                    <td><code>@c.Slug</code></td>
                    <td>
                        <span class="adm-badge @(c.IsSmart ? "adm-badge--info" : null)">@(c.IsSmart ? "Smart" : "Manual")</span>
                    </td>
                    <td>@c.ProductCount</td>
                    <td>
                        <span class="adm-badge @(c.IsActive ? "adm-badge--ok" : "adm-badge--warn")">@(c.IsActive ? "Active" : "Inactive")</span>
                    </td>
                    <td>@c.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td><a class="adm-btn" href="/collections/@c.Id/edit">Edit</a></td>
                </tr>
            }
            </tbody>
        </table>

        <div class="adm-panel__body">
            <partial name="_Pager" model="PagerInfo.From(Model.Collections)" />
        </div>
    }
</section>
