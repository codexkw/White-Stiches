@model OrderDetailViewModel
@{
    var o = Model.Order;
    ViewData["Title"] = $"Order {o.OrderNumber}";
    ViewData["Nav"] = "orders";
}
@section Styles {
    <link rel="stylesheet" href="~/css/modules/orders.css" asp-append-version="true" />
}

<div class="ord-head">
    <span class="adm-badge @OrderBadges.Status(o.Status)">@o.Status</span>
    <span class="adm-badge @OrderBadges.Payment(o.PaymentStatus)">@o.PaymentStatus</span>
    <span class="adm-badge @OrderBadges.Fulfillment(o.FulfillmentStatus)">@o.FulfillmentStatus</span>
    <span class="adm-badge">@o.Channel</span>
    <span class="ord-head__meta">
        @L["Placed"] @(o.PlacedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "—") UTC
        · @o.Items.Sum(i => i.Quantity) @L["item(s)"]
        · @o.Total.ToString("0.000") KWD
    </span>
    <a href="/orders/@o.Id/invoice" class="adm-btn">@L["Download invoice"]</a>
    <a href="/orders" class="adm-btn">@L["Back to orders"]</a>
</div>

<div class="ord-grid">
    <div class="ord-col">

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Items"]</h2></header>
            <table class="adm-table">
                <thead>
                    <tr><th>@L["Item"]</th><th>@L["Unit price"]</th><th>@L["Qty"]</th><th>@L["Line total"]</th></tr>
                </thead>
                <tbody>
                @foreach (var item in o.Items)
                {
                    <tr>
                        <td>
                            <strong>@item.Title()</strong>
                            @if (!string.IsNullOrEmpty(item.VariantDescription))
                            {
                                <br /><span class="adm-card__hint">@item.VariantDescription</span>
                            }
                            @if (!string.IsNullOrEmpty(item.Sku))
                            {
                                <br /><span class="adm-card__hint">SKU @item.Sku</span>
                            }
                        </td>
                        <td>@item.UnitPrice.ToString("0.000") KWD</td>
                        <td>@item.Quantity</td>
                        <td>@item.LineTotal.ToString("0.000") KWD</td>
                    </tr>
                }
                </tbody>
            </table>
            <div class="adm-panel__body">
                <table class="ord-totals">
                    <tr><td>@L["Subtotal"]</td><td>@o.Subtotal.ToString("0.000") KWD</td></tr>
                    <tr>
                        <td>@L["Discount"]@(string.IsNullOrEmpty(o.DiscountCodeSnapshot) ? "" : $" ({o.DiscountCodeSnapshot})")</td>
                        <td>−@o.DiscountAmount.ToString("0.000") KWD</td>
                    </tr>
                    <tr><td>@L["Shipping"]@(string.IsNullOrEmpty(o.ShippingMethodName) ? "" : $" ({o.ShippingMethodName})")</td><td>@o.ShippingAmount.ToString("0.000") KWD</td></tr>
                    @if (o.GiftWrap || o.GiftWrapFee > 0)
                    {
                        <tr><td>@L["Gift wrap"]</td><td>@o.GiftWrapFee.ToString("0.000") KWD</td></tr>
                    }
                    @if (o.TaxAmount > 0)
                    {
                        <tr><td>@L["Tax"]</td><td>@o.TaxAmount.ToString("0.000") KWD</td></tr>
                    }
                    <tr class="is-total"><td>@L["Total"]</td><td>@o.Total.ToString("0.000") KWD</td></tr>
                    <tr><td>@L["Paid"]</td><td>@Model.TotalPaid.ToString("0.000") KWD</td></tr>
                    <tr><td>@L["Refunded"]</td><td>@Model.TotalRefunded.ToString("0.000") KWD</td></tr>
                    <tr><td>@L["Refundable"]</td><td>@Model.RemainingRefundable.ToString("0.000") KWD</td></tr>
                </table>
            </div>
        </section>

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Payments"]</h2></header>
            @if (o.Payments.Count == 0)
            {
                <div class="adm-panel__body"><div class="adm-empty">@L["No payments recorded."]</div></div>
            }
            else
            {
                <table class="adm-table">
                    <thead><tr><th>@L["Provider"]</th><th>@L["Method"]</th><th>@L["Status"]</th><th>@L["Amount"]</th><th>@L["Reference"]</th><th>@L["Processed (UTC)"]</th></tr></thead>
                    <tbody>
                    @foreach (var p in o.Payments)
                    {
                        <tr>
                            <td>@p.Provider</td>
                            <td>@p.Method</td>
                            <td><span class="adm-badge @OrderBadges.Transaction(p.Status)">@p.Status</span></td>
                            <td>@p.Amount.ToString("0.000") @p.Currency</td>
                            <td>@(p.GatewayTransactionId ?? "—")</td>
                            <td>@(p.ProcessedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </section>

        @if (o.Refunds.Count > 0)
        {
            <section class="adm-panel">
                <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Refunds"]</h2></header>
                <table class="adm-table">
                    <thead><tr><th>@L["Amount"]</th><th>@L["Status"]</th><th>@L["Reason"]</th><th>@L["Processed (UTC)"]</th></tr></thead>
                    <tbody>
                    @foreach (var r in o.Refunds)
                    {
                        <tr>
                            <td>@r.Amount.ToString("0.000") KWD</td>
                            <td><span class="adm-badge @OrderBadges.Refund(r.Status)">@r.Status</span></td>
                            <td>@(r.Reason ?? "—")</td>
                            <td>@(r.ProcessedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </section>
        }

        @if (o.Shipments.Count > 0)
        {
            <section class="adm-panel">
                <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Shipments"]</h2></header>
                <table class="adm-table">
                    <thead><tr><th>@L["Carrier"]</th><th>@L["AWB"]</th><th>@L["Tracking"]</th><th>@L["Status"]</th><th>@L["Created (UTC)"]</th></tr></thead>
                    <tbody>
                    @foreach (var s in o.Shipments)
                    {
                        <tr>
                            <td>@(s.Carrier ?? "—")</td>
                            <td>@(s.AwbNumber ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(s.TrackingUrl))
                                {
                                    <a href="@s.TrackingUrl" target="_blank" rel="noopener">@L["Track"]</a>
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </td>
                            <td><span class="adm-badge @OrderBadges.Shipment(s.Status)">@s.Status</span></td>
                            <td>@s.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </section>
        }

        @if (o.ReturnRequests.Count > 0)
        {
            <section class="adm-panel">
                <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Return requests"]</h2></header>
                <table class="adm-table">
                    <thead><tr><th>@L["RMA"]</th><th>@L["Status"]</th><th>@L["Reason"]</th><th>@L["Created (UTC)"]</th></tr></thead>
                    <tbody>
                    @foreach (var r in o.ReturnRequests)
                    {
                        <tr>
                            <td><a href="/returns">@r.RmaNumber</a></td>
                            <td><span class="adm-badge @OrderBadges.Return(r.Status)">@r.Status</span></td>
                            <td>@(r.CustomerReason ?? "—")</td>
                            <td>@r.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </section>
        }

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Timeline"]</h2></header>
            <div class="adm-panel__body">
                <form asp-controller="Orders" asp-action="AddComment" asp-route-id="@o.Id" method="post" class="ord-inline-form">
                    <div class="adm-field">
                        <label for="comment-text">@L["Staff comment"]</label>
                        <input id="comment-text" type="text" name="text" placeholder="@L["Visible to staff only"]" required />
                    </div>
                    <button type="submit" class="adm-btn">@L["Add comment"]</button>
                </form>

                @if (o.Events.Count == 0)
                {
                    <div class="adm-empty">@L["No events yet."]</div>
                }
                else
                {
                    <ul class="ord-timeline">
                    @foreach (var e in o.Events)
                    {
                        <li>
                            <div class="ord-timeline__meta">
                                <span class="ord-timeline__kind">@e.Kind</span>
                                <span>@e.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</span>
                                @if (!string.IsNullOrEmpty(e.AuthorName))
                                {
                                    <span>@L["by"] @e.AuthorName</span>
                                }
                            </div>
                            @e.Description
                        </li>
                    }
                    </ul>
                }
            </div>
        </section>

    </div>
    <div class="ord-col">

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Customer"]</h2></header>
            <div class="adm-panel__body">
                <div class="ord-kv">
                    <div><span>@L["Name:"]</span> @o.ShipFirstName @o.ShipLastName</div>
                    <div><span>@L["Email:"]</span> @o.Email</div>
                    <div><span>@L["Phone:"]</span> @o.Phone</div>
                    <div><span>@L["Language:"]</span> @o.LanguageCode.ToUpperInvariant()</div>
                    @if (o.UserId is not null)
                    {
                        <div><a href="/customers/@o.UserId" class="adm-btn">@L["View customer"]</a></div>
                    }
                    else
                    {
                        <div><span>@L["Guest checkout"]</span></div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(o.CustomerNote))
                {
                    <p><span class="adm-card__hint">@L["Customer note:"]</span><br />@o.CustomerNote</p>
                }
            </div>
        </section>

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Shipping address"]</h2></header>
            <div class="adm-panel__body">
                <address class="ord-address">
                    @o.ShipFirstName @o.ShipLastName<br />
                    @if (!string.IsNullOrEmpty(o.ShipGovernorate)) { @o.ShipGovernorate <text>, </text> } @o.ShipArea<br />
                    @L["Block"] @o.ShipBlock, @o.ShipStreet, @L["Building"] @o.ShipBuilding<br />
                    @if (!string.IsNullOrEmpty(o.ShipFloor)) { <text>@L["Floor"] @o.ShipFloor</text> }
                    @if (!string.IsNullOrEmpty(o.ShipApartment)) { <text>, @L["Apt"] @o.ShipApartment</text> }
                    @if (!string.IsNullOrEmpty(o.ShipFloor) || !string.IsNullOrEmpty(o.ShipApartment)) { <br /> }
                    @o.ShipCountry · @o.ShipPhone
                    @if (!string.IsNullOrEmpty(o.ShipDirections))
                    {
                        <br /><span class="adm-card__hint">@o.ShipDirections</span>
                    }
                </address>
            </div>
        </section>

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Actions"]</h2></header>
            <div class="adm-panel__body ord-stack">

                <form asp-controller="Orders" asp-action="UpdateStatus" asp-route-id="@o.Id" method="post">
                    <h3>@L["Change status"]</h3>
                    <div class="ord-inline-form">
                        <div class="adm-field">
                            <label for="status-select">@L["Status"]</label>
                            <select id="status-select" name="status">
                                @foreach (var s in Enum.GetValues<OrderStatus>())
                                {
                                    <option value="@s" selected="@(o.Status == s)">@s</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="adm-btn">@L["Update"]</button>
                    </div>
                </form>

                <form asp-controller="Orders" asp-action="MarkPaid" asp-route-id="@o.Id" method="post">
                    <h3>@L["Mark paid (manual)"]</h3>
                    <div class="ord-inline-form">
                        <div class="adm-field adm-field--narrow">
                            <label for="paid-amount">@L["Amount (KWD)"]</label>
                            <input id="paid-amount" type="number" step="0.001" min="0" name="amount"
                                   placeholder="@o.Total.ToString("0.000")" />
                        </div>
                        <div class="adm-field">
                            <label for="paid-reference">@L["Reference"]</label>
                            <input id="paid-reference" type="text" name="reference" placeholder="KNET ref, bank transfer…" />
                        </div>
                        <button type="submit" class="adm-btn">@L["Mark paid"]</button>
                    </div>
                </form>

                <form asp-controller="Orders" asp-action="Fulfill" asp-route-id="@o.Id" method="post">
                    <h3>@L["Fulfil &amp; ship"]</h3>
                    <div class="ord-inline-form">
                        <div class="adm-field">
                            <label for="ship-carrier">@L["Carrier"]</label>
                            <input id="ship-carrier" type="text" name="carrier" placeholder="DHL, Aramex…" />
                        </div>
                        <div class="adm-field">
                            <label for="ship-tracking">@L["Tracking / AWB"]</label>
                            <input id="ship-tracking" type="text" name="trackingNumber" />
                        </div>
                        <div class="adm-field">
                            <label for="ship-url">@L["Tracking URL"]</label>
                            <input id="ship-url" type="text" name="trackingUrl" placeholder="https://…" />
                        </div>
                        <button type="submit" class="adm-btn">@L["Create shipment"]</button>
                    </div>
                </form>

                <form asp-controller="Orders" asp-action="RefundOrder" asp-route-id="@o.Id" method="post">
                    <h3>@L["Refund"]</h3>
                    <div class="ord-inline-form">
                        <div class="adm-field adm-field--narrow">
                            <label for="refund-amount">@L["Amount (KWD)"]</label>
                            <input id="refund-amount" type="number" step="0.001" min="0.001"
                                   max="@Model.RemainingRefundable.ToString("0.000")" name="amount" required />
                        </div>
                        <div class="adm-field">
                            <label for="refund-reason">@L["Reason"]</label>
                            <input id="refund-reason" type="text" name="reason" />
                        </div>
                        <button type="submit" class="adm-btn">@L["Refund"]</button>
                    </div>
                    <p class="adm-card__hint">@L["Refundable:"] @Model.RemainingRefundable.ToString("0.000") KWD</p>
                </form>

                @if (o.Status != OrderStatus.Cancelled)
                {
                    <form asp-controller="Orders" asp-action="Cancel" asp-route-id="@o.Id" method="post">
                        <h3>@L["Cancel order"]</h3>
                        <div class="ord-inline-form">
                            <div class="adm-field">
                                <label for="cancel-reason">@L["Reason"]</label>
                                <input id="cancel-reason" type="text" name="reason" required />
                            </div>
                            <div class="adm-field adm-field--check">
                                <input id="cancel-restock" type="checkbox" name="restock" value="true" />
                                <label for="cancel-restock">@L["Restock items"]</label>
                            </div>
                            <button type="submit" class="adm-btn">@L["Cancel order"]</button>
                        </div>
                    </form>
                }
                else
                {
                    <p class="adm-card__hint">
                        @L["Cancelled"] @(o.CancelledAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "") UTC — @o.CancelReason
                    </p>
                }

                <form asp-controller="Orders" asp-action="SaveNote" asp-route-id="@o.Id" method="post">
                    <h3>@L["Internal note"]</h3>
                    <div class="adm-field">
                        <label for="internal-note">@L["Staff-only note"]</label>
                        <textarea id="internal-note" name="internalNote">@o.InternalNote</textarea>
                    </div>
                    <button type="submit" class="adm-btn">@L["Save note"]</button>
                </form>

            </div>
        </section>

    </div>
</div>
