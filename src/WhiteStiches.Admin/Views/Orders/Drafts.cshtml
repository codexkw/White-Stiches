@model DraftListViewModel
@{
    ViewData["Title"] = L["Draft orders"];
    ViewData["Nav"] = "orders";
}

<section class="adm-toolbar">
    <form method="get" class="adm-toolbar__filters">
        <div class="adm-field">
            <label for="channel">@L["Channel"]</label>
            <select id="channel" name="channel">
                <option value="">@L["All"]</option>
                @foreach (var c in new[] { OrderChannel.Instagram, OrderChannel.WhatsApp, OrderChannel.Phone })
                {
                    <option value="@c" selected="@(Model.Channel == c)">@c</option>
                }
            </select>
        </div>
        <div class="adm-field">
            <label for="search">@L["Search"]</label>
            <input id="search" type="text" name="search" value="@Model.Search"
                   placeholder="@L["Number, email, name, phone"]" />
        </div>
        <button type="submit" class="adm-btn">@L["Filter"]</button>
        <a href="/orders/drafts" class="adm-btn">@L["Reset"]</a>
    </form>
    <div class="adm-actions">
        <a href="/orders" class="adm-btn">@L["All orders"]</a>
        <a href="/orders/drafts/new" class="adm-btn adm-btn--solid">@L["New draft"]</a>
    </div>
</section>

<section class="adm-panel">
    <header class="adm-panel__head">
        <h2 class="adm-panel__title">@L["Draft orders"] (@Model.Drafts.TotalCount)</h2>
    </header>
    <table class="adm-table">
        <thead>
            <tr>
                <th>@L["Number"]</th>
                <th>@L["Created (UTC)"]</th>
                <th>@L["Customer"]</th>
                <th>@L["Channel"]</th>
                <th>@L["Items"]</th>
                <th>@L["Total"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Drafts.Items.Count == 0)
        {
            <tr>
                <td colspan="7">
                    <div class="adm-empty">
                        <strong>@L["No draft orders"]</strong>
                        @L["Create one for an Instagram, WhatsApp, or phone sale."]
                    </div>
                </td>
            </tr>
        }
        @foreach (var o in Model.Drafts.Items)
        {
            <tr>
                <td><a href="/orders/drafts/@o.Id"><strong>@o.OrderNumber</strong></a></td>
                <td>@o.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    @o.ShipFirstName @o.ShipLastName<br />
                    <span class="adm-card__hint">@(string.IsNullOrEmpty(o.Email) ? o.Phone : o.Email)</span>
                </td>
                <td>@o.Channel</td>
                <td>@o.Items.Sum(i => i.Quantity)</td>
                <td>@o.Total.ToString("0.000") KWD</td>
                <td><a href="/orders/drafts/@o.Id" class="adm-btn">@L["Edit"]</a></td>
            </tr>
        }
        </tbody>
    </table>
    <div class="adm-panel__body">
        <partial name="_Pager" model="PagerInfo.From(Model.Drafts)" />
    </div>
</section>
