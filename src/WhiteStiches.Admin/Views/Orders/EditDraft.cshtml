@model DraftEditViewModel
@{
    var o = Model.Order;
    ViewData["Title"] = $"Draft {o.OrderNumber}";
    ViewData["Nav"] = "orders";
}
@section Styles {
    <link rel="stylesheet" href="~/css/modules/orders.css" asp-append-version="true" />
}

<div class="ord-head">
    <span class="adm-badge adm-badge--warn">Draft</span>
    <span class="adm-badge">@o.Channel</span>
    <span class="ord-head__meta">
        Created @o.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC
        · @o.Items.Sum(i => i.Quantity) item(s)
        · @o.Total.ToString("0.000") KWD
    </span>
    <a href="/orders/drafts" class="adm-btn">Back to drafts</a>
</div>

<div class="ord-grid">
    <div class="ord-col">

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">Items</h2></header>
            <table class="adm-table">
                <thead>
                    <tr><th>Item</th><th>Unit price</th><th>Qty</th><th>Line total</th><th></th></tr>
                </thead>
                <tbody>
                @if (o.Items.Count == 0)
                {
                    <tr>
                        <td colspan="5">
                            <div class="adm-empty">
                                <strong>No items yet</strong>
                                Use the product picker below to add items.
                            </div>
                        </td>
                    </tr>
                }
                @foreach (var item in o.Items)
                {
                    <tr>
                        <td>
                            <strong>@item.TitleEn</strong>
                            @if (!string.IsNullOrEmpty(item.VariantDescription))
                            {
                                <br /><span class="adm-card__hint">@item.VariantDescription</span>
                            }
                            @if (!string.IsNullOrEmpty(item.Sku))
                            {
                                <br /><span class="adm-card__hint">SKU @item.Sku</span>
                            }
                        </td>
                        <td>@item.UnitPrice.ToString("0.000") KWD</td>
                        <td>@item.Quantity</td>
                        <td>@item.LineTotal.ToString("0.000") KWD</td>
                        <td>
                            <form asp-controller="Orders" asp-action="RemoveDraftItem"
                                  asp-route-id="@o.Id" asp-route-itemId="@item.Id" method="post">
                                <button type="submit" class="adm-btn">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </section>

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">Add products</h2></header>
            <div class="adm-panel__body">
                <form method="get" class="ord-inline-form">
                    <div class="adm-field">
                        <label for="productSearch">Search active products</label>
                        <input id="productSearch" type="text" name="productSearch" value="@Model.ProductSearch"
                               placeholder="Title, handle, or SKU" />
                    </div>
                    <button type="submit" class="adm-btn">Search</button>
                </form>

                @if (!string.IsNullOrWhiteSpace(Model.ProductSearch))
                {
                    @if (Model.ProductResults.Count == 0)
                    {
                        <div class="adm-empty">No active products match "@Model.ProductSearch".</div>
                    }
                    else
                    {
                        <table class="adm-table">
                            <thead>
                                <tr><th>Product / variant</th><th>Price</th><th>Stock</th><th>Add</th></tr>
                            </thead>
                            <tbody>
                            @foreach (var product in Model.ProductResults)
                            {
                                foreach (var variant in product.Variants)
                                {
                                    var options = string.Join(" / ", new[] { variant.Option1, variant.Option2, variant.Option3 }
                                        .Where(x => !string.IsNullOrWhiteSpace(x)));
                                    <tr>
                                        <td>
                                            <strong>@product.TitleEn</strong>
                                            @if (!string.IsNullOrEmpty(options))
                                            {
                                                <br /><span class="adm-card__hint">@options</span>
                                            }
                                            @if (!string.IsNullOrEmpty(variant.Sku))
                                            {
                                                <br /><span class="adm-card__hint">SKU @variant.Sku</span>
                                            }
                                        </td>
                                        <td>@variant.Price.ToString("0.000") KWD</td>
                                        <td>
                                            @variant.StockQuantity
                                            @if (variant.AllowOversell)
                                            {
                                                <span class="adm-card__hint">(oversell ok)</span>
                                            }
                                        </td>
                                        <td>
                                            <form asp-controller="Orders" asp-action="AddDraftItem"
                                                  asp-route-id="@o.Id" method="post" class="ord-picker-variant">
                                                <input type="hidden" name="variantId" value="@variant.Id" />
                                                <input type="hidden" name="productSearch" value="@Model.ProductSearch" />
                                                <input type="number" name="quantity" value="1" min="1"
                                                       style="width:70px;" aria-label="Quantity" />
                                                <button type="submit" class="adm-btn">Add</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    }
                }
            </div>
        </section>

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">Totals</h2></header>
            <div class="adm-panel__body">
                <table class="ord-totals">
                    <tr><td>Subtotal</td><td>@o.Subtotal.ToString("0.000") KWD</td></tr>
                    <tr><td>Discount</td><td>−@o.DiscountAmount.ToString("0.000") KWD</td></tr>
                    <tr><td>Shipping</td><td>@o.ShippingAmount.ToString("0.000") KWD</td></tr>
                    <tr class="is-total"><td>Total</td><td>@o.Total.ToString("0.000") KWD</td></tr>
                </table>
            </div>
        </section>

    </div>
    <div class="ord-col">

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">Draft details</h2></header>
            <div class="adm-panel__body">
                <form asp-controller="Orders" asp-action="UpdateDraft" asp-route-id="@o.Id" method="post">
                    <div class="adm-form-grid">
                        <div class="adm-field">
                            <label for="shippingAmount">Shipping (KWD)</label>
                            <input id="shippingAmount" type="number" step="0.001" min="0"
                                   name="shippingAmount" value="@o.ShippingAmount.ToString("0.000")" />
                        </div>
                        <div class="adm-field">
                            <label for="discountAmount">Manual discount (KWD)</label>
                            <input id="discountAmount" type="number" step="0.001" min="0"
                                   name="discountAmount" value="@o.DiscountAmount.ToString("0.000")" />
                        </div>
                        <div class="adm-field">
                            <label for="email">Email</label>
                            <input id="email" type="email" name="email" value="@o.Email" />
                        </div>
                        <div class="adm-field">
                            <label for="phone">Phone</label>
                            <input id="phone" type="text" name="phone" value="@o.Phone" />
                        </div>
                        <div class="adm-field">
                            <label for="shipFirstName">First name</label>
                            <input id="shipFirstName" type="text" name="shipFirstName" value="@o.ShipFirstName" />
                        </div>
                        <div class="adm-field">
                            <label for="shipLastName">Last name</label>
                            <input id="shipLastName" type="text" name="shipLastName" value="@o.ShipLastName" />
                        </div>
                        <div class="adm-field">
                            <label for="shipPhone">Shipping phone</label>
                            <input id="shipPhone" type="text" name="shipPhone" value="@o.ShipPhone" />
                        </div>
                        <div class="adm-field">
                            <label for="shipGovernorate">Governorate</label>
                            <input id="shipGovernorate" type="text" name="shipGovernorate" value="@o.ShipGovernorate" />
                        </div>
                        <div class="adm-field">
                            <label for="shipArea">Area</label>
                            <input id="shipArea" type="text" name="shipArea" value="@o.ShipArea" />
                        </div>
                        <div class="adm-field">
                            <label for="shipBlock">Block</label>
                            <input id="shipBlock" type="text" name="shipBlock" value="@o.ShipBlock" />
                        </div>
                        <div class="adm-field">
                            <label for="shipStreet">Street</label>
                            <input id="shipStreet" type="text" name="shipStreet" value="@o.ShipStreet" />
                        </div>
                        <div class="adm-field">
                            <label for="shipBuilding">Building</label>
                            <input id="shipBuilding" type="text" name="shipBuilding" value="@o.ShipBuilding" />
                        </div>
                        <div class="adm-field">
                            <label for="shipFloor">Floor</label>
                            <input id="shipFloor" type="text" name="shipFloor" value="@o.ShipFloor" />
                        </div>
                        <div class="adm-field">
                            <label for="shipApartment">Apartment</label>
                            <input id="shipApartment" type="text" name="shipApartment" value="@o.ShipApartment" />
                        </div>
                        <div class="adm-field is-full">
                            <label for="shipDirections">Directions</label>
                            <input id="shipDirections" type="text" name="shipDirections" value="@o.ShipDirections" />
                        </div>
                        <div class="adm-field is-full">
                            <label for="customerNote">Customer note</label>
                            <textarea id="customerNote" name="customerNote">@o.CustomerNote</textarea>
                        </div>
                    </div>
                    <div class="adm-actions" style="margin-top:16px;">
                        <button type="submit" class="adm-btn adm-btn--solid">Save draft</button>
                    </div>
                </form>
            </div>
        </section>

        <section class="adm-panel">
            <header class="adm-panel__head"><h2 class="adm-panel__title">Finish</h2></header>
            <div class="adm-panel__body ord-stack">
                <form asp-controller="Orders" asp-action="ConvertDraft" asp-route-id="@o.Id" method="post">
                    <h3>Convert to order</h3>
                    <p class="adm-card__hint">
                        Validates items, decrements stock, and places the order as @o.OrderNumber.
                    </p>
                    <button type="submit" class="adm-btn adm-btn--solid">Convert to order</button>
                </form>
                <form asp-controller="Orders" asp-action="DeleteDraft" asp-route-id="@o.Id" method="post">
                    <h3>Delete draft</h3>
                    <p class="adm-card__hint">Permanently removes this draft and its items.</p>
                    <button type="submit" class="adm-btn">Delete draft</button>
                </form>
            </div>
        </section>

    </div>
</div>
