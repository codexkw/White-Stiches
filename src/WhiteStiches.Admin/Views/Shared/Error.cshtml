@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error · White Stitches Admin</title>
    <link rel="icon" type="image/svg+xml" href="~/assets/logo-mark.svg" />
    <link rel="stylesheet" href="~/css/design-system.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
</head>
<body>
<div class="adm-login">
    <div class="adm-login__card">
        <img src="~/assets/logo-full.png" alt="White Stitches" />
        <span class="adm-login__eyebrow">@L["Something went wrong"]</span>
        <p style="color:#b8b2a6">@L["An unexpected error occurred. The team has been notified — try again, or head back to the dashboard."]</p>
        <a class="adm-btn adm-btn--solid adm-login__submit" href="/" style="margin-top:16px">@L["Back to dashboard"]</a>
    </div>
</div>
</body>
</html>
