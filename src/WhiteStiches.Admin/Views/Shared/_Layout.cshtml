@using System.Globalization
@{
    var ci = CultureInfo.CurrentUICulture;
    var dir = ci.TextInfo.IsRightToLeft ? "rtl" : "ltr";
    var lang = ci.TwoLetterISOLanguageName;
    var otherLang = lang == "ar" ? "en" : "ar";
    var langLabel = lang == "ar" ? "EN" : "ع";
    var returnPath = Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString);
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · White Stitches Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="~/assets/logo-mark.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600&family=Inter+Tight:wght@300;400;500;600&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/design-system.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/rtl.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/editor.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="adm">

    <aside class="adm-side">
        <a href="/" class="adm-side__logo" aria-label="White Stitches Admin home">
            <img src="~/assets/logo-full.png" alt="White Stitches" />
        </a>

        <nav class="adm-nav" aria-label="Admin navigation">
            @{ var nav = ViewData["Nav"] as string; }
            <div class="adm-side__label">@L["Store"]</div>
            <a href="/" class="@(nav == "dashboard" ? "is-active" : null)">@L["Dashboard"]</a>
            <a href="/orders" class="@(nav == "orders" ? "is-active" : null)">@L["Orders"]</a>
            <a href="/returns" class="@(nav == "returns" ? "is-active" : null)">@L["Returns"]</a>
            <a href="/products" class="@(nav == "products" ? "is-active" : null)">@L["Products"]</a>
            <a href="/categories" class="@(nav == "categories" ? "is-active" : null)">@L["Categories"]</a>
            <a href="/collections" class="@(nav == "collections" ? "is-active" : null)">@L["Collections"]</a>
            <a href="/customers" class="@(nav == "customers" ? "is-active" : null)">@L["Customers"]</a>

            <div class="adm-side__label">@L["Marketing"]</div>
            <a href="/discounts" class="@(nav == "discounts" ? "is-active" : null)">@L["Discounts"]</a>
            <a href="/newsletter" class="@(nav == "newsletter" ? "is-active" : null)">@L["Newsletter"]</a>
            <a href="/banners" class="@(nav == "banners" ? "is-active" : null)">@L["Banners"]</a>

            <div class="adm-side__label">@L["Content"]</div>
            <a href="/pages" class="@(nav == "pages" ? "is-active" : null)">@L["Pages"]</a>
            <a href="/journal" class="@(nav == "journal" ? "is-active" : null)">@L["Journal"]</a>
            <a href="/inbox" class="@(nav == "inbox" ? "is-active" : null)">@L["Inbox"]</a>

            <div class="adm-side__label">@L["System"]</div>
            <a href="/reports" class="@(nav == "reports" ? "is-active" : null)">@L["Reports"]</a>
            <a href="/settings" class="@(nav == "settings" ? "is-active" : null)">@L["Settings"]</a>
            <a href="/staff" class="@(nav == "staff" ? "is-active" : null)">@L["Staff & Roles"]</a>
            <a href="/audit" class="@(nav == "audit" ? "is-active" : null)">@L["Audit Log"]</a>
        </nav>
    </aside>

    <div class="adm-main">
        <header class="adm-top">
            <h1 class="adm-top__title">@ViewData["Title"]</h1>
            <div class="adm-top__user">
                <a class="adm-btn adm-btn--ghost" href="/set-culture?culture=@otherLang&returnUrl=@returnPath" title="@L["Language"]">@langLabel</a>
                <span>@User.Identity?.Name</span>
                <form asp-controller="Auth" asp-action="Logout" method="post">
                    <button type="submit" class="adm-btn">@L["Sign out"]</button>
                </form>
            </div>
        </header>

        <main class="adm-content">
            @if (TempData["Ok"] is string ok)
            {
                <div class="adm-toast adm-toast--ok" role="status">@ok</div>
            }
            @if (TempData["Err"] is string err)
            {
                <div class="adm-toast adm-toast--err" role="alert">@err</div>
            }
            @RenderBody()
        </main>
    </div>

</div>
<script src="~/js/editor.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
