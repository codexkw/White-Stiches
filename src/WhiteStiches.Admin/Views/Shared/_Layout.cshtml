<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · White Stitches Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="~/assets/logo-mark.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600&family=Inter+Tight:wght@300;400;500;600&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/design-system.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="adm">

    <aside class="adm-side">
        <a href="/" class="adm-side__logo" aria-label="White Stitches Admin home">
            <img src="~/assets/logo-full.png" alt="White Stitches" />
        </a>

        <nav class="adm-nav" aria-label="Admin navigation">
            @{ var nav = ViewData["Nav"] as string; }
            <div class="adm-side__label">Store</div>
            <a href="/" class="@(nav == "dashboard" ? "is-active" : null)">Dashboard</a>
            <a href="/orders" class="@(nav == "orders" ? "is-active" : null)">Orders</a>
            <a href="/returns" class="@(nav == "returns" ? "is-active" : null)">Returns</a>
            <a href="/products" class="@(nav == "products" ? "is-active" : null)">Products</a>
            <a href="/categories" class="@(nav == "categories" ? "is-active" : null)">Categories</a>
            <a href="/collections" class="@(nav == "collections" ? "is-active" : null)">Collections</a>
            <a href="/customers" class="@(nav == "customers" ? "is-active" : null)">Customers</a>

            <div class="adm-side__label">Marketing</div>
            <a href="/discounts" class="@(nav == "discounts" ? "is-active" : null)">Discounts</a>
            <a href="/newsletter" class="@(nav == "newsletter" ? "is-active" : null)">Newsletter</a>

            <div class="adm-side__label">Content</div>
            <a href="/pages" class="@(nav == "pages" ? "is-active" : null)">Pages</a>
            <a href="/journal" class="@(nav == "journal" ? "is-active" : null)">Journal</a>
            <a href="/inbox" class="@(nav == "inbox" ? "is-active" : null)">Inbox</a>

            <div class="adm-side__label">System</div>
            <a href="/settings" class="@(nav == "settings" ? "is-active" : null)">Settings</a>
            <a href="/staff" class="@(nav == "staff" ? "is-active" : null)">Staff &amp; Roles</a>
            <a href="/audit" class="@(nav == "audit" ? "is-active" : null)">Audit Log</a>
        </nav>
    </aside>

    <div class="adm-main">
        <header class="adm-top">
            <h1 class="adm-top__title">@ViewData["Title"]</h1>
            <div class="adm-top__user">
                <span>@User.Identity?.Name</span>
                <form asp-controller="Auth" asp-action="Logout" method="post">
                    <button type="submit" class="adm-btn">Sign out</button>
                </form>
            </div>
        </header>

        <main class="adm-content">
            @if (TempData["Ok"] is string ok)
            {
                <div class="adm-toast adm-toast--ok" role="status">@ok</div>
            }
            @if (TempData["Err"] is string err)
            {
                <div class="adm-toast adm-toast--err" role="alert">@err</div>
            }
            @RenderBody()
        </main>
    </div>

</div>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
