@using WhiteStiches.Core.Interfaces
@model WhiteStiches.Admin.Models.SettingsIndexViewModel
@{
    ViewData["Title"] = "Settings";
    ViewData["Nav"] = "settings";
}

@section Styles {
    <link rel="stylesheet" href="~/css/modules/settings.css" asp-append-version="true" />
}

<div class="adm-toolbar">
    <p class="set-note">@L["Each panel saves independently. Money values are KWD with 3 decimals."]</p>
    <div class="adm-actions">
        <a class="adm-btn" href="/profile/2fa">@L["My two-factor authentication"]</a>
    </div>
</div>

<section class="adm-panel">
    <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Store details"]</h2></header>
    <div class="adm-panel__body">
        <form asp-controller="Settings" asp-action="Save" asp-route-group="store" method="post">
            <div class="adm-form-grid">
                <div class="adm-field">
                    <label for="set-name-en">@L["Store name (EN)"]</label>
                    <input id="set-name-en" name="store.name.en" value="@Model.Get(SettingKeys.StoreNameEn)" />
                </div>
                <div class="adm-field">
                    <label for="set-name-ar">@L["Store name (AR)"]</label>
                    <input id="set-name-ar" name="store.name.ar" dir="rtl" value="@Model.Get(SettingKeys.StoreNameAr)" />
                </div>
                <div class="adm-field">
                    <label for="set-email">@L["Contact email"]</label>
                    <input id="set-email" name="store.contact.email" type="email" value="@Model.Get(SettingKeys.ContactEmail)" />
                </div>
                <div class="adm-field">
                    <label for="set-phone">@L["Contact phone"]</label>
                    <input id="set-phone" name="store.contact.phone" value="@Model.Get(SettingKeys.ContactPhone)" />
                </div>
                <div class="adm-field">
                    <label for="set-whatsapp">@L["WhatsApp number"]</label>
                    <input id="set-whatsapp" name="store.whatsapp.number" value="@Model.Get(SettingKeys.WhatsAppNumber)" />
                </div>
            </div>
            <div class="adm-actions set-actions">
                <button type="submit" class="adm-btn adm-btn--solid">@L["Save store details"]</button>
            </div>
        </form>
    </div>
</section>

<section class="adm-panel">
    <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Social links"]</h2></header>
    <div class="adm-panel__body">
        <form asp-controller="Settings" asp-action="Save" asp-route-group="social" method="post">
            <div class="adm-form-grid">
                <div class="adm-field">
                    <label for="set-instagram">@L["Instagram URL"]</label>
                    <input id="set-instagram" name="store.social.instagram" type="url" value="@Model.Get(SettingKeys.InstagramUrl)" placeholder="https://instagram.com/..." />
                </div>
                <div class="adm-field">
                    <label for="set-tiktok">@L["TikTok URL"]</label>
                    <input id="set-tiktok" name="store.social.tiktok" type="url" value="@Model.Get(SettingKeys.TikTokUrl)" placeholder="https://tiktok.com/@@..." />
                </div>
                <div class="adm-field">
                    <label for="set-pinterest">@L["Pinterest URL"]</label>
                    <input id="set-pinterest" name="store.social.pinterest" type="url" value="@Model.Get(SettingKeys.PinterestUrl)" placeholder="https://pinterest.com/..." />
                </div>
            </div>
            <div class="adm-actions set-actions">
                <button type="submit" class="adm-btn adm-btn--solid">@L["Save social links"]</button>
            </div>
        </form>
    </div>
</section>

<section class="adm-panel">
    <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Shipping rates (KWD)"]</h2></header>
    <div class="adm-panel__body">
        <form asp-controller="Settings" asp-action="Save" asp-route-group="shipping" method="post">
            <div class="adm-form-grid">
                <div class="adm-field">
                    <label for="set-free">@L["Free shipping threshold"]</label>
                    <input id="set-free" name="shipping.free_threshold" type="number" step="0.001" min="0" value="@Model.GetMoney(SettingKeys.FreeShippingThreshold)" />
                </div>
                <div class="adm-field">
                    <label for="set-standard">@L["Standard rate"]</label>
                    <input id="set-standard" name="shipping.standard_rate" type="number" step="0.001" min="0" value="@Model.GetMoney(SettingKeys.StandardShippingRate)" />
                </div>
                <div class="adm-field">
                    <label for="set-express">@L["Express rate"]</label>
                    <input id="set-express" name="shipping.express_rate" type="number" step="0.001" min="0" value="@Model.GetMoney(SettingKeys.ExpressShippingRate)" />
                </div>
                <div class="adm-field">
                    <label for="set-sameday">@L["Same-day rate"]</label>
                    <input id="set-sameday" name="shipping.same_day_rate" type="number" step="0.001" min="0" value="@Model.GetMoney(SettingKeys.SameDayShippingRate)" />
                </div>
            </div>
            <div class="adm-actions set-actions">
                <button type="submit" class="adm-btn adm-btn--solid">@L["Save shipping rates"]</button>
            </div>
        </form>
    </div>
</section>

<section class="adm-panel">
    <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Cart"]</h2></header>
    <div class="adm-panel__body">
        <form asp-controller="Settings" asp-action="Save" asp-route-group="cart" method="post">
            <div class="adm-form-grid">
                <div class="adm-field">
                    <label for="set-giftwrap">@L["Gift wrap fee (KWD)"]</label>
                    <input id="set-giftwrap" name="cart.gift_wrap_fee" type="number" step="0.001" min="0" value="@Model.GetMoney(SettingKeys.GiftWrapFee)" />
                </div>
            </div>
            <div class="adm-actions set-actions">
                <button type="submit" class="adm-btn adm-btn--solid">@L["Save cart settings"]</button>
            </div>
        </form>
    </div>
</section>

<section class="adm-panel">
    <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Tickers"]</h2></header>
    <div class="adm-panel__body">
        <p class="set-note">@L["Two scrolling tickers — the header bar and the strip under the hero. One message per line, per language. Untick to hide a ticker."]</p>
        <form asp-controller="Settings" asp-action="Save" asp-route-group="ticker" method="post">
            <div class="adm-field adm-field--check">
                <input type="hidden" name="ticker.header.enabled" value="false" />
                <input id="set-th-on" type="checkbox" name="ticker.header.enabled" value="true" checked="@(Model.GetBool(SettingKeys.TickerHeaderEnabled) ? "checked" : null)" />
                <label for="set-th-on">@L["Show header ticker"]</label>
            </div>
            <div class="adm-form-grid">
                <div class="adm-field">
                    <label for="set-th-en">@L["Header ticker — messages (EN)"]</label>
                    <textarea id="set-th-en" name="ticker.header.en" rows="4">@Model.Get(SettingKeys.TickerHeaderEn)</textarea>
                </div>
                <div class="adm-field">
                    <label for="set-th-ar">@L["Header ticker — messages (AR)"]</label>
                    <textarea id="set-th-ar" name="ticker.header.ar" dir="rtl" rows="4">@Model.Get(SettingKeys.TickerHeaderAr)</textarea>
                </div>
            </div>

            <div class="adm-field adm-field--check">
                <input type="hidden" name="ticker.hero.enabled" value="false" />
                <input id="set-hh-on" type="checkbox" name="ticker.hero.enabled" value="true" checked="@(Model.GetBool(SettingKeys.TickerHeroEnabled) ? "checked" : null)" />
                <label for="set-hh-on">@L["Show hero marquee (under banner)"]</label>
            </div>
            <div class="adm-form-grid">
                <div class="adm-field">
                    <label for="set-hh-en">@L["Hero marquee — messages (EN)"]</label>
                    <textarea id="set-hh-en" name="ticker.hero.en" rows="4">@Model.Get(SettingKeys.TickerHeroEn)</textarea>
                </div>
                <div class="adm-field">
                    <label for="set-hh-ar">@L["Hero marquee — messages (AR)"]</label>
                    <textarea id="set-hh-ar" name="ticker.hero.ar" dir="rtl" rows="4">@Model.Get(SettingKeys.TickerHeroAr)</textarea>
                </div>
            </div>

            <div class="adm-actions set-actions">
                <button type="submit" class="adm-btn adm-btn--solid">@L["Save tickers"]</button>
            </div>
        </form>
    </div>
</section>

<section class="adm-panel">
    <header class="adm-panel__head"><h2 class="adm-panel__title">@L["Maintenance"]</h2></header>
    <div class="adm-panel__body">
        <form asp-controller="Settings" asp-action="Save" asp-route-group="maintenance" method="post">
            <div class="adm-field adm-field--check">
                <input type="hidden" name="store.maintenance_mode" value="false" />
                <input id="set-maintenance" type="checkbox" name="store.maintenance_mode" value="true" checked="@Model.GetBool(SettingKeys.MaintenanceMode)" />
                <label for="set-maintenance">@L["Maintenance mode — storefront shows a holding page"]</label>
            </div>
            <div class="adm-actions set-actions">
                <button type="submit" class="adm-btn adm-btn--solid">@L["Save maintenance mode"]</button>
            </div>
        </form>
    </div>
</section>
