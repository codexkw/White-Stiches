@using WhiteStiches.Core.Models.Admin
@model CustomerListViewModel
@{
    ViewData["Title"] = "Customers";
    ViewData["Nav"] = "customers";
}

<section class="adm-toolbar" aria-label="@L["Customer filters"]">
    <form method="get" action="/customers" class="adm-toolbar__filters">
        <div class="adm-field">
            <label for="q">@L["Search"]</label>
            <input type="search" id="q" name="q" value="@Model.Search" placeholder="@L["Name, email, or phone"]" />
        </div>
        <div class="adm-actions">
            <button type="submit" class="adm-btn adm-btn--solid">@L["Search"]</button>
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <a href="/customers" class="adm-btn">@L["Clear"]</a>
            }
        </div>
    </form>
    <div class="adm-actions">
        <span>@Model.Customers.TotalCount customer@(Model.Customers.TotalCount == 1 ? "" : "s")</span>
    </div>
</section>

<section class="adm-panel">
    <header class="adm-panel__head">
        <h2 class="adm-panel__title">@L["Customer directory"]</h2>
    </header>

    @if (Model.Customers.Items.Count == 0)
    {
        <div class="adm-panel__body">
            <div class="adm-empty">
                <strong>@L["No customers found"]</strong>
                @(string.IsNullOrWhiteSpace(Model.Search)
                    ? L["Registered shoppers will appear here."].Value
                    : L["Try a different name, email, or phone number."].Value)
            </div>
        </div>
    }
    else
    {
        <table class="adm-table">
            <thead>
                <tr>
                    <th>@L["Customer"]</th>
                    <th>@L["Email"]</th>
                    <th>@L["Phone"]</th>
                    <th>@L["Orders"]</th>
                    <th>@L["Total spent"]</th>
                    <th>@L["Consent"]</th>
                    <th>@L["Registered (UTC)"]</th>
                    <th>@L["Status"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Customers.Items)
                {
                    <tr>
                        <td>
                            <a href="/customers/@c.UserId">
                                @(string.IsNullOrWhiteSpace(c.FullName) ? c.Email : c.FullName)
                            </a>
                        </td>
                        <td>@c.Email</td>
                        <td>@(string.IsNullOrWhiteSpace(c.Phone) ? "—" : c.Phone)</td>
                        <td>@c.OrdersCount</td>
                        <td>KWD @c.TotalSpent.ToString("0.000")</td>
                        <td>
                            @if (c.EmailOptIn)
                            {
                                <span class="adm-badge adm-badge--ok">@L["Email"]</span>
                            }
                            @if (c.WhatsAppOptIn)
                            {
                                <span class="adm-badge adm-badge--ok">@L["WhatsApp"]</span>
                            }
                            @if (!c.EmailOptIn && !c.WhatsAppOptIn)
                            {
                                <span>—</span>
                            }
                        </td>
                        <td>@c.RegisteredAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (c.IsLockedOut)
                            {
                                <span class="adm-badge adm-badge--err">@L["Locked"]</span>
                            }
                            else
                            {
                                <span class="adm-badge adm-badge--ok">@L["Active"]</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="adm-panel__body">
            <partial name="_Pager" model="PagerInfo.From(Model.Customers)" />
        </div>
    }
</section>
