@using WhiteStiches.Core.Models.Admin
@model CustomerDetailViewModel
@{
    var c = Model.Customer;
    ViewData["Title"] = string.IsNullOrWhiteSpace(c.FullName) ? c.Email : c.FullName;
    ViewData["Nav"] = "customers";
}

@section Styles {
    <link rel="stylesheet" href="~/css/modules/customers.css" asp-append-version="true" />
}

@functions {
    private static string StatusBadge(OrderStatus status) => status switch
    {
        OrderStatus.Paid or OrderStatus.Delivered => "adm-badge adm-badge--ok",
        OrderStatus.Placed => "adm-badge adm-badge--warn",
        OrderStatus.Fulfilled or OrderStatus.Shipped or OrderStatus.Refunded => "adm-badge adm-badge--info",
        OrderStatus.Cancelled => "adm-badge adm-badge--err",
        _ => "adm-badge"
    };
}

<section class="adm-toolbar" aria-label="@L["Customer actions"]">
    <div class="adm-actions">
        <a href="/customers" class="adm-btn">&lsaquo; @L["All customers"]</a>
        @if (c.IsLockedOut)
        {
            <span class="adm-badge adm-badge--err">@L["Locked"]</span>
        }
        else
        {
            <span class="adm-badge adm-badge--ok">@L["Active"]</span>
        }
    </div>
    <div class="adm-actions">
        @if (c.IsLockedOut)
        {
            <form method="post" asp-controller="Customers" asp-action="Unlock" asp-route-userId="@c.UserId">
                <button type="submit" class="adm-btn adm-btn--solid">@L["Unlock account"]</button>
            </form>
        }
        else
        {
            <form method="post" asp-controller="Customers" asp-action="Lock" asp-route-userId="@c.UserId">
                <button type="submit" class="adm-btn">@L["Lock account"]</button>
            </form>
        }
    </div>
</section>

<section class="adm-stats" aria-label="@L["Customer snapshot"]">
    <div class="adm-card">
        <div class="adm-card__label">@L["Orders"]</div>
        <div class="adm-card__value">@c.OrdersCount</div>
        <div class="adm-card__hint">@L["placed (excl. drafts)"]</div>
    </div>
    <div class="adm-card">
        <div class="adm-card__label">@L["Total spent"]</div>
        <div class="adm-card__value">@c.TotalSpent.ToString("0.000")</div>
        <div class="adm-card__hint">@L["KWD, excl. cancelled"]</div>
    </div>
    <div class="adm-card">
        <div class="adm-card__label">@L["Wishlist"]</div>
        <div class="adm-card__value">@c.WishlistCount</div>
        <div class="adm-card__hint">@L["saved items"]</div>
    </div>
</section>

<div class="cust-cols">
    <section class="adm-panel">
        <header class="adm-panel__head">
            <h2 class="adm-panel__title">@L["Identity"]</h2>
        </header>
        <div class="adm-panel__body">
            <dl class="cust-dl">
                <dt>@L["Name"]</dt>
                <dd>@(string.IsNullOrWhiteSpace(c.FullName) ? "—" : c.FullName)</dd>

                <dt>@L["Email"]</dt>
                <dd>@c.Email</dd>

                <dt>@L["Phone"]</dt>
                <dd>@(string.IsNullOrWhiteSpace(c.Phone) ? "—" : c.Phone)</dd>

                <dt>@L["Preferred language"]</dt>
                <dd>@(c.PreferredLanguage == "ar" ? "Arabic (ar)" : "English (en)")</dd>

                <dt>@L["Registered"]</dt>
                <dd>@c.RegisteredAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</dd>

                <dt>@L["Last login"]</dt>
                <dd>@(c.LastLoginAtUtc is DateTime last ? $"{last:yyyy-MM-dd HH:mm} UTC" : L["Never"].Value)</dd>
            </dl>
        </div>
    </section>

    <section class="adm-panel">
        <header class="adm-panel__head">
            <h2 class="adm-panel__title">@L["Marketing consent"]</h2>
        </header>
        <div class="adm-panel__body">
            <div class="cust-consent">
                <div class="cust-consent__row">
                    <span>@L["Email marketing"]</span>
                    @if (c.EmailOptIn)
                    {
                        <span class="adm-badge adm-badge--ok">@L["Opted in"]</span>
                    }
                    else
                    {
                        <span class="adm-badge">@L["Not opted in"]</span>
                    }
                </div>
                <div class="cust-consent__row">
                    <span>@L["WhatsApp marketing"]</span>
                    @if (c.WhatsAppOptIn)
                    {
                        <span class="adm-badge adm-badge--ok">@L["Opted in"]</span>
                    }
                    else
                    {
                        <span class="adm-badge">@L["Not opted in"]</span>
                    }
                </div>
            </div>
            <p class="cust-consent__meta">
                @L["Consent preferences recorded with the account, registered"]
                @c.RegisteredAtUtc.ToString("yyyy-MM-dd HH:mm") UTC.
            </p>
        </div>
    </section>
</div>

<section class="adm-panel">
    <header class="adm-panel__head">
        <h2 class="adm-panel__title">@L["Addresses"]</h2>
    </header>
    <div class="adm-panel__body">
        @if (c.Addresses.Count == 0)
        {
            <div class="adm-empty">
                <strong>@L["No saved addresses"]</strong>
                @L["This customer has not added a delivery address yet."]
            </div>
        }
        else
        {
            <div class="cust-addr-grid">
                @foreach (var a in c.Addresses)
                {
                    <article class="cust-addr">
                        <header class="cust-addr__head">
                            <span class="cust-addr__label">@(string.IsNullOrWhiteSpace(a.Label) ? L["Address"].Value : a.Label)</span>
                            @if (a.IsDefault)
                            {
                                <span class="adm-badge adm-badge--info">@L["Default"]</span>
                            }
                        </header>
                        <div class="cust-addr__body">
                            <div>@a.FirstName @a.LastName</div>
                            <div>@a.Phone</div>
                            <div>@a.Governorate · @a.Area</div>
                            <div>@L["Block"] @a.Block, @a.Street, @L["Building"] @a.Building</div>
                            @if (!string.IsNullOrWhiteSpace(a.Floor) || !string.IsNullOrWhiteSpace(a.Apartment))
                            {
                                <div>
                                    @if (!string.IsNullOrWhiteSpace(a.Floor))
                                    {
                                        <text>@L["Floor"] @a.Floor</text>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(a.Floor) && !string.IsNullOrWhiteSpace(a.Apartment))
                                    {
                                        <text>, </text>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(a.Apartment))
                                    {
                                        <text>@L["Apt"] @a.Apartment</text>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(a.Directions))
                            {
                                <div class="cust-addr__directions">@a.Directions</div>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>

<section class="adm-panel">
    <header class="adm-panel__head">
        <h2 class="adm-panel__title">@L["Recent orders"]</h2>
    </header>

    @if (c.RecentOrders.Items.Count == 0)
    {
        <div class="adm-panel__body">
            <div class="adm-empty">
                <strong>@L["No orders yet"]</strong>
                @L["Orders placed by this customer will appear here."]
            </div>
        </div>
    }
    else
    {
        <table class="adm-table">
            <thead>
                <tr>
                    <th>@L["Order"]</th>
                    <th>@L["Date (UTC)"]</th>
                    <th>@L["Total"]</th>
                    <th>@L["Status"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in c.RecentOrders.Items)
                {
                    <tr>
                        <td><a href="/orders/@o.Id">@o.OrderNumber</a></td>
                        <td>@((o.PlacedAtUtc ?? o.CreatedAtUtc).ToString("yyyy-MM-dd HH:mm"))</td>
                        <td>KWD @o.Total.ToString("0.000")</td>
                        <td><span class="@StatusBadge(o.Status)">@o.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="adm-panel__body">
            <partial name="_Pager" model="PagerInfo.From(c.RecentOrders)" />
        </div>
    }
</section>
