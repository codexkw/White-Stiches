@model CategoryListViewModel
@{
    ViewData["Title"] = "Categories";
    ViewData["Nav"] = "categories";
}

<div class="adm-form-grid" style="grid-template-columns: 2fr 1fr; align-items: start;">

    <section class="adm-panel">
        <header class="adm-panel__head">
            <h2 class="adm-panel__title">Category tree</h2>
            <span>@Model.Rows.Count total</span>
        </header>
        @if (Model.Rows.Count == 0)
        {
            <div class="adm-panel__body">
                <div class="adm-empty"><strong>No categories yet</strong> Create the first one on the right.</div>
            </div>
        }
        else
        {
            <table class="adm-table">
                <thead>
                    <tr><th>Name</th><th>Slug</th><th>Products</th><th>Status</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>
                                @Html.Raw(string.Concat(Enumerable.Repeat("&nbsp;&nbsp;&nbsp;&nbsp;", row.Depth)))
                                <strong>@row.Category.NameEn</strong>
                                @if (!string.IsNullOrEmpty(row.Category.NameAr))
                                {
                                    <span style="color:#6b665c"> · @row.Category.NameAr</span>
                                }
                            </td>
                            <td>@row.Category.Slug</td>
                            <td>@row.ProductCount</td>
                            <td>
                                @if (row.Category.IsActive)
                                {
                                    <span class="adm-badge adm-badge--ok">Active</span>
                                }
                                else
                                {
                                    <span class="adm-badge">Hidden</span>
                                }
                            </td>
                            <td>
                                <div class="adm-actions">
                                    <a class="adm-btn" href="/categories?edit=@row.Category.Id">Edit</a>
                                    <form action="/categories/@row.Category.Id/delete" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="adm-btn">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="adm-panel">
        <header class="adm-panel__head">
            <h2 class="adm-panel__title">@(Model.IsEditing ? "Edit category" : "New category")</h2>
            @if (Model.IsEditing)
            {
                <a href="/categories" class="adm-btn">Cancel</a>
            }
        </header>
        <div class="adm-panel__body">
            <form asp-controller="Categories" asp-action="Save" method="post">
                <input type="hidden" asp-for="Form.Id" />

                <div class="adm-field">
                    <label asp-for="Form.NameEn">Name (EN)</label>
                    <input asp-for="Form.NameEn" />
                </div>
                <div class="adm-field">
                    <label asp-for="Form.NameAr">Name (AR)</label>
                    <input asp-for="Form.NameAr" dir="rtl" />
                </div>
                <div class="adm-field">
                    <label asp-for="Form.Slug">Slug (blank = from name)</label>
                    <input asp-for="Form.Slug" placeholder="auto" />
                </div>
                <div class="adm-field">
                    <label asp-for="Form.ParentId">Parent</label>
                    <select asp-for="Form.ParentId">
                        <option value="">— top level —</option>
                        @foreach (var c in Model.ParentChoices)
                        {
                            <option value="@c.Id">@c.Label</option>
                        }
                    </select>
                </div>
                <div class="adm-field">
                    <label asp-for="Form.SortOrder">Sort order</label>
                    <input asp-for="Form.SortOrder" type="number" />
                </div>
                <div class="adm-field adm-field--check">
                    <input asp-for="Form.IsActive" />
                    <label asp-for="Form.IsActive">Active</label>
                </div>

                <div class="adm-actions">
                    <button type="submit" class="adm-btn adm-btn--solid">@(Model.IsEditing ? "Save category" : "Create category")</button>
                </div>
            </form>
        </div>
    </section>

</div>
