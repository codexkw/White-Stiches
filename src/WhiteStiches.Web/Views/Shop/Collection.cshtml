@model WhiteStiches.Web.Models.Shop.CollectionViewModel
@using System.Globalization
@using WhiteStiches.Web.Models.Shop
@{
    ViewData["Title"] = $"{Model.BannerTitle} · Spring/Summer 2026 · White Stitches";
    ViewData["MetaDescription"] = $"Discover the {Model.BannerTitle} edit from White Stitches — handcrafted pieces designed and finished in our Kuwait atelier.";

    var total = Model.Products.TotalCount;
    var isEmpty = total == 0;

    static IEnumerable<WhiteStiches.Core.Entities.Catalog.Category> Flatten(IEnumerable<WhiteStiches.Core.Entities.Catalog.Category> categories) =>
        categories.SelectMany(c => new[] { c }.Concat(Flatten(c.Children)));
    var allCategories = Flatten(Model.Categories).ToList();

    // Sizes & colours are now sourced from real variant data (Model.SizeOptions / Model.ColorOptions),
    // so every swatch maps to products that exist. This map only supplies a display hex per colour
    // name; unrecognised colours fall back to a neutral swatch.
    var colorHex = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Black"] = "#0a0a0a", ["Oat"] = "#d4cdbc", ["Ivory"] = "#f5f1ea", ["Sand"] = "#c2a98a",
        ["Stone"] = "#a8a29a", ["Champagne"] = "#e6d8b8", ["Ink"] = "#1a1f2e", ["White"] = "#f4f4f4",
        ["Silver"] = "#c7cacb", ["Bone"] = "#e3dccb", ["Olive"] = "#7a8a76", ["Tan"] = "#b08d57",
        ["Camel"] = "#c19a6b", ["Charcoal"] = "#3a3a3a", ["Gold"] = "#c8a96a", ["Forest"] = "#2b3b2f",
        ["Burgundy"] = "#5a2a2a"
    };
    string Hex(string name) => colorHex.TryGetValue(name, out var h) ? h : "#9a9a9a";
    var quickRanges = new (decimal? Min, decimal? Max, string Label)[]
    {
        (null, 30m, "Under 30 KWD"),
        (30m, 60m, "30 – 60 KWD"),
        (60m, 100m, "60 – 100 KWD"),
        (100m, null, "Over 100 KWD")
    };

    var sortOptions = new (string Value, string Label)[]
    {
        ("featured", "Featured"),
        ("newest", "Newest"),
        ("bestselling", "Best-selling"),
        ("price-asc", "Price · low to high"),
        ("price-desc", "Price · high to low"),
        ("alpha", "Alphabetical")
    };

    // Pagination tokens (-1 = ellipsis)
    var totalPages = Model.Products.TotalPages;
    var current = Model.Products.Page;
    var pageTokens = new List<int>();
    if (totalPages > 1)
    {
        var shown = new SortedSet<int> { 1, totalPages };
        for (var i = current - 1; i <= current + 1; i++)
        {
            if (i >= 1 && i <= totalPages) shown.Add(i);
        }
        int? prev = null;
        foreach (var n in shown)
        {
            if (prev is not null && n - prev.Value > 1) { pageTokens.Add(-1); }
            pageTokens.Add(n);
            prev = n;
        }
    }
}

<!-- ============================ COLLECTION BANNER ============================ -->
<section class="coll-banner">
  <div class="coll-banner__bg" aria-hidden="true"></div>
  <div class="coll-banner__inner">
    <span class="eyebrow">@L["Spring · Summer 2026"]</span>
    <h1 class="coll-banner__title">@Model.BannerTitle</h1>
    <p class="coll-banner__intro">
      @L["A curated edit of cuts, fabrics and silhouettes — designed for the woman who measures luxury in stitches, not labels."]
    </p>
  </div>
</section>

<!-- ============================ BREADCRUMB ============================ -->
<nav class="breadcrumb" aria-label="Breadcrumb">
  <div class="breadcrumb__inner">
    <a href="/">@L["Home"]</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__current">@Model.BannerTitle</span>
  </div>
</nav>

<!-- ============================ COLLECTION TOOLBAR (sort + filter toggle) ============================ -->
<section class="coll-toolbar">
  <div class="coll-toolbar__inner">
    <button class="coll-toolbar__filter-btn" id="filterToggle" type="button" aria-controls="filterSidebar" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 6h16M7 12h10M10 18h4"/></svg>
      <span>@L["Filter"]</span>
      <span class="coll-toolbar__filter-count" id="activeFilterCount" hidden="@(Model.ActiveFilterCount == 0)">@Model.ActiveFilterCount</span>
    </button>
    <div class="coll-toolbar__count" id="resultCount">@total @(total == 1 ? L["piece"].Value : L["pieces"].Value)</div>
    <div class="coll-toolbar__sort">
      <label for="sortSelect" class="visually-hidden">@L["Sort by"]</label>
      <select id="sortSelect" class="sort-select" name="sort" form="filterForm" onchange="this.form && this.form.submit()">
        @foreach (var option in sortOptions)
        {
          <option value="@option.Value" selected="@(string.Equals(Model.Sort, option.Value, StringComparison.OrdinalIgnoreCase))">@option.Label</option>
        }
      </select>
      <svg class="sort-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
    </div>
  </div>
</section>

<!-- ============================ COLLECTION GRID ============================ -->
<section class="coll">
  <div class="coll__inner">

    <!-- ── FILTER SIDEBAR (desktop) / SLIDE-IN SHEET (mobile) ────────── -->
    <aside class="filter" id="filterSidebar" aria-label="Filter products">
      <div class="filter__head">
        <h2 class="filter__title">@L["Filter"]</h2>
        <button type="button" class="filter__close" id="filterClose" aria-label="@L["Close filters"]">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>

      <!-- Active filter chips (server-rendered) -->
      @if (Model.Chips.Count > 0)
      {
        <div class="filter__chips">
          @foreach (var chip in Model.Chips)
          {
            <span class="chip">
              <span>@chip.Label</span>
              <a class="chip__remove" href="@chip.RemoveUrl" aria-label="Remove @chip.Label filter">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 6l12 12M18 6L6 18"/></svg>
              </a>
            </span>
          }
        </div>
      }
      <!-- Inert stub keeps the legacy demo chip module from touching the page -->
      <div class="filter__chips" id="filterChips" style="display:none" hidden></div>

      <form id="filterForm" method="get" action="@Model.BasePath" style="display:flex;flex-direction:column;gap:var(--s-2)">

        <!-- Category -->
        <details class="filter-group" open>
          <summary class="filter-group__head">
            <span>@L["Category"]</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="filter-group__body">
            @foreach (var category in allCategories)
            {
              <label class="check"><input type="checkbox" name="category" value="@category.Slug" checked="@(string.Equals(Model.Category, category.Slug, StringComparison.OrdinalIgnoreCase))" /><span>@category.Name()</span></label>
            }
          </div>
        </details>

        <!-- Size -->
        <details class="filter-group" open>
          <summary class="filter-group__head">
            <span>@L["Size"]</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="filter-group__body">
            <div class="filter-sizes">
              @foreach (var size in Model.SizeOptions)
              {
                <label class="size-pill"><input type="checkbox" name="size" value="@size" checked="@(string.Equals(Model.Size, size, StringComparison.OrdinalIgnoreCase))" /><span>@size</span></label>
              }
            </div>
          </div>
        </details>

        <!-- Colour -->
        <details class="filter-group" open>
          <summary class="filter-group__head">
            <span>@L["Colour"]</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="filter-group__body">
            <div class="filter-colors">
              @foreach (var color in Model.ColorOptions)
              {
                <label class="color-dot" title="@color"><input type="checkbox" name="color" value="@color" checked="@(Model.Colors.Any(c => string.Equals(c, color, StringComparison.OrdinalIgnoreCase)))" /><span style="background:@Hex(color)"></span><em>@color</em></label>
              }
            </div>
          </div>
        </details>

        <!-- Price -->
        <details class="filter-group" open>
          <summary class="filter-group__head">
            <span>@L["Price (KWD)"]</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="filter-group__body">
            <div class="filter-price">
              <div class="filter-price__inputs">
                <input type="number" id="priceMin" name="min" value="@(Model.Min?.ToString("0.###", CultureInfo.InvariantCulture))" placeholder="@L["From"]" min="0" step="any" aria-label="@L["Minimum price"]" />
                <span>—</span>
                <input type="number" id="priceMax" name="max" value="@(Model.Max?.ToString("0.###", CultureInfo.InvariantCulture))" placeholder="@L["To"]" min="0" step="any" aria-label="@L["Maximum price"]" />
              </div>
              <div class="filter-price__quick">
                @foreach (var range in quickRanges)
                {
                  <label class="check"><input type="checkbox" data-price-quick data-min="@(range.Min?.ToString("0.###", CultureInfo.InvariantCulture))" data-max="@(range.Max?.ToString("0.###", CultureInfo.InvariantCulture))" checked="@(Model.Min == range.Min && Model.Max == range.Max && (Model.Min is not null || Model.Max is not null))" /><span>@range.Label</span></label>
                }
              </div>
            </div>
          </div>
        </details>

        <!-- Availability -->
        <details class="filter-group">
          <summary class="filter-group__head">
            <span>@L["Availability"]</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="filter-group__body">
            <label class="check"><input type="checkbox" name="instock" value="true" checked="@Model.InStock" /><span>@L["In stock"]</span></label>
          </div>
        </details>

        <div class="filter__foot">
          <a class="btn btn--ghost filter__clear" id="filterClear" href="@Model.BasePath">@L["Clear all"]</a>
          <button type="submit" class="btn btn--primary filter__apply" id="filterApply">@L["Show results"]</button>
        </div>
      </form>
    </aside>

    <!-- Filter overlay (mobile only) -->
    <div class="filter-overlay" id="filterOverlay" aria-hidden="true"></div>

    <!-- ── PRODUCT GRID ─────────────────────────────────────────────── -->
    <div class="coll__main @(isEmpty ? "is-empty" : null)">

      <!-- Skeleton loading state (hidden by default — toggle .is-loading on .coll__main to show) -->
      <div class="coll__skeleton" aria-hidden="true">
        <div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>
        <div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>
        <div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>
      </div>

      @if (isEmpty)
      {
        <!-- Empty state -->
        <div class="coll__empty">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
            <circle cx="28" cy="28" r="14"/>
            <path d="m48 48-10-10"/>
            <path d="M22 28h12M28 22v12" opacity="0"/>
          </svg>
          <h3>@L["No pieces match those filters."]</h3>
          <p>@L["Try widening one of your selections or clearing the filters to see the full edit."]</p>
          <a class="btn btn--ghost" id="emptyClear" href="@Model.BasePath">@L["Clear all filters"]</a>
        </div>
      }
      else
      {
        <!-- Product grid (default state) -->
        <div class="coll__grid">
          @foreach (var product in Model.Products.Items)
          {
            <partial name="_ProductCard" model="product" />
          }
        </div>
      }

      @if (totalPages > 1)
      {
        <!-- ── PAGINATION ──────────────────────────────────────────────── -->
        <nav class="pagination" aria-label="@L["Pagination"]">
          @if (Model.Products.HasPrevious)
          {
            <a class="pagination__btn pagination__btn--prev" href="@Model.PageUrl(current - 1)" aria-label="@L["Previous page"]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg>
            </a>
          }
          else
          {
            <button class="pagination__btn pagination__btn--prev" disabled aria-label="@L["Previous page"]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg>
            </button>
          }
          <ol class="pagination__nums">
            @foreach (var token in pageTokens)
            {
              if (token == -1)
              {
                <li class="pagination__ellipsis" aria-hidden="true">…</li>
              }
              else if (token == current)
              {
                <li><a href="@Model.PageUrl(token)" class="is-active" aria-current="page">@token</a></li>
              }
              else
              {
                <li><a href="@Model.PageUrl(token)">@token</a></li>
              }
            }
          </ol>
          @if (Model.Products.HasNext)
          {
            <a class="pagination__btn pagination__btn--next" href="@Model.PageUrl(current + 1)" aria-label="@L["Next page"]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 6l6 6-6 6"/></svg>
            </a>
          }
          else
          {
            <button class="pagination__btn pagination__btn--next" disabled aria-label="@L["Next page"]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 6l6 6-6 6"/></svg>
            </button>
          }
        </nav>
      }

      <!-- SEO copy block (optional, helps category page rank) -->
      <div class="coll__seo">
        <h2>@L["The"] @Model.BannerTitle @L["Edit · Spring/Summer 2026"]</h2>
        <p>The SS26 collection from White Stitches is a study in quiet luxury — natural fibers, weightless drape, and a palette borrowed from desert mornings. Every piece is designed and hand-finished in our Kuwait atelier, then shipped across the GCC.</p>
        <p>Browse linen midi dresses, tailored linen-viscose trousers, hand-knit cashmere, and editorial silk pieces — all built for the woman who measures luxury in stitches, not labels. Looking for something specific? Use the filter to narrow by size, colour, or price.</p>
      </div>

    </div>
  </div>
</section>

@section Scripts {
<script>
  (function () {
    var form = document.getElementById('filterForm');
    if (!form) return;

    // Radio-like behavior: a single selection per filter group.
    // Colour is intentionally excluded — it supports multi-select checkboxes.
    ['category', 'size'].forEach(function (group) {
      var boxes = form.querySelectorAll('input[type="checkbox"][name="' + group + '"]');
      boxes.forEach(function (box) {
        box.addEventListener('change', function () {
          if (box.checked) {
            boxes.forEach(function (other) { if (other !== box) other.checked = false; });
          }
        });
      });
    });

    // Quick price ranges fill the min/max inputs (single selection)
    var minInput = document.getElementById('priceMin');
    var maxInput = document.getElementById('priceMax');
    var quicks = form.querySelectorAll('input[type="checkbox"][data-price-quick]');
    quicks.forEach(function (box) {
      box.addEventListener('change', function () {
        if (box.checked) {
          quicks.forEach(function (other) { if (other !== box) other.checked = false; });
          if (minInput) minInput.value = box.dataset.min || '';
          if (maxInput) maxInput.value = box.dataset.max || '';
        } else {
          if (minInput) minInput.value = '';
          if (maxInput) maxInput.value = '';
        }
      });
    });
  })();
</script>
}
