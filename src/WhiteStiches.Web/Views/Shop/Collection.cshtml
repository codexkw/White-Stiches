@{
    ViewData["Title"] = "Women · Spring/Summer 2026 · White Stitches";
    ViewData["MetaDescription"] = "Discover the Women's SS26 edit from White Stitches — handcrafted dresses, trousers, knits and outerwear, finished in our Kuwait atelier.";
}

<!-- ============================ COLLECTION BANNER ============================ -->
<section class="coll-banner">
  <div class="coll-banner__bg" aria-hidden="true"></div>
  <div class="coll-banner__inner">
    <span class="eyebrow">Spring · Summer 2026</span>
    <h1 class="coll-banner__title">Women</h1>
    <p class="coll-banner__intro">
      A curated edit of cuts, fabrics and silhouettes — designed for the woman who measures luxury in stitches, not labels.
    </p>
  </div>
</section>

<!-- ============================ BREADCRUMB ============================ -->
<nav class="breadcrumb" aria-label="Breadcrumb">
  <div class="breadcrumb__inner">
    <a href="/">Home</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__current">Women</span>
  </div>
</nav>

<!-- ============================ COLLECTION TOOLBAR (sort + filter toggle) ============================ -->
<section class="coll-toolbar">
  <div class="coll-toolbar__inner">
    <button class="coll-toolbar__filter-btn" id="filterToggle" type="button" aria-controls="filterSidebar" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 6h16M7 12h10M10 18h4"/></svg>
      <span>Filter</span>
      <span class="coll-toolbar__filter-count" id="activeFilterCount" hidden>0</span>
    </button>
    <div class="coll-toolbar__count" id="resultCount">128 pieces</div>
    <div class="coll-toolbar__sort">
      <label for="sortSelect" class="visually-hidden">Sort by</label>
      <select id="sortSelect" class="sort-select">
        <option value="featured">Featured</option>
        <option value="newest">Newest</option>
        <option value="bestselling">Best-selling</option>
        <option value="price-asc">Price · low to high</option>
        <option value="price-desc">Price · high to low</option>
        <option value="alpha">Alphabetical</option>
      </select>
      <svg class="sort-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
    </div>
  </div>
</section>

<!-- ============================ COLLECTION GRID ============================ -->
<section class="coll">
  <div class="coll__inner">

    <!-- ── FILTER SIDEBAR (desktop) / SLIDE-IN SHEET (mobile) ────────── -->
    <aside class="filter" id="filterSidebar" aria-label="Filter products">
      <div class="filter__head">
        <h2 class="filter__title">Filter</h2>
        <button type="button" class="filter__close" id="filterClose" aria-label="Close filters">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>

      <!-- Active filter chips -->
      <div class="filter__chips" id="filterChips" hidden>
        <!-- JS injects chips here -->
      </div>

      <!-- Category -->
      <details class="filter-group" open>
        <summary class="filter-group__head">
          <span>Category</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <label class="check"><input type="checkbox" name="category" value="dresses" /><span>Dresses <em>32</em></span></label>
          <label class="check"><input type="checkbox" name="category" value="tops" /><span>Tops &amp; Blouses <em>28</em></span></label>
          <label class="check"><input type="checkbox" name="category" value="trousers" /><span>Trousers <em>21</em></span></label>
          <label class="check"><input type="checkbox" name="category" value="knitwear" /><span>Knitwear <em>14</em></span></label>
          <label class="check"><input type="checkbox" name="category" value="outerwear" /><span>Outerwear <em>11</em></span></label>
          <label class="check"><input type="checkbox" name="category" value="skirts" /><span>Skirts <em>9</em></span></label>
          <label class="check"><input type="checkbox" name="category" value="kaftans" /><span>Abayas &amp; Kaftans <em>13</em></span></label>
        </div>
      </details>

      <!-- Size -->
      <details class="filter-group" open>
        <summary class="filter-group__head">
          <span>Size</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <div class="filter-sizes">
            <label class="size-pill"><input type="checkbox" name="size" value="XS" /><span>XS</span></label>
            <label class="size-pill"><input type="checkbox" name="size" value="S" /><span>S</span></label>
            <label class="size-pill"><input type="checkbox" name="size" value="M" /><span>M</span></label>
            <label class="size-pill"><input type="checkbox" name="size" value="L" /><span>L</span></label>
            <label class="size-pill"><input type="checkbox" name="size" value="XL" /><span>XL</span></label>
            <label class="size-pill"><input type="checkbox" name="size" value="XXL" /><span>XXL</span></label>
          </div>
        </div>
      </details>

      <!-- Colour -->
      <details class="filter-group" open>
        <summary class="filter-group__head">
          <span>Colour</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <div class="filter-colors">
            <label class="color-dot" title="Black"><input type="checkbox" name="color" value="black" /><span style="background:#0a0a0a"></span><em>Black</em></label>
            <label class="color-dot" title="Oat"><input type="checkbox" name="color" value="oat" /><span style="background:#d4cdbc"></span><em>Oat</em></label>
            <label class="color-dot" title="Ivory"><input type="checkbox" name="color" value="ivory" /><span style="background:#f5f1ea"></span><em>Ivory</em></label>
            <label class="color-dot" title="Sand"><input type="checkbox" name="color" value="sand" /><span style="background:#c2a98a"></span><em>Sand</em></label>
            <label class="color-dot" title="Olive"><input type="checkbox" name="color" value="olive" /><span style="background:#7a8a76"></span><em>Olive</em></label>
            <label class="color-dot" title="Burgundy"><input type="checkbox" name="color" value="burgundy" /><span style="background:#5a2a2a"></span><em>Burgundy</em></label>
            <label class="color-dot" title="Gold"><input type="checkbox" name="color" value="gold" /><span style="background:#c8a96a"></span><em>Gold</em></label>
            <label class="color-dot" title="Charcoal"><input type="checkbox" name="color" value="charcoal" /><span style="background:#3a3a3a"></span><em>Charcoal</em></label>
          </div>
        </div>
      </details>

      <!-- Price -->
      <details class="filter-group" open>
        <summary class="filter-group__head">
          <span>Price (KWD)</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <div class="filter-price">
            <div class="filter-price__inputs">
              <input type="number" id="priceMin" placeholder="From" min="0" aria-label="Minimum price" />
              <span>—</span>
              <input type="number" id="priceMax" placeholder="To" min="0" aria-label="Maximum price" />
            </div>
            <div class="filter-price__quick">
              <label class="check"><input type="checkbox" name="price" value="0-30" /><span>Under 30 KWD</span></label>
              <label class="check"><input type="checkbox" name="price" value="30-60" /><span>30 – 60 KWD</span></label>
              <label class="check"><input type="checkbox" name="price" value="60-100" /><span>60 – 100 KWD</span></label>
              <label class="check"><input type="checkbox" name="price" value="100+" /><span>Over 100 KWD</span></label>
            </div>
          </div>
        </div>
      </details>

      <!-- Fabric -->
      <details class="filter-group">
        <summary class="filter-group__head">
          <span>Fabric</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <label class="check"><input type="checkbox" name="fabric" value="linen" /><span>Linen <em>34</em></span></label>
          <label class="check"><input type="checkbox" name="fabric" value="silk" /><span>Silk <em>18</em></span></label>
          <label class="check"><input type="checkbox" name="fabric" value="cotton" /><span>Cotton <em>26</em></span></label>
          <label class="check"><input type="checkbox" name="fabric" value="cashmere" /><span>Cashmere <em>8</em></span></label>
          <label class="check"><input type="checkbox" name="fabric" value="wool" /><span>Wool <em>12</em></span></label>
          <label class="check"><input type="checkbox" name="fabric" value="viscose" /><span>Viscose <em>15</em></span></label>
        </div>
      </details>

      <!-- Occasion -->
      <details class="filter-group">
        <summary class="filter-group__head">
          <span>Occasion</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <label class="check"><input type="checkbox" name="occasion" value="everyday" /><span>Everyday</span></label>
          <label class="check"><input type="checkbox" name="occasion" value="workwear" /><span>Workwear</span></label>
          <label class="check"><input type="checkbox" name="occasion" value="evening" /><span>Evening</span></label>
          <label class="check"><input type="checkbox" name="occasion" value="resort" /><span>Resort</span></label>
          <label class="check"><input type="checkbox" name="occasion" value="ramadan" /><span>Ramadan &amp; Eid</span></label>
          <label class="check"><input type="checkbox" name="occasion" value="wedding-guest" /><span>Wedding Guest</span></label>
        </div>
      </details>

      <!-- Availability -->
      <details class="filter-group">
        <summary class="filter-group__head">
          <span>Availability</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <label class="check"><input type="checkbox" name="availability" value="in-stock" /><span>In stock</span></label>
          <label class="check"><input type="checkbox" name="availability" value="on-sale" /><span>On sale</span></label>
          <label class="check"><input type="checkbox" name="availability" value="new" /><span>New arrivals</span></label>
        </div>
      </details>

      <div class="filter__foot">
        <button type="button" class="btn btn--ghost filter__clear" id="filterClear">Clear all</button>
        <button type="button" class="btn btn--primary filter__apply" id="filterApply">Show results</button>
      </div>
    </aside>

    <!-- Filter overlay (mobile only) -->
    <div class="filter-overlay" id="filterOverlay" aria-hidden="true"></div>

    <!-- ── PRODUCT GRID ─────────────────────────────────────────────── -->
    <div class="coll__main">

      <!-- Skeleton loading state (hidden by default — toggle .is-loading on .coll__main to show) -->
      <div class="coll__skeleton" aria-hidden="true">
        <div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>
        <div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>
        <div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>
      </div>

      <!-- Empty state (hidden by default — toggle .is-empty on .coll__main to show) -->
      <div class="coll__empty">
