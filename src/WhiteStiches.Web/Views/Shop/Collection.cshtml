          <circle cx="28" cy="28" r="14"/>
          <path d="m48 48-10-10"/>
          <path d="M22 28h12M28 22v12" opacity="0"/>
        </svg>
        <h3>No pieces match those filters.</h3>
        <p>Try widening one of your selections or clearing the filters to see the full edit.</p>
        <button type="button" class="btn btn--ghost" id="emptyClear">Clear all filters</button>
      </div>

