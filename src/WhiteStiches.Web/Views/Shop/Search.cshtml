@{
    ViewData["Title"] = "Search Results · White Stitches";
    ViewData["MetaDescription"] = "Search results — find your piece across the White Stitches edit.";
}

<!-- ============================ SEARCH HEADER ============================ -->
<section class="search-head">
  <div class="search-head__inner">
    <form class="search-head__form" id="searchForm" role="search" onsubmit="event.preventDefault(); window.handleSearchSubmit && window.handleSearchSubmit();">
      <button type="submit" class="search-head__submit" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </button>
      <input
        type="search"
        id="searchInput"
        class="search-head__input"
        placeholder="Search dresses, linen, evening..."
        aria-label="Search the store"
        autocomplete="off"
        value="linen midi"
      />
      <button type="button" class="search-head__clear" id="searchClear" aria-label="Clear search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </form>

    <div class="search-head__meta" id="searchMeta">
      <span class="search-head__count"><strong id="searchCount">42</strong> results for <em id="searchQuery">"linen midi"</em></span>
      <span class="search-head__hint" id="searchHint">
        Did you mean
        <button type="button" class="link-arrow link-arrow--inline" id="suggestionBtn">linen midi dresses</button>?
      </span>
    </div>

    <!-- Search refinement chips: type filter at a glance -->
    <div class="search-refine" role="tablist" aria-label="Refine results by type">
      <button type="button" class="search-refine__chip is-active" role="tab" aria-selected="true">
        Products <em>42</em>
      </button>
      <button type="button" class="search-refine__chip" role="tab" aria-selected="false">
        Collections <em>3</em>
      </button>
      <button type="button" class="search-refine__chip" role="tab" aria-selected="false">
        Journal <em>2</em>
      </button>
    </div>
  </div>
</section>

<!-- ============================ TOOLBAR (reused from collection) ============================ -->
<section class="coll-toolbar">
  <div class="coll-toolbar__inner">
    <button class="coll-toolbar__filter-btn" id="filterToggle" type="button" aria-controls="filterSidebar" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 6h16M7 12h10M10 18h4"/></svg>
      <span>Filter</span>
      <span class="coll-toolbar__filter-count" id="activeFilterCount" hidden>0</span>
    </button>
    <div class="coll-toolbar__count" id="resultCount">42 pieces</div>
    <div class="coll-toolbar__sort">
      <label for="sortSelect" class="visually-hidden">Sort by</label>
      <select id="sortSelect" class="sort-select">
        <option value="relevance">Most relevant</option>
        <option value="newest">Newest</option>
        <option value="bestselling">Best-selling</option>
        <option value="price-asc">Price · low to high</option>
        <option value="price-desc">Price · high to low</option>
      </select>
      <svg class="sort-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
    </div>
  </div>
</section>

<!-- ============================ GRID (reuses .coll layout) ============================ -->
<section class="coll">
  <div class="coll__inner">

    <!-- ── FILTER SIDEBAR (reduced set — fabric/occasion most useful for search) -->
    <aside class="filter" id="filterSidebar" aria-label="Filter results">
      <div class="filter__head">
        <h2 class="filter__title">Filter</h2>
        <button type="button" class="filter__close" id="filterClose" aria-label="Close filters">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>

      <div class="filter__chips" id="filterChips" hidden></div>

      <details class="filter-group" open>
        <summary class="filter-group__head">
          <span>Category</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <label class="check"><input type="checkbox" name="category" value="dresses" /><span>Dresses <em>18</em></span></label>
          <label class="check"><input type="checkbox" name="category" value="tops" /><span>Tops &amp; Blouses <em>12</em></span></label>
          <label class="check"><input type="checkbox" name="category" value="trousers" /><span>Trousers <em>8</em></span></label>
          <label class="check"><input type="checkbox" name="category" value="skirts" /><span>Skirts <em>4</em></span></label>
        </div>
      </details>

      <details class="filter-group" open>
        <summary class="filter-group__head">
          <span>Size</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <div class="filter-sizes">
            <label class="size-pill"><input type="checkbox" name="size" value="XS" /><span>XS</span></label>
            <label class="size-pill"><input type="checkbox" name="size" value="S" /><span>S</span></label>
            <label class="size-pill"><input type="checkbox" name="size" value="M" /><span>M</span></label>
            <label class="size-pill"><input type="checkbox" name="size" value="L" /><span>L</span></label>
            <label class="size-pill"><input type="checkbox" name="size" value="XL" /><span>XL</span></label>
          </div>
        </div>
      </details>

      <details class="filter-group" open>
        <summary class="filter-group__head">
          <span>Colour</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <div class="filter-colors">
            <label class="color-dot"><input type="checkbox" name="color" value="black" /><span style="background:#0a0a0a"></span><em>Black</em></label>
            <label class="color-dot"><input type="checkbox" name="color" value="oat" /><span style="background:#d4cdbc"></span><em>Oat</em></label>
            <label class="color-dot"><input type="checkbox" name="color" value="ivory" /><span style="background:#f5f1ea"></span><em>Ivory</em></label>
            <label class="color-dot"><input type="checkbox" name="color" value="sand" /><span style="background:#c2a98a"></span><em>Sand</em></label>
          </div>
        </div>
      </details>

      <details class="filter-group">
        <summary class="filter-group__head">
          <span>Fabric</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <label class="check"><input type="checkbox" name="fabric" value="linen" /><span>Linen <em>26</em></span></label>
          <label class="check"><input type="checkbox" name="fabric" value="silk" /><span>Silk <em>9</em></span></label>
          <label class="check"><input type="checkbox" name="fabric" value="cotton" /><span>Cotton <em>7</em></span></label>
        </div>
      </details>

      <details class="filter-group">
        <summary class="filter-group__head">
          <span>Occasion</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="filter-group__body">
          <label class="check"><input type="checkbox" name="occasion" value="everyday" /><span>Everyday</span></label>
          <label class="check"><input type="checkbox" name="occasion" value="workwear" /><span>Workwear</span></label>
          <label class="check"><input type="checkbox" name="occasion" value="evening" /><span>Evening</span></label>
          <label class="check"><input type="checkbox" name="occasion" value="resort" /><span>Resort</span></label>
        </div>
      </details>

      <div class="filter__foot">
        <button type="button" class="btn btn--ghost filter__clear" id="filterClear">Clear all</button>
        <button type="button" class="btn btn--primary filter__apply" id="filterApply">Show results</button>
      </div>
    </aside>

    <div class="filter-overlay" id="filterOverlay" aria-hidden="true"></div>

    <!-- ── RESULTS column ─────────────────────────────────────────── -->
    <div class="coll__main">

      <!-- Skeleton loading state -->
      <div class="coll__skeleton" aria-hidden="true">
        <div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>
        <div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>
      </div>

      <!-- Zero-results state — search-specific (different from collection's filter-empty) -->
      <div class="search-empty">
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
          <circle cx="28" cy="28" r="14"/>
          <path d="m48 48-10-10"/>
        </svg>
        <h3>No results for <em id="searchEmptyQuery">"your search"</em></h3>
        <p>We couldn't find anything matching that. Try a different word, browse a category, or talk to our atelier.</p>
        <div class="search-empty__chips" aria-label="Popular searches">
          <span class="search-empty__label">Popular searches:</span>
          <a href="#" class="search-empty__chip">linen midi dress</a>
          <a href="#" class="search-empty__chip">silk slip</a>
          <a href="#" class="search-empty__chip">tailored blazer</a>
          <a href="#" class="search-empty__chip">cashmere</a>
          <a href="#" class="search-empty__chip">SS26 lookbook</a>
        </div>
        <div class="search-empty__cta">
          <a href="/collection" class="btn btn--ghost">Browse Women</a>
          <a href="#" class="btn btn--primary">Chat with the atelier</a>
        </div>
      </div>

      <!-- Default: results grid -->
      <div class="coll__grid">

