@model WhiteStiches.Web.Models.Shop.SearchViewModel
@using WhiteStiches.Web.Models.Shop
@{
    ViewData["Title"] = Model.HasQuery ? $"Search · {Model.Query} · White Stitches" : "Search · White Stitches";
    ViewData["MetaDescription"] = "Search results — find your piece across the White Stitches edit.";

    var total = Model.TotalCount;
    var isEmpty = Model.IsEmpty;

    // Pagination tokens (-1 = ellipsis)
    var totalPages = Model.Results?.TotalPages ?? 0;
    var current = Model.Results?.Page ?? 1;
    var pageTokens = new List<int>();
    if (totalPages > 1)
    {
        var shown = new SortedSet<int> { 1, totalPages };
        for (var i = current - 1; i <= current + 1; i++)
        {
            if (i >= 1 && i <= totalPages) shown.Add(i);
        }
        int? prev = null;
        foreach (var n in shown)
        {
            if (prev is not null && n - prev.Value > 1) { pageTokens.Add(-1); }
            pageTokens.Add(n);
            prev = n;
        }
    }
}

<!-- ============================ SEARCH HEADER ============================ -->
<section class="search-head">
  <div class="search-head__inner">
    <form class="search-head__form" id="searchForm" role="search" method="get" action="/search">
      <button type="submit" class="search-head__submit" aria-label="@L["Search"]">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </button>
      <input
        type="search"
        id="searchInput"
        name="q"
        class="search-head__input"
        placeholder="@L["Search dresses, linen, evening..."]"
        aria-label="@L["Search the store"]"
        autocomplete="off"
        value="@Model.Query"
      />
      <button type="button" class="search-head__clear" id="searchClear" aria-label="@L["Clear search"]">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </form>

    <div class="search-head__meta" id="searchMeta">
      @if (Model.HasQuery)
      {
        <span class="search-head__count"><strong id="searchCount">@total</strong> @(total == 1 ? L["result"].Value : L["results"].Value) @L["for"] <em id="searchQuery">"@Model.Query"</em></span>
      }
      else
      {
        <span class="search-head__count">@L["Search the edit — dresses, linen, evening and more."]</span>
      }
    </div>

    @if (Model.HasQuery)
    {
      <!-- Search refinement chips: type filter at a glance -->
      <div class="search-refine" role="tablist" aria-label="@L["Refine results by type"]">
        <button type="button" class="search-refine__chip is-active" role="tab" aria-selected="true">
          @L["Products"] <em>@total</em>
        </button>
      </div>
    }
  </div>
</section>

@if (Model.HasQuery)
{
<!-- ============================ TOOLBAR (reused from collection) ============================ -->
<section class="coll-toolbar">
  <div class="coll-toolbar__inner">
    <div class="coll-toolbar__count" id="resultCount">@total @(total == 1 ? L["piece"].Value : L["pieces"].Value)</div>
  </div>
</section>

<!-- ============================ GRID (reuses .coll layout) ============================ -->
<section class="coll">
  <div class="coll__inner">

    <!-- ── RESULTS column (full width — search has no filter sidebar) ── -->
    <div class="coll__main @(isEmpty ? "is-empty" : null)" style="grid-column: 1 / -1">

      <!-- Skeleton loading state -->
      <div class="coll__skeleton" aria-hidden="true">
        <div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>
        <div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>
      </div>

      @if (isEmpty)
      {
        <!-- Zero-results state — search-specific -->
        <div class="search-empty">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
            <circle cx="28" cy="28" r="14"/>
            <path d="m48 48-10-10"/>
          </svg>
          <h3>@L["No results for"] <em>"@Model.Query"</em></h3>
          <p>@L["We couldn't find anything matching that. Try a different word, browse a category, or talk to our atelier."]</p>
          <div class="search-empty__chips" aria-label="@L["Popular searches"]">
            <span class="search-empty__label">@L["Popular searches:"]</span>
            <a href="/search?q=linen" class="search-empty__chip">linen</a>
            <a href="/search?q=dress" class="search-empty__chip">dress</a>
            <a href="/search?q=blazer" class="search-empty__chip">blazer</a>
            <a href="/search?q=silk" class="search-empty__chip">silk</a>
            <a href="/search?q=suit" class="search-empty__chip">suit</a>
          </div>
          <div class="search-empty__cta">
            <a href="/collection" class="btn btn--ghost">@L["Browse the Edit"]</a>
            <a href="/contact" class="btn btn--primary">@L["Chat with the atelier"]</a>
          </div>
        </div>
      }
      else
      {
        <!-- Results grid -->
        <div class="coll__grid">
          @foreach (var product in Model.Results!.Items)
          {
            <partial name="_ProductCard" model="product" />
          }
        </div>
      }

      @if (totalPages > 1)
      {
        <!-- Pagination (reused) -->
        <nav class="pagination" aria-label="@L["Pagination"]">
          @if (Model.Results!.HasPrevious)
          {
            <a class="pagination__btn pagination__btn--prev" href="@Model.PageUrl(current - 1)" aria-label="@L["Previous page"]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg>
            </a>
          }
          else
          {
            <button class="pagination__btn pagination__btn--prev" disabled aria-label="@L["Previous page"]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg>
            </button>
          }
          <ol class="pagination__nums">
            @foreach (var token in pageTokens)
            {
              if (token == -1)
              {
                <li class="pagination__ellipsis" aria-hidden="true">…</li>
              }
              else if (token == current)
              {
                <li><a href="@Model.PageUrl(token)" class="is-active" aria-current="page">@token</a></li>
              }
              else
              {
                <li><a href="@Model.PageUrl(token)">@token</a></li>
              }
            }
          </ol>
          @if (Model.Results!.HasNext)
          {
            <a class="pagination__btn pagination__btn--next" href="@Model.PageUrl(current + 1)" aria-label="@L["Next page"]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 6l6 6-6 6"/></svg>
            </a>
          }
          else
          {
            <button class="pagination__btn pagination__btn--next" disabled aria-label="@L["Next page"]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 6l6 6-6 6"/></svg>
            </button>
          }
        </nav>
      }

    </div>
  </div>
</section>
}

@if (Model.Suggestions.Count > 0)
{
  <!-- ============================ FEATURED SUGGESTIONS ============================ -->
  <section class="products">
    <div class="section-head section-head--center">
      <span class="eyebrow">@(isEmpty ? L["You may like"].Value : L["Popular right now"].Value)</span>
      <h2 class="section-title">@L["Pieces from the atelier."]</h2>
    </div>

    <div class="products__grid">
      @foreach (var product in Model.Suggestions)
      {
        <partial name="_ProductCard" model="product" />
      }
    </div>
  </section>
}
