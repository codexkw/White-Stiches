@model WhiteStiches.Web.Models.Shop.ProductDetailViewModel
@using System.Globalization
@using WhiteStiches.Web.Models.Shop
@{
    var p = Model.Product;
    var images = Model.Images;
    var dv = Model.DefaultVariant;
    var canBuy = dv is not null && ProductDetailViewModel.IsPurchasable(dv);
    var onSale = dv?.CompareAtPrice is not null && dv.CompareAtPrice.Value > dv.Price;
    var returnUrl = $"/products/{p.Slug}";
    var deliveryEta = DateTime.Now.AddDays(3).ToString("ddd, d MMM", CultureInfo.InvariantCulture);

    string Money(decimal value) => value.ToString("0.000", CultureInfo.InvariantCulture);

    ViewData["Title"] = p.SeoTitleEn is { Length: > 0 } seoTitle ? seoTitle : $"{p.TitleEn} · White Stitches";
    ViewData["MetaDescription"] = p.SeoDescriptionEn is { Length: > 0 } seoDesc ? seoDesc : $"{p.TitleEn} — by White Stitches, Kuwait.";

    string stockSignalHtml;
    if (dv is null || (dv.StockQuantity <= 0 && !dv.AllowOversell))
    {
        stockSignalHtml = "Currently <strong>out of stock</strong>";
    }
    else if (dv.StockQuantity > 0 && dv.StockQuantity <= dv.LowStockThreshold)
    {
        stockSignalHtml = $"Only <strong>{dv.StockQuantity} left</strong> in this size";
    }
    else
    {
        stockSignalHtml = "<strong>In stock</strong> — ready to ship";
    }

    var variantJson = Model.Variants.Select(v => new
    {
        id = v.Id,
        option1 = v.Option1,
        option2 = v.Option2,
        price = Money(v.Price),
        compareAt = v.CompareAtPrice is not null && v.CompareAtPrice.Value > v.Price ? Money(v.CompareAtPrice.Value) : null,
        stock = v.StockQuantity,
        lowStock = v.LowStockThreshold,
        oversell = v.AllowOversell
    }).ToList();

    var alsoLike = Model.Related.Take(4).ToList();
    var completeLook = Model.Related.Skip(4).Take(4).ToList();
}

<!-- ============================ BREADCRUMB ============================ -->
<nav class="breadcrumb" aria-label="Breadcrumb">
  <div class="breadcrumb__inner">
    <a href="/">@L["Home"]</a>
    <span class="breadcrumb__sep">/</span>
    @if (p.Category is not null)
    {
      <a href="/collection?category=@p.Category.Slug">@p.Category.Name()</a>
    }
    else
    {
      <a href="/collection">@L["Collection"]</a>
    }
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__current">@p.Title()</span>
  </div>
</nav>

<!-- ============================ PDP GRID ============================ -->
<section class="pdp">
  <div class="pdp__inner">

    <!-- ── GALLERY ─────────────────────────────────────────────────── -->
    <div class="pdp__gallery">
      <!-- Vertical thumbnail rail (desktop) -->
      <div class="pdp__thumbs" role="tablist" aria-label="@L["Product gallery thumbnails"]">
        @if (images.Count > 0)
        {
          for (var i = 0; i < images.Count; i++)
          {
            <button class="pdp__thumb @(i == 0 ? "is-active" : null)" data-index="@i" role="tab" aria-selected="@(i == 0 ? "true" : "false")">
              @if (images[i].MediaKind == MediaKind.Video)
              {
                <video src="@images[i].Url" muted playsinline preload="metadata"></video>
                <span class="pdp__thumb-play"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"></path></svg></span>
              }
              else
              {
                <img src="@images[i].Url" alt="@(images[i].Alt() ?? p.Title())" />
              }
            </button>
          }
        }
        else
        {
          <button class="pdp__thumb is-active" data-index="0" role="tab" aria-selected="true">
            <img src="~/assets/products/product-1.jpg" alt="@p.Title()" />
          </button>
        }
      </div>

      <!-- Main media area -->
      <div class="pdp__main">
        <div class="pdp__slides">
          @if (images.Count > 0)
          {
            for (var i = 0; i < images.Count; i++)
            {
              <div class="pdp__slide @(i == 0 ? "is-active" : null)" data-index="@i">
                @if (images[i].MediaKind == MediaKind.Video)
                {
                  <video src="@images[i].Url" muted loop playsinline controls preload="metadata" autoplay="@(i == 0 ? "autoplay" : null)"></video>
                }
                else
                {
                  <img src="@images[i].Url" alt="@(images[i].Alt() ?? p.Title())" />
                }
              </div>
            }
          }
          else
          {
            <div class="pdp__slide is-active" data-index="0">
              <img src="~/assets/products/product-1.jpg" alt="@p.Title()" />
            </div>
          }
        </div>

        <!-- Mobile dots (visible only on mobile) -->
        <div class="pdp__dots" aria-hidden="true">
          @for (var i = 0; i < Math.Max(images.Count, 1); i++)
          {
            <span class="pdp__dot @(i == 0 ? "is-active" : null)"></span>
          }
        </div>

        <!-- Slide counter (desktop) -->
        <div class="pdp__counter">
          <span class="pdp__counter-current">01</span>
          <span class="pdp__counter-sep">/</span>
          <span class="pdp__counter-total">@Math.Max(images.Count, 1).ToString("00")</span>
        </div>
      </div>
    </div>

    <!-- ── INFO COLUMN (sticky on desktop) ───────────────────────────── -->
    <aside class="pdp__info">
      <div class="pdp__info-inner">

        <span class="pdp__eyebrow">@(p.Vendor is { Length: > 0 } vendor ? vendor : "White Stitches · Atelier")</span>
        <h1 class="pdp__title">@p.Title()</h1>

        <div class="pdp__price-row">
          <span class="pdp__price">
            <span class="product__price--was" id="pdpWas" hidden="@(!onSale)">@(onSale ? Money(dv!.CompareAtPrice!.Value) : null)</span>
            <span id="pdpPrice">@Money(dv?.Price ?? 0m)</span> <span class="pdp__currency">KWD</span>
          </span>
          <span class="pdp__price-meta">@L["VAT included · Free shipping over 50 KWD"]</span>
        </div>

        @if (Model.ColorValues.Count > 0)
        {
          <!-- ── COLOR VARIANTS (image thumbnail picker) ──────── -->
          <div class="variant">
            <div class="variant__head">
              <span class="variant__label">@Model.ColorLabel</span>
              <span class="variant__value" id="colorValue">@(dv?.Option2 ?? Model.ColorValues[0])</span>
            </div>
            <div class="variant__colors" role="radiogroup" aria-label="@Model.ColorLabel">
              @foreach (var color in Model.ColorValues)
              {
                var isActive = string.Equals(dv?.Option2?.Trim(), color, StringComparison.OrdinalIgnoreCase);
                var soldOut = Model.IsColorSoldOut(color);
                var colorImage = Model.ImageForColor(color);
                <button type="button" class="color-thumb @(isActive ? "is-active" : null) @(soldOut ? "is-soldout" : null)" role="radio" aria-checked="@(isActive ? "true" : "false")" aria-disabled="@(soldOut ? "true" : null)" data-color="@color">
                  @if (colorImage is not null && colorImage.MediaKind == MediaKind.Image)
                  {
                    <img src="@colorImage.Url" alt="" />
                  }
                  else
                  {
                    <img src="~/assets/products/product-1.jpg" alt="" />
                  }
                  <span class="color-thumb__name">@color</span>
                  @if (soldOut)
                  {
                    <span class="color-thumb__badge">@L["Sold out"]</span>
                  }
                </button>
              }
            </div>
          </div>
        }

        @if (Model.SizeValues.Count > 0)
        {
          <!-- ── SIZE VARIANTS ─────────────────────────────────────────── -->
          <div class="variant">
            <div class="variant__head">
              <span class="variant__label">@Model.SizeLabel</span>
              <a class="variant__guide" id="sizeGuideOpen" href="/size-guide">@L["Size guide →"]</a>
            </div>
            <div class="variant__sizes" role="radiogroup" aria-label="@Model.SizeLabel">
              @foreach (var size in Model.SizeValues)
              {
                var isActive = string.Equals(dv?.Option1?.Trim(), size, StringComparison.OrdinalIgnoreCase);
                var soldOut = Model.IsSizeSoldOut(size);
                <button type="button" class="size-chip @(isActive ? "is-active" : null) @(soldOut ? "is-soldout" : null)" role="radio" aria-checked="@(isActive ? "true" : "false")" aria-disabled="@(soldOut ? "true" : null)" data-size="@size">@size</button>
              }
            </div>
          </div>
        }

        <!-- ── QUANTITY + ACTIONS ────────────────────────────────────── -->
        <form class="pdp__actions" id="atcForm" method="post" action="/cart/items">
          @Html.AntiForgeryToken()
          <input type="hidden" name="variantId" id="variantIdInput" value="@(dv?.Id ?? 0)" />
          <input type="hidden" name="returnUrl" value="@returnUrl" />
          <div class="qty">
            <button type="button" class="qty__btn" id="qtyMinus" aria-label="@L["Decrease quantity"]">−</button>
            <input type="number" class="qty__input" id="qtyInput" name="quantity" value="1" min="1" max="10" aria-label="@L["Quantity"]" />
            <button type="button" class="qty__btn" id="qtyPlus" aria-label="@L["Increase quantity"]">+</button>
          </div>
          <button type="submit" class="btn btn--primary pdp__atc" id="addToCartBtn" disabled="@(!canBuy)">
            <span>@L["Add to bag"]</span>
            <span class="pdp__atc-price" id="atcPrice">· @Money(dv?.Price ?? 0m) KWD</span>
          </button>
          <button type="submit" form="pdpWishlistForm" class="pdp__wishlist" aria-label="@L["Add to wishlist"]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </form>
        <form id="pdpWishlistForm" method="post" action="/account/wishlist/add" hidden>
          @Html.AntiForgeryToken()
          <input type="hidden" name="productId" value="@p.Id" />
          <input type="hidden" name="returnUrl" value="@returnUrl" />
        </form>

        <!-- ── STOCK + DELIVERY MICROCOPY ────────────────────────────── -->
        <div class="pdp__signals">
          <div class="pdp__signal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            <span id="stockSignal">@Html.Raw(stockSignalHtml)</span>
          </div>
          <div class="pdp__signal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7h13v9H3zM16 10h3l2 3v3h-5zM7 19a2 2 0 100-4 2 2 0 000 4zM18 19a2 2 0 100-4 2 2 0 000 4z"/></svg>
            <span>@L["Free delivery in Kuwait"] · <strong>@deliveryEta</strong></span>
          </div>
          <div class="pdp__signal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 1 1-9-9"/><path d="M21 4v5h-5"/></svg>
            <span>@L["14-day easy returns"] · <a href="/returns-policy" class="link-inline">@L["policy"]</a></span>
          </div>
        </div>

        <!-- ── SHARE ─────────────────────────────────────────────────── -->
        <div class="pdp__share">
          <span>@L["Share"]</span>
          <a href="#" aria-label="@L["Share on WhatsApp"]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 11.5a8.4 8.4 0 0 1-8.4 8.4 8.4 8.4 0 0 1-4-1L3 20l1.1-5.6a8.4 8.4 0 0 1-1-4A8.4 8.4 0 0 1 11.5 2"/></svg>
          </a>
          <a href="#" aria-label="@L["Share on Instagram"]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg>
          </a>
          <a href="#" aria-label="@L["Copy link"]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
          </a>
        </div>

      </div>
    </aside>
  </div>
</section>

<!-- ============================ DETAILS ACCORDION ============================ -->
<section class="pdp-details">
  <div class="pdp-details__inner">

    @if (!string.IsNullOrWhiteSpace(p.Description()))
    {
      <details class="acc" open>
        <summary class="acc__head">
          <span>@L["Description"]</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="acc__body">
          @Html.Raw(p.Description())
        </div>
      </details>
    }

    @if (!string.IsNullOrWhiteSpace(p.MaterialCare()))
    {
      <details class="acc">
        <summary class="acc__head">
          <span>@L["Fabric & Materials"]</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="acc__body">
          @Html.Raw(p.MaterialCare())
        </div>
      </details>
    }

    @if (!string.IsNullOrWhiteSpace(p.SizeFit()))
    {
      <details class="acc">
        <summary class="acc__head">
          <span>@L["Size & Fit"]</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <div class="acc__body">
          @Html.Raw(p.SizeFit())
          <a href="/size-guide" class="link-arrow">@L["View full size chart →"]</a>
        </div>
      </details>
    }

    <details class="acc">
      <summary class="acc__head">
        <span>@L["Delivery & Returns"]</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
      </summary>
      <div class="acc__body">
        <ul class="acc__list">
          <li>@L["Free standard delivery within Kuwait on orders above 50 KWD"]</li>
          <li>@L["Same-day delivery in Kuwait City for orders before 2 PM"]</li>
          <li>@L["GCC delivery 3–5 working days · duties included"]</li>
          <li>@L["Easy returns within 14 days · unworn, with tags · refund to original payment method"]</li>
        </ul>
      </div>
    </details>

  </div>
</section>

@if (completeLook.Count > 0)
{
  <!-- ============================ COMPLETE THE LOOK ============================ -->
  <section class="products">
    <div class="section-head section-head--center">
      <span class="eyebrow">@L["Complete the Look"]</span>
      <h2 class="section-title">@L["Styled with this piece."]</h2>
    </div>

    <div class="products__grid">
      @foreach (var related in completeLook)
      {
        <partial name="_ProductCard" model="related" />
      }
    </div>
  </section>
}

@if (alsoLike.Count > 0)
{
  <!-- ============================ YOU MAY ALSO LIKE ============================ -->
  <section class="products">
    <div class="section-head section-head--center">
      <span class="eyebrow">@L["You may also like"]</span>
      <h2 class="section-title">@L["More from the atelier."]</h2>
    </div>

    <div class="products__grid">
      @foreach (var related in alsoLike)
      {
        <partial name="_ProductCard" model="related" />
      }
    </div>
  </section>
}

<!-- ============================ STICKY MOBILE ATC ============================ -->
<div class="pdp-stickybar" id="pdpStickybar" aria-hidden="true">
  <div class="pdp-stickybar__info">
    <div class="pdp-stickybar__title">@p.Title()</div>
    <div class="pdp-stickybar__price" id="stickyPrice">@Money(dv?.Price ?? 0m) KWD</div>
  </div>
  <button type="submit" form="atcForm" class="btn btn--primary pdp-stickybar__atc" disabled="@(!canBuy)">@L["Add to bag"]</button>
</div>

@section Scripts {
<script>
  (function () {
    var variants = @Html.Raw(Json.Serialize(variantJson));
    var hasSizes = @(Model.SizeValues.Count > 0 ? "true" : "false");
    var hasColors = @(Model.ColorValues.Count > 0 ? "true" : "false");
    var selectedSize = @Html.Raw(Json.Serialize(dv?.Option1));
    var selectedColor = @Html.Raw(Json.Serialize(dv?.Option2));

    var variantInput = document.getElementById('variantIdInput');
    var priceEl = document.getElementById('pdpPrice');
    var wasEl = document.getElementById('pdpWas');
    var atcBtn = document.getElementById('addToCartBtn');
    var atcPrice = document.getElementById('atcPrice');
    var stickyPrice = document.getElementById('stickyPrice');
    var stickyBtn = document.querySelector('.pdp-stickybar__atc');
    var stockSignal = document.getElementById('stockSignal');

    function findVariant() {
      for (var i = 0; i < variants.length; i++) {
        var v = variants[i];
        if ((!hasSizes || v.option1 === selectedSize) &&
            (!hasColors || v.option2 === selectedColor)) {
          return v;
        }
      }
      return null;
    }

    function refresh() {
      var v = findVariant();
      if (!v) {
        if (variantInput) variantInput.value = '';
        if (atcBtn) atcBtn.disabled = true;
        if (stickyBtn) stickyBtn.disabled = true;
        if (stockSignal) stockSignal.innerHTML = 'Currently <strong>unavailable</strong> in this combination';
        return;
      }
      if (variantInput) variantInput.value = v.id;
      if (priceEl) priceEl.textContent = v.price;
      if (wasEl) {
        if (v.compareAt) {
          wasEl.textContent = v.compareAt;
          wasEl.hidden = false;
        } else {
          wasEl.textContent = '';
          wasEl.hidden = true;
        }
      }
      if (atcPrice) atcPrice.textContent = '· ' + v.price + ' KWD';
      if (stickyPrice) stickyPrice.textContent = v.price + ' KWD';

      var buyable = v.stock > 0 || v.oversell;
      if (atcBtn) atcBtn.disabled = !buyable;
      if (stickyBtn) stickyBtn.disabled = !buyable;
      if (stockSignal) {
        if (!buyable) {
          stockSignal.innerHTML = 'Currently <strong>out of stock</strong>';
        } else if (v.stock > 0 && v.stock <= v.lowStock) {
          stockSignal.innerHTML = 'Only <strong>' + v.stock + ' left</strong> in this size';
        } else {
          stockSignal.innerHTML = '<strong>In stock</strong> — ready to ship';
        }
      }
    }

    document.querySelectorAll('.size-chip').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (btn.classList.contains('is-soldout')) return;
        selectedSize = btn.dataset.size;
        refresh();
      });
    });

    document.querySelectorAll('.color-thumb').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (btn.classList.contains('is-soldout')) return;
        selectedColor = btn.dataset.color;
        refresh();
      });
    });

    // Sticky mobile bar — the legacy demo observer keyed on the old #addToCart id no longer runs
    var stickybar = document.getElementById('pdpStickybar');
    if (stickybar && atcBtn && 'IntersectionObserver' in window) {
      document.body.classList.add('has-pdp-stickybar');
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          stickybar.classList.toggle('is-visible', !entry.isIntersecting);
          stickybar.setAttribute('aria-hidden', entry.isIntersecting ? 'true' : 'false');
        });
      }, { threshold: 0 });
      observer.observe(atcBtn);
    }
  })();
</script>
}
