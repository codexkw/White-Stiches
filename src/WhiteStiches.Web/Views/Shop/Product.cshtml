<!-- ============================ BREADCRUMB ============================ -->
<nav class="breadcrumb" aria-label="Breadcrumb">
  <div class="breadcrumb__inner">
    <a href="/">Home</a>
    <span class="breadcrumb__sep">/</span>
    <a href="#">Women</a>
    <span class="breadcrumb__sep">/</span>
    <a href="#">Dresses</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__current">Noor Double-Breasted Dress</span>
  </div>
</nav>

<!-- ============================ PDP GRID ============================ -->
<section class="pdp">
  <div class="pdp__inner">

    <!-- ── GALLERY ─────────────────────────────────────────────────── -->
    <div class="pdp__gallery">
      <!-- Vertical thumbnail rail (desktop) -->
      <div class="pdp__thumbs" role="tablist" aria-label="Product gallery thumbnails">
        <button class="pdp__thumb is-active" data-index="0" role="tab" aria-selected="true">
          <img src="~/assets/products/product-3.jpg" alt="Noor Double-Breasted Dress — front view" />
        </button>
        <button class="pdp__thumb" data-index="1" role="tab" aria-selected="false">
          <img src="~/assets/products/product-1.jpg" alt="Noor Double-Breasted Dress — back view" />
        </button>
        <button class="pdp__thumb pdp__thumb--video" data-index="2" data-type="video" role="tab" aria-selected="false">
          <img src="~/assets/products/product-3.jpg" alt="Noor Double-Breasted Dress — runway video preview" />
          <span class="pdp__thumb-play" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7L8 5z"/></svg>
          </span>
        </button>
        <button class="pdp__thumb" data-index="3" role="tab" aria-selected="false">
          <img src="~/assets/products/product-1.jpg" alt="Noor Double-Breasted Dress — detail shot" />
        </button>
        <button class="pdp__thumb" data-index="4" role="tab" aria-selected="false">
          <img src="~/assets/products/product-3.jpg" alt="Noor Double-Breasted Dress — styling on model" />
        </button>
        <button class="pdp__thumb" data-index="5" role="tab" aria-selected="false">
          <img src="~/assets/products/product-1.jpg" alt="Noor Double-Breasted Dress — fabric close-up" />
        </button>
      </div>

      <!-- Main media area -->
      <div class="pdp__main">
        <div class="pdp__slides">
          <div class="pdp__slide is-active" data-index="0">
            <img src="~/assets/products/product-3.jpg" alt="Noor Double-Breasted Dress — front view" />
          </div>
          <div class="pdp__slide" data-index="1">
            <img src="~/assets/products/product-1.jpg" alt="Noor Double-Breasted Dress — back view" />
          </div>
          <!-- VIDEO SLIDE -->
          <div class="pdp__slide pdp__slide--video" data-index="2" data-type="video">
            <video
              poster="~/assets/products/product-3.jpg"
              preload="metadata"
              playsinline
              muted
              loop
              controls>
              <!-- Source omitted (would be the merchant's CDN MP4). The poster shows in its place. -->
              <source src="" type="video/mp4" />
            </video>
          </div>
          <div class="pdp__slide" data-index="3">
            <img src="~/assets/products/product-1.jpg" alt="Noor Double-Breasted Dress — detail shot" />
          </div>
          <div class="pdp__slide" data-index="4">
            <img src="~/assets/products/product-3.jpg" alt="Noor Double-Breasted Dress — styling on model" />
          </div>
          <div class="pdp__slide" data-index="5">
            <img src="~/assets/products/product-1.jpg" alt="Noor Double-Breasted Dress — fabric close-up" />
          </div>
        </div>

        <!-- Mobile dots (visible only on mobile) -->
        <div class="pdp__dots" aria-hidden="true">
          <span class="pdp__dot is-active"></span>
          <span class="pdp__dot"></span>
          <span class="pdp__dot"></span>
          <span class="pdp__dot"></span>
          <span class="pdp__dot"></span>
          <span class="pdp__dot"></span>
        </div>

        <!-- Slide counter (desktop) -->
        <div class="pdp__counter">
          <span class="pdp__counter-current">01</span>
          <span class="pdp__counter-sep">/</span>
          <span class="pdp__counter-total">06</span>
        </div>
      </div>
    </div>

    <!-- ── INFO COLUMN (sticky on desktop) ───────────────────────────── -->
    <aside class="pdp__info">
      <div class="pdp__info-inner">

        <span class="pdp__eyebrow">White Stitches · Atelier</span>
        <h1 class="pdp__title">Noor Double-Breasted Dress</h1>

        <div class="pdp__rating">
          <span class="pdp__stars" aria-label="4.7 out of 5 stars">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" opacity=".3"/></svg>
          </span>
          <a href="#reviews" class="pdp__rating-link">4.7 · 38 reviews</a>
        </div>

        <div class="pdp__price-row">
          <span class="pdp__price">42.500 <span class="pdp__currency">KWD</span></span>
          <span class="pdp__price-meta">VAT included · Free shipping over 50 KWD</span>
        </div>

        <p class="pdp__intro">
          A fluid linen-blend midi with handcrafted draping at the shoulder and a softly gathered waist. Designed for the woman who lets the silhouette speak — never the label.
        </p>

        <!-- ── COLOR VARIANTS (image thumbnail picker, like cloot) ──────── -->
        <div class="variant">
          <div class="variant__head">
            <span class="variant__label">Colour</span>
            <span class="variant__value" id="colorValue">Oat</span>
          </div>
          <div class="variant__colors" role="radiogroup" aria-label="Colour">
            <button type="button" class="color-thumb is-active" role="radio" aria-checked="true" data-color="Oat">
              <img src="~/assets/products/product-4.jpg" alt="" />
              <span class="color-thumb__name">Oat</span>
            </button>
            <button type="button" class="color-thumb" role="radio" aria-checked="false" data-color="Black">
              <img src="~/assets/products/product-1.jpg" alt="" />
              <span class="color-thumb__name">Black</span>
            </button>
            <button type="button" class="color-thumb" role="radio" aria-checked="false" data-color="Sand">
              <img src="~/assets/products/product-2.jpg" alt="" />
              <span class="color-thumb__name">Sand</span>
            </button>
            <button type="button" class="color-thumb is-soldout" role="radio" aria-checked="false" aria-disabled="true" data-color="Olive">
              <img src="~/assets/products/product-3.jpg" alt="" />
              <span class="color-thumb__name">Olive</span>
              <span class="color-thumb__badge">Sold out</span>
            </button>
          </div>
        </div>

        <!-- ── SIZE VARIANTS ─────────────────────────────────────────── -->
        <div class="variant">
          <div class="variant__head">
            <span class="variant__label">Size</span>
            <button type="button" class="variant__guide" id="sizeGuideOpen">Size guide →</button>
          </div>
          <div class="variant__sizes" role="radiogroup" aria-label="Size">
            <button type="button" class="size-chip" role="radio" aria-checked="false" data-size="XS">XS</button>
            <button type="button" class="size-chip is-active" role="radio" aria-checked="true" data-size="S">S</button>
            <button type="button" class="size-chip" role="radio" aria-checked="false" data-size="M">M</button>
            <button type="button" class="size-chip" role="radio" aria-checked="false" data-size="L">L</button>
            <button type="button" class="size-chip is-soldout" role="radio" aria-checked="false" aria-disabled="true" data-size="XL">XL</button>
          </div>
        </div>

        <!-- ── QUANTITY + ACTIONS ────────────────────────────────────── -->
        <div class="pdp__actions">
          <div class="qty">
            <button type="button" class="qty__btn" id="qtyMinus" aria-label="Decrease quantity">−</button>
            <input type="number" class="qty__input" id="qtyInput" value="1" min="1" max="10" aria-label="Quantity" />
            <button type="button" class="qty__btn" id="qtyPlus" aria-label="Increase quantity">+</button>
          </div>
          <button type="button" class="btn btn--primary pdp__atc" id="addToCart">
            <span>Add to bag</span>
            <span class="pdp__atc-price">· 42.500 KWD</span>
          </button>
          <button type="button" class="pdp__wishlist" id="wishlistBtn" aria-label="Add to wishlist" aria-pressed="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </div>

        <!-- ── STOCK + DELIVERY MICROCOPY ────────────────────────────── -->
        <div class="pdp__signals">
          <div class="pdp__signal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            <span>Only <strong>6 left</strong> in this size</span>
          </div>
          <div class="pdp__signal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7h13v9H3zM16 10h3l2 3v3h-5zM7 19a2 2 0 100-4 2 2 0 000 4zM18 19a2 2 0 100-4 2 2 0 000 4z"/></svg>
            <span>Free delivery in Kuwait · <strong>Tue, 21 May</strong></span>
          </div>
          <div class="pdp__signal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 1 1-9-9"/><path d="M21 4v5h-5"/></svg>
            <span>14-day easy returns · <a href="#" class="link-inline">policy</a></span>
          </div>
        </div>

        <!-- ── SHARE ─────────────────────────────────────────────────── -->
        <div class="pdp__share">
          <span>Share</span>
          <a href="#" aria-label="Share on WhatsApp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 11.5a8.4 8.4 0 0 1-8.4 8.4 8.4 8.4 0 0 1-4-1L3 20l1.1-5.6a8.4 8.4 0 0 1-1-4A8.4 8.4 0 0 1 11.5 2"/></svg>
          </a>
          <a href="#" aria-label="Share on Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg>
          </a>
          <a href="#" aria-label="Copy link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
          </a>
        </div>

      </div>
    </aside>
  </div>
</section>

<!-- ============================ DETAILS ACCORDION ============================ -->
<section class="pdp-details">
  <div class="pdp-details__inner">

    <details class="acc" open>
      <summary class="acc__head">
        <span>Description</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
      </summary>
      <div class="acc__body">
        <p>The Noor is a floor-length double-breasted dress crafted from a structured wool crepe, finished with hand-set crystal buttons running the full length of the bodice. Sheer organza collar and cuffs detailed with hand-applied flocked dots add a couture flourish without breaking the silhouette.</p>
        <p>Designed and finished at our Kuwait atelier. Each piece carries a single white stitch on the inside seam — our maker's signature.</p>
      </div>
    </details>

    <details class="acc">
      <summary class="acc__head">
        <span>Fabric &amp; Materials</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
      </summary>
      <div class="acc__body">
        <ul class="acc__list">
          <li>62% European linen · 38% viscose</li>
          <li>Mother-of-pearl button at neckline</li>
          <li>OEKO-TEX Standard 100 certified</li>
          <li>Hand wash cold or dry-clean · iron on reverse · do not bleach</li>
        </ul>
      </div>
    </details>

    <details class="acc">
      <summary class="acc__head">
        <span>Size &amp; Fit</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
      </summary>
      <div class="acc__body">
        <ul class="acc__list">
          <li>Model is 178 cm and wears size S</li>
          <li>True to size · order your usual</li>
          <li>Mid-calf length · approx. 118 cm from shoulder on size S</li>
          <li>Unlined · slightly relaxed through the bodice</li>
        </ul>
        <a href="#" class="link-arrow">View full size chart →</a>
      </div>
    </details>

    <details class="acc">
      <summary class="acc__head">
        <span>Delivery &amp; Returns</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
      </summary>
      <div class="acc__body">
        <ul class="acc__list">
          <li>Free standard delivery within Kuwait on orders above 50 KWD</li>
          <li>Same-day delivery in Kuwait City for orders before 2 PM</li>
          <li>GCC delivery 3–5 working days · duties included</li>
          <li>Easy returns within 14 days · unworn, with tags · refund to original payment method</li>
        </ul>
      </div>
    </details>

  </div>
</section>

