@{
    ViewData["Title"] = "Noor Double-Breasted Dress · White Stitches";
    ViewData["MetaDescription"] = "Noor Double-Breasted Dress — a fluid linen-blend dress with handcrafted draping. By White Stitches, Kuwait.";
