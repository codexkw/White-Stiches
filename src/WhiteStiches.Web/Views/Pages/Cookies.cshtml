@{
    ViewData["Title"] = "Cookies policy · White Stitches";
    ViewData["MetaDescription"] = "How we use cookies and how to control them.";
}

<section class="page-hero">
  <div class="page-hero__inner">
    <span class="eyebrow">@L["Legal · Cookies"]</span>
    <h1 class="page-hero__title">@L["Cookies policy."]</h1>
    <p class="page-hero__lede">@L["How we use cookies and similar technologies — and how you can control them."]</p>
    <p class="page-hero__meta">Last updated · 1 May 2026</p>
  </div>
</section>

<section class="policy">
  <div class="policy__inner">
    <aside class="policy__toc" aria-label="@L["On this page"]">
      <span class="eyebrow">@L["On this page"]</span>
      <ol class="policy__toc-list">
    <li><a href="#what">@L["What cookies are"]</a></li>
    <li><a href="#categories">@L["The cookies we use"]</a></li>
    <li><a href="#control">@L["How to control them"]</a></li>
    <li><a href="#third-party">@L["Third-party cookies"]</a></li>
    <li><a href="#changes">@L["Changes to this policy"]</a></li>
      </ol>
    </aside>

    <main class="policy__main">
      <section class="policy-section" id="what">
        <h2 class="policy-section__title">@L["What cookies are"]</h2>
        <p>Cookies are small text files saved by your browser when you visit a website. They help the site remember things about your visit — like the items in your cart, your language preference, or whether you&rsquo;re signed in.</p>
         <p>We also use similar technologies (local storage, web beacons) for the same purposes. Throughout this policy, we call them all "cookies" for simplicity.</p>
      </section>

      <section class="policy-section" id="categories">
        <h2 class="policy-section__title">@L["The cookies we use"]</h2>
        <div class="cookies-grid">
           <article class="cookie-card cookie-card--essential">
             <span class="cookie-card__chip">@L["Essential · always on"]</span>
             <h3>@L["Strictly necessary"]</h3>
             <p>Required for the site to work — sign-in, cart, checkout, security. Cannot be disabled.</p>
             <ul><li>Session cookies</li><li>Authentication tokens</li><li>Cart contents</li><li>CSRF protection</li></ul>
           </article>
           <article class="cookie-card">
             <span class="cookie-card__chip">@L["Functional"]</span>
             <h3>@L["Preferences"]</h3>
             <p>Remember your language, currency, recently viewed items, and other personalisation.</p>
             <ul><li>Language &amp; currency</li><li>Recently viewed</li><li>Wishlist (when not signed in)</li></ul>
           </article>
           <article class="cookie-card">
             <span class="cookie-card__chip">@L["Analytics"]</span>
             <h3>@L["Performance &amp; analytics"]</h3>
             <p>Help us understand which pages work, what fails, and where to invest. Anonymised via Google Consent Mode v2.</p>
             <ul><li>Google Analytics 4</li><li>Performance monitoring</li><li>Error tracking</li></ul>
           </article>
           <article class="cookie-card">
             <span class="cookie-card__chip">@L["Marketing"]</span>
             <h3>@L["Marketing &amp; advertising"]</h3>
             <p>Used to show you relevant pieces on other platforms (Instagram, Google). Only with your consent.</p>
             <ul><li>Meta Pixel</li><li>Google Ads</li><li>TikTok Pixel</li></ul>
           </article>
         </div>
      </section>

      <section class="policy-section" id="control">
        <h2 class="policy-section__title">@L["How to control them"]</h2>
        <p>You can change your cookie preferences any time by clicking the cookie icon in the bottom-left corner of any page, or by adjusting your browser settings.</p>
         <p>If you opt out of analytics or marketing cookies, you&rsquo;ll still be able to shop normally — but recommendations may be less personalised, and we won&rsquo;t see your visit in our reports.</p>
         <p>To opt out of marketing cookies set by third parties (Meta, Google) at the source, visit <a href="https://www.youronlinechoices.com" target="_blank" rel="noopener" class="link-inline">youronlinechoices.com</a>.</p>
      </section>

      <section class="policy-section" id="third-party">
        <h2 class="policy-section__title">@L["Third-party cookies"]</h2>
        <p>Some of our partners set their own cookies when you use their services on our site (payment, analytics, social embeds). They each have their own privacy and cookie policies:</p>
         <ul class="policy-list">
           <li><strong>Tap Payments</strong> — <a href="https://www.tap.company/kw/en/privacy-policy" target="_blank" rel="noopener" class="link-inline">tap.company/privacy</a></li>
           <li><strong>Google</strong> — <a href="https://policies.google.com/privacy" target="_blank" rel="noopener" class="link-inline">policies.google.com/privacy</a></li>
           <li><strong>Meta</strong> — <a href="https://www.facebook.com/policy.php" target="_blank" rel="noopener" class="link-inline">facebook.com/policy</a></li>
           <li><strong>WhatsApp</strong> — <a href="https://www.whatsapp.com/legal/privacy-policy" target="_blank" rel="noopener" class="link-inline">whatsapp.com/legal/privacy-policy</a></li>
         </ul>
      </section>

      <section class="policy-section" id="changes">
        <h2 class="policy-section__title">@L["Changes to this policy"]</h2>
        <p>If we add new cookies or change how we use existing ones, we&rsquo;ll update this policy and ask for your consent again where required.</p>
      </section>
    </main>
  </div>
</section>

