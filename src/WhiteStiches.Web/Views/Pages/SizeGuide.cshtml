@{
    ViewData["Title"] = "Size guide · White Stitches";
    ViewData["MetaDescription"] = "How to measure, our size charts, and how our pieces fit.";
}

<section class="page-hero">
  <div class="page-hero__inner">
    <span class="eyebrow">Help · Size Guide</span>
    <h1 class="page-hero__title">Size guide.</h1>
    <p class="page-hero__lede">Our pieces are drafted in Kuwait. They run true to GCC sizing — closer to your body than European fits, with allowance for movement.</p>
    <p class="page-hero__meta">Last updated · 1 May 2026</p>
  </div>
</section>

<section class="policy">
  <div class="policy__inner">
