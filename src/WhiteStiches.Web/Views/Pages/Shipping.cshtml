@{
    ViewData["Title"] = "Shipping & delivery · White Stitches";
    ViewData["MetaDescription"] = "Delivery options, times, costs and tracking across the GCC.";
}

<section class="page-hero">
  <div class="page-hero__inner">
    <span class="eyebrow">Help · Shipping</span>
    <h1 class="page-hero__title">Shipping &amp; delivery.</h1>
    <p class="page-hero__lede">Free standard delivery in Kuwait over 50 KWD. Express, same-day and pickup options available.</p>
    <p class="page-hero__meta">Last updated · 5 May 2026</p>
  </div>
</section>

<section class="policy">
  <div class="policy__inner">
    <aside class="policy__toc" aria-label="On this page">
      <span class="eyebrow">On this page</span>
      <ol class="policy__toc-list">
    <li><a href="#kuwait">Within Kuwait</a></li>
    <li><a href="#gcc">Across the GCC</a></li>
    <li><a href="#tracking">Tracking your order</a></li>
    <li><a href="#delivery-day">On delivery day</a></li>
    <li><a href="#issues">If something goes wrong</a></li>
      </ol>
    </aside>

    <main class="policy__main">
      <section class="policy-section" id="kuwait">
        <h2 class="policy-section__title">Within Kuwait</h2>
        <div class="shipping-grid">
           <article class="shipping-option">
             <h3>Standard</h3>
             <p class="shipping-option__price">Free over 50 KWD<br><span>2.500 KWD under</span></p>
             <p>2–3 working days · Sat–Thu delivery · WhatsApp tracking</p>
           </article>
           <article class="shipping-option">
             <h3>Express next-day</h3>
             <p class="shipping-option__price">3.500 KWD</p>
             <p>Next working day · order by 2 PM · WhatsApp tracking</p>
           </article>
           <article class="shipping-option">
             <h3>Same-day · Kuwait City</h3>
             <p class="shipping-option__price">5.000 KWD</p>
             <p>Same day · order by 12 PM · within Capital, Hawalli, Mubarak Al-Kabeer governorates</p>
           </article>
           <article class="shipping-option">
             <h3>Atelier pickup</h3>
             <p class="shipping-option__price">Free</p>
             <p>Ready in 2 hours · Sharq Tower · Sat–Thu, 11 AM – 7 PM</p>
           </article>
         </div>
      </section>

      <section class="policy-section" id="gcc">
        <h2 class="policy-section__title">Across the GCC</h2>
        <div class="size-table-wrap">
           <table class="size-table">
             <thead><tr><th>Country</th><th>Standard</th><th>Express</th><th>Free over</th></tr></thead>
             <tbody>
               <tr><td><strong>Saudi Arabia</strong></td><td>3–5 days · 7.500 KWD</td><td>1–2 days · 12.500 KWD</td><td>100 KWD</td></tr>
               <tr><td><strong>UAE</strong></td><td>3–5 days · 6.500 KWD</td><td>1–2 days · 11.500 KWD</td><td>100 KWD</td></tr>
               <tr><td><strong>Bahrain</strong></td><td>3–5 days · 5.000 KWD</td><td>1–2 days · 9.000 KWD</td><td>80 KWD</td></tr>
               <tr><td><strong>Qatar</strong></td><td>3–5 days · 6.000 KWD</td><td>1–2 days · 10.500 KWD</td><td>100 KWD</td></tr>
               <tr><td><strong>Oman</strong></td><td>4–6 days · 7.000 KWD</td><td>2–3 days · 12.000 KWD</td><td>100 KWD</td></tr>
             </tbody>
           </table>
         </div>
         <p>Import duties and VAT are calculated at checkout and included in your total — no surprise fees at delivery.</p>
      </section>

      <section class="policy-section" id="tracking">
        <h2 class="policy-section__title">Tracking your order</h2>
        <p>Once your order ships, you&rsquo;ll get:</p>
         <ul class="policy-list">
           <li>A <strong>WhatsApp message</strong> with the tracking link and ETA</li>
           <li>An <strong>email confirmation</strong> with the same details</li>
           <li><strong>Real-time updates</strong> from the courier as the package moves</li>
           <li>An <strong>arrival window</strong> on the day of delivery</li>
         </ul>
         <p>You can also track from your account dashboard at any time.</p>
      </section>

      <section class="policy-section" id="delivery-day">
        <h2 class="policy-section__title">On delivery day</h2>
        <p>Our couriers will WhatsApp you 30 minutes before arrival. Please make sure someone is available to receive the package — most pieces require a signature.</p>
         <p>If you&rsquo;re not home, the courier will hold the package and attempt redelivery the next working day. After two failed attempts, the package returns to our atelier and we&rsquo;ll reach out to arrange.</p>
      </section>

      <section class="policy-section" id="issues">
        <h2 class="policy-section__title">If something goes wrong</h2>
        <p>If your package is damaged, missing items, or hasn&rsquo;t arrived after the expected window:</p>
         <p><a href="/contact" class="link-arrow">WhatsApp the atelier <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></p>
         <p>We&rsquo;ll resolve it within 24 hours — usually with a same-day reship.</p>
      </section>
    </main>
  </div>
</section>

