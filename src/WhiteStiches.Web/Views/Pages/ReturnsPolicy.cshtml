@{
    ViewData["Title"] = "Returns policy · White Stitches";
    ViewData["MetaDescription"] = "Our 14-day returns policy, what can be returned, and how refunds work.";
}

<section class="page-hero">
  <div class="page-hero__inner">
    <span class="eyebrow">@L["Help · Returns policy"]</span>
    <h1 class="page-hero__title">@L["Returns & exchanges."]</h1>
    <p class="page-hero__lede">@L["14 days from the day you receive your order. Unworn pieces with original tags. Refunds in 3–5 working days."]</p>
    <p class="page-hero__meta">@L["Last updated"] · 5 May 2026</p>
  </div>
</section>

<section class="policy">
  <div class="policy__inner">
    <aside class="policy__toc" aria-label="@L["On this page"]">
      <span class="eyebrow">@L["On this page"]</span>
      <ol class="policy__toc-list">
    <li><a href="#window">@L["The 14-day window"]</a></li>
    <li><a href="#what-can">@L["What can be returned"]</a></li>
    <li><a href="#cannot">@L["What cannot be returned"]</a></li>
    <li><a href="#how-to">@L["How to return"]</a></li>
    <li><a href="#exchanges">@L["Exchanges"]</a></li>
    <li><a href="#costs">@L["Return shipping costs"]</a></li>
    <li><a href="#refunds">@L["Refunds"]</a></li>
      </ol>
    </aside>

    <main class="policy__main">
      <section class="policy-section" id="window">
        <h2 class="policy-section__title">@L["The 14-day window"]</h2>
        <p>You have <strong>14 days</strong> from the day you receive your order to request a return. After 14 days, returns can only be processed at our discretion and as store credit.</p>
         <p>For orders shipped outside Kuwait, the 14 days begin from the delivery date confirmed by the courier — not the dispatch date.</p>
      </section>

      <section class="policy-section" id="what-can">
        <h2 class="policy-section__title">@L["What can be returned"]</h2>
        <p>Pieces must be:</p>
         <ul class="policy-list">
           <li><strong>Unworn</strong> — no perfume, deodorant, makeup or wear marks</li>
           <li><strong>With original tags</strong> attached</li>
           <li><strong>In original packaging</strong> — tissue, dustbag and box where applicable</li>
         </ul>
      </section>

      <section class="policy-section" id="cannot">
        <h2 class="policy-section__title">@L["What cannot be returned"]</h2>
        <ul class="policy-list">
           <li><strong>Final-sale items</strong> (marked clearly on the product page)</li>
           <li><strong>Swimwear and lingerie</strong> for hygiene reasons</li>
           <li><strong>Pierced earrings</strong> for hygiene reasons</li>
           <li><strong>Personalised or made-to-measure pieces</strong></li>
           <li><strong>Sale items</strong> — returnable for store credit only, not refund</li>
         </ul>
      </section>

      <section class="policy-section" id="how-to">
        <h2 class="policy-section__title">@L["How to return"]</h2>
        <ol class="policy-list policy-list--ordered">
           <li>Go to Account → Returns and select the order</li>
           <li>Choose the items you want to return and the reason</li>
           <li>We&rsquo;ll review within 24 hours and email a prepaid label</li>
           <li>Drop the package at any courier point within 7 days</li>
           <li>Once received and inspected, your refund lands in 3–5 working days</li>
         </ol>
      </section>

      <section class="policy-section" id="exchanges">
        <h2 class="policy-section__title">@L["Exchanges"]</h2>
        <p>We don&rsquo;t do direct exchanges — instead, return the original piece for a refund or store credit, and place a new order for the size or colour you want.</p>
         <p>This way you get what you want faster, and we can hold the new size for you while the return is in transit.</p>
      </section>

      <section class="policy-section" id="costs">
        <h2 class="policy-section__title">@L["Return shipping costs"]</h2>
        <p><strong>Free returns</strong> on defective pieces or our errors.</p>
         <p><strong>2.000 KWD flat fee</strong> deducted from your refund for change-of-mind returns within Kuwait. Higher for GCC returns (see your return label for exact cost).</p>
      </section>

      <section class="policy-section" id="refunds">
        <h2 class="policy-section__title">@L["Refunds"]</h2>
        <p>Refunds go back to your original payment method:</p>
         <ul class="policy-list">
           <li><strong>KNET / cards</strong> — 3–5 working days</li>
           <li><strong>Tabby / Tamara</strong> — adjusted on your next instalment, processed by them</li>
           <li><strong>Cash on delivery</strong> — refunded as store credit (we cannot send physical cash)</li>
         </ul>
      </section>
    </main>
  </div>
</section>

