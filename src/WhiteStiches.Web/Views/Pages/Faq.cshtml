@{
    ViewData["Title"] = "FAQ · White Stitches";
    ViewData["MetaDescription"] = "Frequently asked questions — tailoring, orders, delivery and returns.";

    // Both translations live in the view (these answers were never localized via resx, and keeping
    // them inline avoids long, fragile resx keys for editorial copy). RTL layout follows the culture.
    var isAr = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    string T(string en, string ar) => isAr ? ar : en;
}

<section class="page-hero">
  <div class="page-hero__inner">
    <span class="eyebrow">@L["Help · FAQ"]</span>
    <h1 class="page-hero__title">@L["Frequently asked."]</h1>
    <p class="page-hero__lede">@T("Quick answers to what we’re asked most — tailoring, orders, delivery and returns.", "إجابات سريعة عن أكثر ما يُسأل عنه — التفصيل، الطلبات، التوصيل والإرجاع.")</p>
    <p class="page-hero__meta">@T("Last updated · 29 June 2026", "آخر تحديث · 29 يونيو 2026")</p>
  </div>
</section>

<section class="policy">
  <div class="policy__inner">
    <aside class="policy__toc" aria-label="@L["On this page"]">
      <span class="eyebrow">@L["On this page"]</span>
      <ol class="policy__toc-list">
        <li><a href="#tailoring">@T("Tailoring & made-to-order", "التفصيل والطلبات الخاصة")</a></li>
        <li><a href="#returns">@T("Returns & exchanges", "الإرجاع والاستبدال")</a></li>
        <li><a href="#shipping">@T("Shipping & delivery", "الشحن والتوصيل")</a></li>
        <li><a href="#contact">@T("Contact", "التواصل")</a></li>
      </ol>
    </aside>

    <main class="policy__main">

      <section class="policy-section" id="tailoring">
        <h2 class="policy-section__title">@T("Tailoring & made-to-order", "التفصيل والطلبات الخاصة")</h2>
        <div class="faq-item">
          <button type="button" class="faq-item__q" aria-expanded="false">
            <span>@T("Do you offer custom tailoring services?", "هل توفرون خدمة التفصيل حسب المقاس؟")</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 5v14M5 12h14"/></svg>
          </button>
          <div class="faq-item__a"><p>@T("Yes, we offer selected designs that can be tailored or adjusted based on the client’s measurements and preferences.", "نعم، نوفر خدمة تنفيذ بعض التصاميم حسب المقاسات أو التعديلات الخاصة بالعميل.")</p></div>
        </div>
      </section>

      <section class="policy-section" id="returns">
        <h2 class="policy-section__title">@T("Returns & exchanges", "الإرجاع والاستبدال")</h2>
        <div class="faq-item">
          <button type="button" class="faq-item__q" aria-expanded="false">
            <span>@T("Can customized orders be exchanged or returned?", "هل يمكن استبدال أو استرجاع الطلبات الخاصة؟")</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 5v14M5 12h14"/></svg>
          </button>
          <div class="faq-item__a"><p>@T("Customized or tailored orders made based on the client’s request or measurements are non-returnable and non-exchangeable.", "الطلبات المصممة أو المفصلة حسب الطلب والمقاسات الخاصة لا يمكن استبدالها أو استرجاعها.")</p></div>
        </div>
        <div class="faq-item">
          <button type="button" class="faq-item__q" aria-expanded="false">
            <span>@T("Can ready-made items be exchanged or returned?", "هل يمكن استبدال أو استرجاع القطع الجاهزة؟")</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 5v14M5 12h14"/></svg>
          </button>
          <div class="faq-item__a"><p>@T("Yes, ready-made items may be exchanged or returned provided that they are unused, in their original condition, and returned with the original packaging. Customers are responsible for all delivery charges related to exchange or return requests.", "نعم، يمكن استبدال أو استرجاع القطع الجاهزة بشرط أن تكون غير مستخدمة، وبحالتها الأصلية، ومرفقة بالتغليف الأصلي. كما يتحمل العميل تكاليف التوصيل الخاصة بعمليات الاستبدال أو الاسترجاع.")</p></div>
        </div>
      </section>

      <section class="policy-section" id="shipping">
        <h2 class="policy-section__title">@T("Shipping & delivery", "الشحن والتوصيل")</h2>
        <div class="faq-item">
          <button type="button" class="faq-item__q" aria-expanded="false">
            <span>@T("How long does delivery take?", "كم تستغرق مدة التوصيل؟")</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 5v14M5 12h14"/></svg>
          </button>
          <div class="faq-item__a"><p>@T("Processing and delivery times vary depending on the item, and the estimated delivery time will be specified in each product’s details section.", "مدة تجهيز وتوصيل الطلب تختلف حسب نوع القطعة، ويتم توضيح المدة في تفاصيل كل منتج.")</p></div>
        </div>
        <div class="faq-item">
          <button type="button" class="faq-item__q" aria-expanded="false">
            <span>@T("Is delivery available outside Kuwait?", "هل التوصيل متوفر خارج الكويت؟")</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 5v14M5 12h14"/></svg>
          </button>
          <div class="faq-item__a"><p>@T("Currently, delivery is available within Kuwait only.", "حالياً، التوصيل متوفر داخل الكويت فقط.")</p></div>
        </div>
      </section>

      <section class="policy-section" id="contact">
        <h2 class="policy-section__title">@T("Contact", "التواصل")</h2>
        <div class="faq-item">
          <button type="button" class="faq-item__q" aria-expanded="false">
            <span>@T("How can we contact you?", "كيف يمكن التواصل معكم؟")</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 5v14M5 12h14"/></svg>
          </button>
          <div class="faq-item__a"><p>@T("You can contact us through our official social media accounts or via the contact page on our website.", "يمكنكم التواصل معنا عبر حساباتنا الرسمية أو من خلال صفحة التواصل بالموقع.")</p></div>
        </div>
      </section>

    </main>
  </div>
</section>

