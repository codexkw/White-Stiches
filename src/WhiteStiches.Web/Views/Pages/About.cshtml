@{
    ViewData["Title"] = "Our Story · White Stitches";
    ViewData["MetaDescription"] = "A small atelier in Kuwait City. Pieces meant to outlast a season.";
}

<!-- ============================ ABOUT HERO ============================ -->
<section class="about-hero">
  <div class="about-hero__media">
    <img src="~/assets/products/product-4.jpg" alt="" />
    <div class="about-hero__overlay"></div>
  </div>
  <div class="about-hero__inner">
    <span class="eyebrow eyebrow--paper">Our Story</span>
    <h1 class="about-hero__title">Made in Kuwait.<br><em>For the women of the GCC.</em></h1>
    <p class="about-hero__lede">Founded in 2024, White Stitches is a small atelier in the heart of Kuwait City — quietly designing pieces meant to outlast a season.</p>
  </div>
</section>

<!-- ============================ FOUNDER LETTER ============================ -->
<section class="about-letter">
  <div class="about-letter__inner">
    <span class="eyebrow">A letter from our founder</span>
    <div class="about-letter__body">
      <p class="about-letter__lead">We started White Stitches because we were tired of fast fashion that didn&rsquo;t fit our climate, our culture, or our values.</p>
      <p>Our pieces are designed for the woman who wants quiet luxury — the silk that drapes correctly, the seam that doesn&rsquo;t fray, the trouser that flatters whether she&rsquo;s in a meeting in Kuwait City or a private dinner in Riyadh. We don&rsquo;t chase trends. We don&rsquo;t over-produce. Every piece is made in small batches, finished by hand, and shipped from our atelier in Sharq.</p>
      <p>Thank you for joining us at the beginning. There&rsquo;s a lot more to make.</p>
      <p class="about-letter__signature">— Layla Al-Sabah<br><em>Founder &amp; Creative Director</em></p>
    </div>
  </div>
</section>

<!-- ============================ VALUES STRIP ============================ -->
<section class="about-values">
  <div class="about-values__inner">
    <article class="about-value">
      <span class="about-value__num">01</span>
      <h3>Made by hand</h3>
      <p>Every seam is finished by our team of 14 tailors in Kuwait. No shortcuts, no outsourcing.</p>
    </article>
    <article class="about-value">
      <span class="about-value__num">02</span>
      <h3>Small batches</h3>
      <p>We produce in runs of 50 or fewer. When a piece sells out, we decide deliberately whether to reorder.</p>
    </article>
    <article class="about-value">
      <span class="about-value__num">03</span>
      <h3>Designed for here</h3>
      <p>Fabrics chosen for our climate. Cuts drafted for our culture. Sizes that actually fit our bodies.</p>
    </article>
    <article class="about-value">
      <span class="about-value__num">04</span>
      <h3>Quiet over loud</h3>
      <p>No logos. No noise. Pieces designed to be recognised by the right people.</p>
    </article>
  </div>
</section>

<!-- ============================ STORY GRID ============================ -->
<section class="about-grid">
  <div class="about-grid__inner">
    <div class="about-grid__row">
      <div class="about-grid__copy">
        <span class="eyebrow">The atelier</span>
        <h2>A small house in Sharq.</h2>
        <p>Our atelier sits on the third floor of a quiet building in Sharq — overlooking the corniche, three doors down from a coffee shop we visit too often. It&rsquo;s where every piece is patterned, cut, sewn and finished.</p>
        <p>You&rsquo;re welcome to visit by appointment. We&rsquo;ll make tea.</p>
      </div>
      <div class="about-grid__media">
        <img src="~/assets/products/product-1.jpg" alt="The atelier" />
      </div>
    </div>

    <div class="about-grid__row about-grid__row--reverse">
      <div class="about-grid__copy">
        <span class="eyebrow">Our fabrics</span>
        <h2>Sourced for the climate.</h2>
        <p>We work with mills in Italy, Japan and India, choosing fabrics that breathe in 45° heat without losing their structure. Silk for the slip dresses. Wool-blend twill for the blazers. Linen-cotton for the trousers.</p>
        <p>Every fabric is tested in our office for a full week before we order in volume — we wear it, wash it, see how it ages.</p>
      </div>
      <div class="about-grid__media">
        <img src="~/assets/products/product-2.jpg" alt="Our fabrics" />
      </div>
    </div>

    <div class="about-grid__row">
      <div class="about-grid__copy">
        <span class="eyebrow">Sustainability</span>
        <h2>Slower, on purpose.</h2>
        <p>We won&rsquo;t pretend to be a sustainable brand — fashion is fundamentally not. But we do the things we can: small production runs, deadstock fabrics where the quality matches, biodegradable packaging, no plastic poly-bags. Returns come back to us, get inspected, and either return to inventory or are donated locally.</p>
      </div>
      <div class="about-grid__media">
        <img src="~/assets/products/product-3.jpg" alt="Sustainability" />
      </div>
    </div>
  </div>
</section>

<!-- ============================ CTA STRIP ============================ -->
<section class="about-cta">
  <div class="about-cta__inner">
    <h2>Come visit the atelier.</h2>
    <p>Block 3, Sharq Tower · Floor 3 · Kuwait City<br>Sat–Thu · 11 AM – 7 PM · by appointment</p>
    <div class="about-cta__actions">
      <a href="/contact" class="btn btn--primary">Book an appointment</a>
      <a href="/" class="btn btn--ghost">Shop the new edit</a>
    </div>
  </div>
</section>

