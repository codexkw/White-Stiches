@{
    ViewData["Title"] = "About Us · White Stitches";
    ViewData["MetaDescription"] = "WhiteStiches was born from a different idea — timeless pieces where every stitch is part of a story.";

    // Both translations live in the view (this is editorial copy, never localized via resx —
    // keeping it inline avoids long, fragile resx keys). RTL layout follows the culture.
    var isAr = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    string T(string en, string ar) => isAr ? ar : en;
}

<!-- ============================ ABOUT HERO ============================ -->
<section class="about-hero">
  <div class="about-hero__media">
    <img src="~/assets/products/product-4.jpg" alt="" />
    <div class="about-hero__overlay"></div>
  </div>
  <div class="about-hero__inner">
    <span class="eyebrow eyebrow--paper">@T("About Us", "من نحن")</span>
    <h1 class="about-hero__title">WhiteStiches</h1>
    <p class="about-hero__lede">
      @T("In a world where fashion is filled with repetition…", "في عالم تمتلئ فيه الموضة بالتكرار…")<br>
      @T("WhiteStiches was born from a different idea.", "وُلدت WhiteStiches بفكرة مختلفة.")
    </p>
  </div>
</section>

<!-- ============================ BRAND STATEMENT ============================ -->
<section class="about-letter">
  <div class="about-letter__inner">
    <span class="eyebrow">@T("Our story", "قصتنا")</span>
    <div class="about-letter__body">
      <p class="about-letter__lead">
        @T("Every piece begins with a vision,", "كل قطعة تبدأ بفكرة")<br>
        @T("then turns into details,", "ثم تتحول إلى تفاصيل")<br>
        @T("then into a design with its own presence.", "ثم إلى قطعة لها حضورها الخاص.")
      </p>
      <p>
        @T("Our designs are not made for just one season,", "تصاميمنا ليست موسمية فقط،")<br>
        @T("but timeless pieces meant to stay in your wardrobe for years.", "بل قطع يمكن أن تبقى في خزانتك لسنوات.")
      </p>
      <p>
        @T("Pieces to wear today…", "قطع تُلبس اليوم…")<br>
        @T("and still feel elegant tomorrow.", "وتبقى أنيقة غداً.")
      </p>
      <p class="about-letter__signature">
        @T("At WhiteStiches,", "في WhiteStiches")<br>
        @T("every stitch is more than just a thread…", "كل غرزة ليست مجرد خيط…")<br>
        @T("it’s part of a story.", "بل جزء من قصة.")
      </p>
    </div>
  </div>
</section>

<!-- ============================ CTA STRIP ============================ -->
<section class="about-cta">
  <div class="about-cta__inner">
    <h2>@T("Every stitch is part of a story.", "كل غرزة جزء من قصة.")</h2>
    <div class="about-cta__actions">
      <a href="/" class="btn btn--primary">@T("Shop the collection", "تسوّق المجموعة")</a>
      <a href="/contact" class="btn btn--ghost">@T("Contact us", "تواصل معنا")</a>
    </div>
  </div>
</section>

<!-- ============================ FOOTER ============================ -->
