@{
    ViewData["Title"] = "White Stitches — Fashion KW";
    ViewData["MetaDescription"] = "White Stitches — Premium fashion from Kuwait. Curated collections delivered across the GCC.";
}

<!-- ============================ HERO ============================ -->
<section class="hero">
  <div class="hero__pattern" aria-hidden="true"></div>

  <div class="hero__media hero__media--video">
    <video class="hero__video"
           autoplay
           muted
           loop
           playsinline
           preload="auto"
           poster="~/assets/products/product-3.jpg"
           aria-label="@L["Spring 2026 editorial — Noor double-breasted dress"]">
      <source src="~/assets/video/hero.mp4" type="video/mp4" />
      <!-- Fallback image for browsers that can't play the video -->
      <img src="~/assets/products/product-3.jpg"
           alt="@L["Spring 2026 editorial — Noor double-breasted dress"]" class="hero__img" />
    </video>
    <div class="hero__veil" aria-hidden="true"></div>
  </div>

  <div class="hero__content">
    <span class="eyebrow">@L["Spring · Summer 2026"]</span>
    <h1 class="hero__title">
      <span class="hero__title-line">@L["The art of"]</span>
      <span class="hero__title-line hero__title-line--italic">@L["quiet elegance."]</span>
    </h1>
    <p class="hero__lede">
      @L["A curated edit of cuts, fabrics and silhouettes — designed for the woman who measures luxury in stitches, not labels."]
    </p>
    <div class="hero__ctas">
      <a href="/collection" class="btn btn--primary">@L["Shop the Edit"]
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <a href="/collection" class="btn btn--ghost">@L["Watch the Film"]</a>
    </div>
  </div>

  <div class="hero__meta">
    <div class="hero__meta-item">
      <span class="hero__meta-num">01</span>
      <span class="hero__meta-label">@L["Lookbook"]</span>
    </div>
    <div class="hero__meta-item">
      <span class="hero__meta-num">28</span>
      <span class="hero__meta-label">@L["New Pieces"]</span>
    </div>
    <div class="hero__meta-item">
      <span class="hero__meta-num">06</span>
      <span class="hero__meta-label">@L["GCC Markets"]</span>
    </div>
  </div>

  <button class="hero__scroll" aria-label="@L["Scroll to explore"]">
    <span>@L["Scroll"]</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
  </button>
</section>

<!-- ============================ MARQUEE STRIP (admin-managed, bilingual) ============================ -->
@await Component.InvokeAsync("SiteChrome", new { section = "HeroMarquee" })

<!-- ============================ CATEGORY CIRCLES ============================ -->
<section class="categories section--light" id="categories">
  <div class="section-head section-head--center">
    <span class="eyebrow">@L["Shop by Category"]</span>
    <h2 class="section-title">@L["Curated lines, season after season."]</h2>
  </div>

  @await Component.InvokeAsync("NavMenu", new { section = "Circles" })
</section>

<!-- ============================ FEATURED PRODUCTS ============================ -->
<section class="products section--light" id="products">
  <div class="section-head section-head--row">
    <div>
      <span class="eyebrow">@L["New Arrivals"]</span>
      <h2 class="section-title">@L["Just landed."]</h2>
    </div>
    <a href="/collection" class="link-arrow">@L["View all →"]</a>
  </div>

  @await Component.InvokeAsync("FeaturedProducts")
</section>

<!-- ============================ NEWSLETTER ============================ -->
<section class="newsletter">
  <div class="newsletter__pattern" aria-hidden="true"></div>
  <div class="newsletter__inner">
    <span class="eyebrow">@L["The List"]</span>
    <h2 class="newsletter__title">@L["Be the first to receive new edits, private events and the SS26 lookbook."]</h2>
    @{ var newsletterResult = TempData["NewsletterResult"] as string; }
    @if (newsletterResult == "ok")
    {
      <div class="auth-success">
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="32" cy="32" r="28"/><path d="M22 32l8 8 14-16"/></svg>
        <h2>@L["You're on the list."]</h2>
        <p>@L["Welcome — the next edit lands in your inbox first."]</p>
      </div>
    }
    else
    {
      <form class="newsletter__form" method="post" action="/newsletter">
        @Html.AntiForgeryToken()
        <input type="hidden" name="source" value="home" />
        <div class="field">
          <input type="email" name="email" placeholder="@L["Your email address"]" required aria-label="@L["Email address"]" />
          <button type="submit" class="btn btn--primary">@L["Subscribe"]</button>
        </div>
        <label class="checkbox">
          <input type="checkbox" name="whatsAppOptIn" value="true" />
          <span>@L["Also send me styling tips on WhatsApp"]</span>
        </label>
        @if (newsletterResult == "exists")
        {
          <p style="margin-top:12px;font-size:13px;color:var(--c-accent)">@L["You're already on the list — we'll keep the edits coming."]</p>
        }
      </form>
    }
  </div>
</section>

<!-- ============================ FOOTER ============================ -->
