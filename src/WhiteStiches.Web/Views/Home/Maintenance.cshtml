@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>We’ll be right back · White Stitches</title>
<meta name="description" content="We’re briefly offline for maintenance. We’ll be back shortly." />
<meta name="robots" content="noindex" />
<link rel="icon" type="image/svg+xml" href="~/assets/logo-mark.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter+Tight:wght@@300;400;500;600&family=Tajawal:wght@@300;400;500;700&display=swap" rel="stylesheet">
<style>
  body { background: #0a0a0a; margin: 0; color: #e8e2d6; font-family: "Inter Tight", system-ui, sans-serif; min-height: 100vh; display: flex; flex-direction: column; }
</style>
<link rel="stylesheet" href="~/css/design-system.css?v=2.6" />
<link rel="stylesheet" href="~/css/site.css?v=2.6" />
</head>
<body class="maint-body">

<main class="maint">
  <div class="maint__inner">
    <a href="/" class="maint__logo" aria-label="White Stitches">
      <img src="~/assets/logo-full.png" alt="White Stitches" />
    </a>

    <span class="eyebrow">Atelier closed briefly</span>
    <h1 class="maint__title">We’ll be right back.</h1>
    <p class="maint__lede">Our site is going through a quick refresh. We’re back in roughly <strong>15 minutes</strong> — the atelier itself is still open and you can WhatsApp us in the meantime.</p>

    <form class="maint__form" onsubmit="event.preventDefault(); window.handleMaintNotify && window.handleMaintNotify();">
      <span class="eyebrow">Want a heads-up when we’re back?</span>
      <div class="maint__form-row">
        <div class="co-field" style="flex: 1;">
          <input type="email" id="maintEmail" required placeholder=" " autocomplete="email" />
          <label for="maintEmail">Email</label>
        </div>
        <button type="submit" class="btn btn--primary">Notify me</button>
      </div>
      <div class="auth-success" id="maintSuccess" hidden>
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="32" cy="32" r="28"/><path d="M22 32l8 8 14-16"/></svg>
        <h2>You’re on the list.</h2>
        <p>We’ll email you the moment we’re back online.</p>
      </div>
    </form>

    <div class="maint__divider"><em>or reach us now</em></div>

    <div class="maint__actions">
      <a href="#" class="btn btn--ghost">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 11.5a8.4 8.4 0 0 1-8.4 8.4 8.4 8.4 0 0 1-4-1L3 20l1.1-5.6a8.4 8.4 0 0 1-1-4A8.4 8.4 0 0 1 11.5 2 8.4 8.4 0 0 1 21 11.5z"/></svg>
        WhatsApp the atelier
      </a>
      <a href="mailto:hello@@whitestiches.kw" class="btn btn--ghost">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="5" width="18" height="14" rx="1"/><path d="m3 7 9 6 9-6"/></svg>
        Email us
      </a>
    </div>

    <div class="maint__social">
      <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg></a>
      <a href="#" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M14 4v10.5a3.5 3.5 0 1 1-3.5-3.5"/><path d="M14 4c0 2.5 2 4.5 4.5 4.5"/></svg></a>
      <a href="#" aria-label="Pinterest"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M11 22c.5-3 .8-4 1.2-5.5"/><path d="M8 9.5C8 7 10 5 12.5 5S17 7 17 9.5c0 3-2 5-4 5-1 0-1.7-.5-2-1.2"/></svg></a>
    </div>
  </div>
</main>

<footer class="maint__foot">
  <span>© 2026 White Stitches Kuwait</span>
  <a href="/contact">Contact</a>
</footer>

<script src="~/js/site.js?v=2.6"></script>
</body>
</html>