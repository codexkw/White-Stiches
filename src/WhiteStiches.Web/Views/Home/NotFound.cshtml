@{
    ViewData["Title"] = "404 · White Stitches";
    ViewData["MetaDescription"] = "The page you’re looking for couldn’t be found.";
}

<section class="error-page">
  <div class="error-page__inner">
    <span class="error-page__num" aria-hidden="true">404</span>
    <span class="eyebrow">Page not found</span>
    <h1 class="error-page__title">This page slipped a stitch.</h1>
    <p class="error-page__lede">The link you followed doesn’t lead anywhere on our site — maybe a typo, or maybe it’s been moved.</p>

    <div class="error-page__actions">
      <a href="/" class="btn btn--primary">Back to home</a>
      <a href="/collection" class="btn btn--ghost">Shop new arrivals</a>
    </div>

    <div class="error-page__suggest">
      <span class="eyebrow">Or try one of these</span>
      <ul>
        <li><a href="/collection">Women</a></li>
        <li><a href="/collection">Men</a></li>
        <li><a href="/collection">Accessories</a></li>
        <li><a href="/account">Your account</a></li>
        <li><a href="/contact">Contact us</a></li>
        <li><a href="/faq">FAQ</a></li>
      </ul>
    </div>

    <div class="error-page__featured">
      <span class="eyebrow">While you’re here</span>
      <div class="error-page__products">
        <a href="/product" class="error-product">
          <img src="~/assets/products/product-4.jpg" alt="" />
          <strong>Mira Draped Midi</strong>
          <span>42.500 KWD</span>
        </a>
        <a href="/product" class="error-product">
          <img src="~/assets/products/product-1.jpg" alt="" />
          <strong>Lina Silk Slip Dress</strong>
          <span>76.000 KWD</span>
        </a>
        <a href="/product" class="error-product">
          <img src="~/assets/products/product-2.jpg" alt="" />
          <strong>Atelier Blazer</strong>
          <span>68.000 KWD</span>
        </a>
        <a href="/product" class="error-product">
          <img src="~/assets/products/product-3.jpg" alt="" />
          <strong>Sahar Trouser</strong>
          <span>38.500 KWD</span>
        </a>
      </div>
    </div>
  </div>
</section>

