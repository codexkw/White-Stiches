<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <symbol id="ws-mark" viewBox="0 0 200 200">
      <g fill="currentColor" fill-rule="evenodd">
        <path d="M40 20 L80 20 L60 60 Z"/><path d="M120 20 L160 20 L140 60 Z"/>
        <path d="M85 30 L100 50 L85 65 Z"/><path d="M115 30 L100 50 L115 65 Z"/>
        <path d="M20 50 L40 70 L40 130 L20 150 Z"/><path d="M180 50 L160 70 L160 130 L180 150 Z"/>
        <path d="M100 60 L130 100 L100 140 L70 100 Z"/>
        <path d="M100 80 L115 100 L100 120 L85 100 Z" fill="#0a0a0a"/>
        <path d="M40 180 L80 180 L60 140 Z"/><path d="M120 180 L160 180 L140 140 Z"/>
        <path d="M85 170 L100 150 L85 135 Z"/><path d="M115 170 L100 150 L115 135 Z"/>
      </g>
    </symbol>
    <symbol id="ws-mark-light" viewBox="0 0 200 200">
      <g fill="currentColor" fill-rule="evenodd">
        <path d="M40 20 L80 20 L60 60 Z"/><path d="M120 20 L160 20 L140 60 Z"/>
        <path d="M85 30 L100 50 L85 65 Z"/><path d="M115 30 L100 50 L115 65 Z"/>
        <path d="M20 50 L40 70 L40 130 L20 150 Z"/><path d="M180 50 L160 70 L160 130 L180 150 Z"/>
        <path d="M100 60 L130 100 L100 140 L70 100 Z"/>
        <path d="M100 80 L115 100 L100 120 L85 100 Z" fill="#f5f1ea"/>
        <path d="M40 180 L80 180 L60 140 Z"/><path d="M120 180 L160 180 L140 140 Z"/>
        <path d="M85 170 L100 150 L85 135 Z"/><path d="M115 170 L100 150 L115 135 Z"/>
      </g>
    </symbol>
  </defs>
</svg>

<div class="doc">

  <header class="doc__intro">
    <div class="doc__meta">
      <div>White Stitches Fashion</div>
      <div>Design System</div>
      <div>Version 1.0 — April 2026</div>
    </div>
    <h1 class="doc__h1">A system for <em>quiet</em><br>luxury.</h1>
  </header>

  <section class="doc__section">
    <div class="doc__section-head">
      <h2 class="doc__h2">Design Principles</h2>
      <span class="doc__num">01</span>
    </div>
    <div class="principles">
      <div class="principle">
        <span class="principle__num">i.</span>
        <h3 class="principle__title">Black is the canvas.</h3>
        <p class="principle__body">The store lives on near-black (#0A0A0A) — not pure black, but a soft, warm void. The gallery wall against which every garment becomes the subject.</p>
      </div>
      <div class="principle">
        <span class="principle__num">ii.</span>
        <h3 class="principle__title">The stitch is the brand.</h3>
        <p class="principle__body">The geometric mark drawn from embroidery is used as a textural pattern — never as decoration. It appears subtly on hero, editorial and newsletter sections — a quiet wallpaper of identity.</p>
      </div>
      <div class="principle">
        <span class="principle__num">iii.</span>
        <h3 class="principle__title">Italic carries emotion.</h3>
        <p class="principle__body">Cormorant Garamond italics handle every emotional moment — taglines, editorial captions, callouts. Roman is for clarity; italics whisper.</p>
      </div>
      <div class="principle">
        <span class="principle__num">iv.</span>
        <h3 class="principle__title">Gold, but never bright.</h3>
        <p class="principle__body">A muted, dusty gold (#C8A96A) is our only accent. It marks sale, hovers, and the cart count — used so sparingly that when it appears, it earns attention.</p>
      </div>
      <div class="principle">
        <span class="principle__num">v.</span>
        <h3 class="principle__title">Bilingual from the start.</h3>
        <p class="principle__body">Every component is built with logical CSS so the entire interface mirrors flawlessly to RTL. Tajawal stands in for Arabic; the same hierarchy holds.</p>
      </div>
      <div class="principle">
        <span class="principle__num">vi.</span>
        <h3 class="principle__title">Hard edges, soft motion.</h3>
        <p class="principle__body">No rounded corners on cards or buttons — luxury demands precision. But every transition is eased, every reveal staggered, every hover soft.</p>
      </div>
    </div>
  </section>

  <section class="doc__section">
    <div class="doc__section-head">
      <h2 class="doc__h2">Logo &amp; Mark</h2>
      <span class="doc__num">02</span>
    </div>
    <div class="logo-row">
      <div class="logo-card logo-card--dark">
        <svg class="logo-mark" style="width:80px;height:80px;color:var(--c-paper)" viewBox="0 0 200 200"><use href="#ws-mark"/></svg>
        <div style="font-family:var(--font-sans);font-size:11px;font-weight:500;letter-spacing:0.32em;color:var(--c-paper)">WHITESTICHES<span style="color:var(--c-accent)">.KW</span></div>
        <div style="font-size:8px;letter-spacing:0.4em;opacity:0.6;color:var(--c-paper)">FASHION</div>
        <div class="logo-card__label" style="color: var(--c-text-fade);margin-top:auto">Primary · on dark</div>
      </div>
      <div class="logo-card logo-card--light">
        <svg class="logo-mark" style="width:80px;height:80px;color:var(--c-ink)" viewBox="0 0 200 200"><use href="#ws-mark-light"/></svg>
        <div style="font-family:var(--font-sans);font-size:11px;font-weight:500;letter-spacing:0.32em">WHITESTICHES<span style="color:var(--c-accent-soft)">.KW</span></div>
        <div style="font-size:8px;letter-spacing:0.4em;opacity:0.6">FASHION</div>
        <div class="logo-card__label" style="margin-top:auto">Inverse · on ivory</div>
      </div>
      <div class="logo-card logo-card--ink">
        <div style="display:flex;align-items:center;gap:14px;color:var(--c-paper)">
          <svg class="logo-mark" style="width:48px;height:48px" viewBox="0 0 200 200"><use href="#ws-mark"/></svg>
          <div style="font-family:var(--font-sans);font-size:14px;font-weight:500;letter-spacing:0.32em">WHITESTICHES<span style="color:var(--c-accent)">.KW</span></div>
        </div>
        <div class="logo-card__label" style="color: var(--c-text-fade);margin-top:auto">Horizontal · navigation</div>
      </div>
      <div class="logo-card logo-card--dark">
        <svg class="logo-mark" style="width:120px;height:120px;color:var(--c-paper)" viewBox="0 0 200 200"><use href="#ws-mark"/></svg>
        <div class="logo-card__label" style="color: var(--c-text-fade);margin-top:auto">Mark only · favicon</div>
      </div>
    </div>
  </section>

  <section class="doc__section">
    <div class="doc__section-head">
      <h2 class="doc__h2">Color Tokens</h2>
      <span class="doc__num">03</span>
    </div>

    <h3 style="font-family:var(--font-display);font-weight:400;font-size:var(--t-xl);margin:0 0 var(--s-3) 0;color:var(--c-text-soft)">Core surfaces</h3>
    <div class="swatches" style="margin-bottom: var(--s-6)">
      <div class="sw"><div class="sw__chip" style="background:#0a0a0a"></div><div class="sw__body"><div class="sw__name">Ink</div><span class="sw__token">--c-ink</span><span class="sw__hex">#0A0A0A</span></div></div>
      <div class="sw"><div class="sw__chip" style="background:#131313"></div><div class="sw__body"><div class="sw__name">Ink 2</div><span class="sw__token">--c-ink-2</span><span class="sw__hex">#131313</span></div></div>
      <div class="sw"><div class="sw__chip" style="background:#1c1c1c"></div><div class="sw__body"><div class="sw__name">Ink 3</div><span class="sw__token">--c-ink-3</span><span class="sw__hex">#1C1C1C</span></div></div>
      <div class="sw"><div class="sw__chip" style="background:#2a2a2a"></div><div class="sw__body"><div class="sw__name">Line</div><span class="sw__token">--c-line</span><span class="sw__hex">#2A2A2A</span></div></div>
      <div class="sw"><div class="sw__chip" style="background:#f5f1ea"></div><div class="sw__body"><div class="sw__name">Paper</div><span class="sw__token">--c-paper</span><span class="sw__hex">#F5F1EA</span></div></div>
      <div class="sw"><div class="sw__chip" style="background:#ebe5d9"></div><div class="sw__body"><div class="sw__name">Paper 2</div><span class="sw__token">--c-paper-2</span><span class="sw__hex">#EBE5D9</span></div></div>
    </div>

    <h3 style="font-family:var(--font-display);font-weight:400;font-size:var(--t-xl);margin:0 0 var(--s-3) 0;color:var(--c-text-soft)">Accents &amp; states</h3>
    <div class="swatches">
      <div class="sw"><div class="sw__chip" style="background:#c8a96a"></div><div class="sw__body"><div class="sw__name">Accent · Gold</div><span class="sw__token">--c-accent</span><span class="sw__hex">#C8A96A</span></div></div>
      <div class="sw"><div class="sw__chip" style="background:#a48851"></div><div class="sw__body"><div class="sw__name">Accent Soft</div><span class="sw__token">--c-accent-soft</span><span class="sw__hex">#A48851</span></div></div>
      <div class="sw"><div class="sw__chip" style="background:#5a2a2a"></div><div class="sw__body"><div class="sw__name">Burgundy</div><span class="sw__token">--c-burgundy</span><span class="sw__hex">#5A2A2A</span></div></div>
      <div class="sw"><div class="sw__chip" style="background:#7a8a76"></div><div class="sw__body"><div class="sw__name">Sage</div><span class="sw__token">--c-sage</span><span class="sw__hex">#7A8A76</span></div></div>
      <div class="sw"><div class="sw__chip" style="background:#6f8a5c"></div><div class="sw__body"><div class="sw__name">Success</div><span class="sw__token">--c-success</span><span class="sw__hex">#6F8A5C</span></div></div>
      <div class="sw"><div class="sw__chip" style="background:#b85547"></div><div class="sw__body"><div class="sw__name">Danger</div><span class="sw__token">--c-danger</span><span class="sw__hex">#B85547</span></div></div>
    </div>
  </section>

  <section class="doc__section">
    <div class="doc__section-head">
      <h2 class="doc__h2">Typography</h2>
      <span class="doc__num">04</span>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--s-5);margin-bottom:var(--s-7)">
      <div style="border:1px solid var(--c-line);padding:var(--s-5)">
        <div style="font-size:11px;letter-spacing:var(--tr-widest);text-transform:uppercase;color:var(--c-text-fade);margin-bottom:var(--s-3)">Display</div>
        <div style="font-family:var(--font-display);font-size:64px;line-height:1;font-weight:300">Cormorant<br><em style="color:var(--c-accent)">Garamond</em></div>
        <div style="margin-top:var(--s-3);font-family:'Courier New',monospace;font-size:11px;color:var(--c-text-muted)">--font-display · 300 / 400 / 500</div>
      </div>
      <div style="border:1px solid var(--c-line);padding:var(--s-5)">
        <div style="font-size:11px;letter-spacing:var(--tr-widest);text-transform:uppercase;color:var(--c-text-fade);margin-bottom:var(--s-3)">UI / Body</div>
        <div style="font-family:var(--font-sans);font-size:48px;line-height:1.05;font-weight:400">Inter Tight<br><span style="font-weight:500">UI &amp; controls</span></div>
        <div style="margin-top:var(--s-3);font-family:'Courier New',monospace;font-size:11px;color:var(--c-text-muted)">--font-sans · 300 / 400 / 500 / 600</div>
      </div>
    </div>

    <h3 style="font-family:var(--font-display);font-weight:400;font-size:var(--t-xl);margin:0 0 var(--s-4) 0;color:var(--c-text-soft)">Type Scale</h3>
    <div class="type-sample"><div class="type-sample__token">--t-5xl</div><div class="type-sample__example" style="font-family:var(--font-display);font-size:var(--t-5xl);font-weight:300;line-height:1">Hero display</div><div class="type-sample__size">96px</div></div>
    <div class="type-sample"><div class="type-sample__token">--t-4xl</div><div class="type-sample__example" style="font-family:var(--font-display);font-size:var(--t-4xl);font-weight:400">Section title</div><div class="type-sample__size">68px</div></div>
    <div class="type-sample"><div class="type-sample__token">--t-3xl</div><div class="type-sample__example" style="font-family:var(--font-display);font-size:var(--t-3xl);font-weight:400">Page heading</div><div class="type-sample__size">48px</div></div>
    <div class="type-sample"><div class="type-sample__token">--t-2xl</div><div class="type-sample__example" style="font-family:var(--font-display);font-size:var(--t-2xl)">Subsection</div><div class="type-sample__size">34px</div></div>
    <div class="type-sample"><div class="type-sample__token">--t-xl</div><div class="type-sample__example" style="font-family:var(--font-display);font-size:var(--t-xl)">Card title</div><div class="type-sample__size">26px</div></div>
    <div class="type-sample"><div class="type-sample__token">--t-lg</div><div class="type-sample__example" style="font-size:var(--t-lg)">Lead paragraph</div><div class="type-sample__size">20px</div></div>
    <div class="type-sample"><div class="type-sample__token">--t-md</div><div class="type-sample__example" style="font-size:var(--t-md)">Body large</div><div class="type-sample__size">17px</div></div>
    <div class="type-sample"><div class="type-sample__token">--t-base</div><div class="type-sample__example" style="font-size:var(--t-base)">Body — default reading size for product descriptions, paragraphs and most UI labels.</div><div class="type-sample__size">15px</div></div>
    <div class="type-sample"><div class="type-sample__token">--t-sm</div><div class="type-sample__example" style="font-size:var(--t-sm)">Small · captions</div><div class="type-sample__size">13px</div></div>
    <div class="type-sample"><div class="type-sample__token">--t-xs</div><div class="type-sample__example" style="font-size:var(--t-xs);letter-spacing:var(--tr-widest);text-transform:uppercase">Eyebrow / micro</div><div class="type-sample__size">11px</div></div>
  </section>

  <section class="doc__section">
    <div class="doc__section-head">
      <h2 class="doc__h2">Spacing Scale</h2>
      <span class="doc__num">05</span>
    </div>
    <div class="spacing-scale">
      <div class="spc"><span class="spc__token">--s-1</span><div class="spc__bar" style="width:4px"></div><span class="spc__val">4px</span></div>
      <div class="spc"><span class="spc__token">--s-2</span><div class="spc__bar" style="width:8px"></div><span class="spc__val">8px</span></div>
      <div class="spc"><span class="spc__token">--s-3</span><div class="spc__bar" style="width:12px"></div><span class="spc__val">12px</span></div>
      <div class="spc"><span class="spc__token">--s-4</span><div class="spc__bar" style="width:16px"></div><span class="spc__val">16px</span></div>
      <div class="spc"><span class="spc__token">--s-5</span><div class="spc__bar" style="width:24px"></div><span class="spc__val">24px</span></div>
      <div class="spc"><span class="spc__token">--s-6</span><div class="spc__bar" style="width:32px"></div><span class="spc__val">32px</span></div>
      <div class="spc"><span class="spc__token">--s-7</span><div class="spc__bar" style="width:48px"></div><span class="spc__val">48px</span></div>
      <div class="spc"><span class="spc__token">--s-8</span><div class="spc__bar" style="width:64px"></div><span class="spc__val">64px</span></div>
      <div class="spc"><span class="spc__token">--s-9</span><div class="spc__bar" style="width:96px"></div><span class="spc__val">96px</span></div>
      <div class="spc"><span class="spc__token">--s-10</span><div class="spc__bar" style="width:128px"></div><span class="spc__val">128px</span></div>
    </div>
  </section>

  <section class="doc__section">
    <div class="doc__section-head">
      <h2 class="doc__h2">Brand Pattern</h2>
      <span class="doc__num">06</span>
    </div>
