@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>White Stitches — Design System v1.0</title>
<link rel="icon" type="image/svg+xml" href="~/assets/logo-mark.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter+Tight:wght@@300;400;500;600&family=Tajawal:wght@@300;400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/design-system.css?v=2.6" />
<style>
  .doc { max-width: 1200px; margin: 0 auto; padding: var(--s-7) var(--gutter) var(--s-9); }
  .doc__intro { border-bottom: 1px solid var(--c-line); padding-bottom: var(--s-7); margin-bottom: var(--s-9); display: grid; grid-template-columns: 1fr 2fr; gap: var(--s-7); align-items: end; }
  .doc__meta { font-size: var(--t-xs); letter-spacing: var(--tr-widest); text-transform: uppercase; color: var(--c-text-fade); line-height: 2; }
  .doc__h1 { font-family: var(--font-display); font-weight: 300; font-size: clamp(var(--t-3xl), 7vw, 7rem); line-height: 0.95; letter-spacing: var(--tr-tight); margin: 0; }
  .doc__h1 em { font-style: italic; color: var(--c-accent); }
  .doc__section { margin-bottom: var(--s-9); }
  .doc__section-head { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--c-line); padding-bottom: var(--s-3); margin-bottom: var(--s-6); }
  .doc__h2 { font-family: var(--font-display); font-weight: 400; font-size: var(--t-3xl); margin: 0; }
  .doc__num { font-family: var(--font-display); font-style: italic; font-size: var(--t-md); color: var(--c-accent); }
  .swatches { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--s-3); }
  .sw { background: var(--c-ink-2); border: 1px solid var(--c-line); }
  .sw__chip { height: 100px; }
  .sw__body { padding: var(--s-3); border-top: 1px solid var(--c-line); }
  .sw__name { font-size: var(--t-sm); font-weight: 500; color: var(--c-text); margin: 0 0 4px 0; }
  .sw__token { font-family: 'Courier New', monospace; font-size: 11px; color: var(--c-text-muted); display: block; }
  .sw__hex { font-family: 'Courier New', monospace; font-size: 11px; color: var(--c-accent); display: block; margin-top: 2px; }
  .type-sample { display: grid; grid-template-columns: 200px 1fr 120px; gap: var(--s-5); padding: var(--s-4) 0; border-bottom: 1px solid var(--c-line); align-items: baseline; }
  .type-sample__token { font-family: 'Courier New', monospace; font-size: 11px; color: var(--c-text-muted); letter-spacing: 0; text-transform: none; }
  .type-sample__example { color: var(--c-text); }
  .type-sample__size { text-align: right; font-family: 'Courier New', monospace; font-size: 11px; color: var(--c-text-fade); }
  .spacing-scale { display: flex; flex-direction: column; gap: var(--s-3); }
  .spc { display: grid; grid-template-columns: 80px 1fr 100px; align-items: center; gap: var(--s-3); padding: var(--s-3) 0; border-bottom: 1px solid var(--c-line); }
  .spc__token { font-family: 'Courier New', monospace; font-size: var(--t-xs); color: var(--c-accent); }
  .spc__bar { height: 12px; background: var(--c-paper); }
  .spc__val { text-align: right; font-family: 'Courier New', monospace; font-size: var(--t-xs); color: var(--c-text-fade); }
  .comp-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--s-3); }
  .comp { background: var(--c-ink-2); border: 1px solid var(--c-line); padding: var(--s-5); }
  .comp__name { font-size: var(--t-xs); letter-spacing: var(--tr-widest); text-transform: uppercase; color: var(--c-text-fade); margin: 0 0 var(--s-3) 0; }
  .comp__demo { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: var(--s-3); min-height: 100px; padding: var(--s-4); background: var(--c-ink); margin-bottom: var(--s-3); border: 1px dashed var(--c-line); }
  .comp__notes { font-size: var(--t-xs); color: var(--c-text-muted); line-height: 1.6; }
  .pattern-demo { height: 280px; border: 1px solid var(--c-line); background: var(--c-ink); position: relative; overflow: hidden; }
  .pattern-demo__inner { position: absolute; inset: 0; }
  .pattern-demo__caption { position: absolute; bottom: var(--s-3); left: var(--s-3); background: var(--c-ink); padding: 6px 12px; font-family: 'Courier New', monospace; font-size: 11px; color: var(--c-accent); border: 1px solid var(--c-line); }
  .logo-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--s-3); }
  .logo-card { border: 1px solid var(--c-line); aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: var(--s-3); }
  .logo-card--dark { background: var(--c-ink); }
  .logo-card--light { background: var(--c-paper); color: var(--c-ink); }
  .logo-card--ink { background: var(--c-ink-2); }
  .logo-card .logo-mark { color: inherit; }
  .logo-card__label { font-size: 9px; letter-spacing: var(--tr-widest); text-transform: uppercase; opacity: 0.5; }
  .principles { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--s-5); }
  .principle { border-left: 1px solid var(--c-accent); padding-left: var(--s-4); }
  .principle__num { font-family: var(--font-display); font-style: italic; font-size: var(--t-md); color: var(--c-accent); }
  .principle__title { font-family: var(--font-display); font-size: var(--t-xl); font-weight: 400; margin: var(--s-2) 0 var(--s-2) 0; }
  .principle__body { font-size: var(--t-sm); color: var(--c-text-soft); line-height: 1.6; margin: 0; }
  .doc-nav { position: fixed; top: var(--s-4); right: var(--s-4); z-index: var(--z-header); background: var(--c-paper); color: var(--c-ink); padding: 10px 18px; font-size: var(--t-xs); font-weight: 600; letter-spacing: var(--tr-wider); text-transform: uppercase; }
  .doc-nav:hover { background: var(--c-accent); }
</style>
</head>
<body>

