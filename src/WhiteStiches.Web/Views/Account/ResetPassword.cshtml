@model WhiteStiches.Web.Models.Auth.ResetPasswordFormModel
@{
    ViewData["Title"] = "Reset password · White Stitches";
    ViewData["MetaDescription"] = "Choose a new password for your White Stitches account.";

    var errors = ViewData.ModelState.Values
        .SelectMany(v => v.Errors)
        .Select(e => e.ErrorMessage)
        .Where(m => !string.IsNullOrWhiteSpace(m))
        .Distinct()
        .ToList();
}

<style>
  .auth-form__error {
    display: flex; flex-direction: column; gap: 4px;
    padding: 12px 16px;
    border: 1px solid rgba(200, 122, 58, 0.4);
    background: rgba(200, 122, 58, 0.08);
  }
  .auth-form__error p { margin: 0; font-size: var(--t-xs); letter-spacing: var(--tr-wide); line-height: var(--lh-loose); color: #c87a3a; }
  .auth-note { margin: 0 0 18px; color: var(--c-muted, #6b6b6b); line-height: var(--lh-loose); }
</style>

<section class="auth">
  <div class="auth__inner">

    <aside class="auth__aside" aria-hidden="true">
      <img src="~/assets/products/product-4.jpg" alt="" class="auth__aside-img" />
      <div class="auth__aside-overlay"></div>
      <div class="auth__aside-copy">
        <span class="eyebrow eyebrow--paper">@L["The Atelier"]</span>
        <h2 class="auth__aside-title">@L["Made in Kuwait. Designed for the GCC."]</h2>
      </div>
    </aside>

    <div class="auth__main">
      <div class="auth-pane is-active">

        @if (Model.Success)
        {
          <header class="auth-pane__head">
            <h1 class="auth-pane__title">@L["Password updated"]</h1>
            <p class="auth-pane__sub">@L["Your password has been changed - you can now sign in with it."]</p>
          </header>
          <a href="/account/login" class="btn btn--primary btn--block">@L["Sign in"]</a>
        }
        else if (Model.LinkInvalid)
        {
          <header class="auth-pane__head">
            <h1 class="auth-pane__title">@L["Reset your password"]</h1>
            <p class="auth-pane__sub">@L["This reset link is invalid or has expired."]</p>
          </header>
          <a href="/account/login" class="btn btn--primary btn--block">@L["Request a new link"]</a>
        }
        else
        {
          <header class="auth-pane__head">
            <h1 class="auth-pane__title">@L["Reset your password"]</h1>
            <p class="auth-pane__sub">@L["Choose a new password to get back into your account."]</p>
          </header>

          <form class="auth-form" method="post" asp-controller="CustomerAuth" asp-action="ResetPassword">
            @if (errors.Count > 0)
            {
              <div class="auth-form__error" role="alert">
                @foreach (var msg in errors)
                {
                  <p>@msg</p>
                }
              </div>
            }

            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div class="co-field">
              <input asp-for="Password" type="password" required autocomplete="new-password" placeholder=" " minlength="8" />
              <label asp-for="Password">@L["New password"]</label>
            </div>

            <div class="co-field">
              <input asp-for="ConfirmPassword" type="password" required autocomplete="new-password" placeholder=" " minlength="8" />
              <label asp-for="ConfirmPassword">@L["Confirm new password"]</label>
            </div>

            <button type="submit" class="btn btn--primary btn--block">@L["Update password"]</button>

            <p class="auth-note" style="margin-top:16px;">
              <a href="/account/login" class="link-arrow link-arrow--inline">@L["Back to sign in"]</a>
            </p>
          </form>
        }

      </div>
    </div>
  </div>
</section>
