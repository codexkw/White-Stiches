@{
    ViewData["Title"] = "Profile · White Stitches";
    ViewData["MetaDescription"] = "Manage your profile, preferences and privacy.";
}

<section class="acct-head">
  <div class="acct-head__inner">
    <span class="eyebrow">Account · Profile</span>
    <h1 class="acct-head__title">Profile &amp; preferences.</h1>
    <p class="acct-head__sub">Manage your personal info, notifications and privacy.</p>
  </div>
</section>

<section class="acct">
  <div class="acct__inner">
    <aside class="acct-nav" aria-label="Account navigation">
  <div class="acct-nav__head">
    <span class="eyebrow">Account</span>
    <strong class="acct-nav__name">Anas Al-Mutairi</strong>
    <span class="acct-nav__email">anas@@whitestiches.kw</span>
  </div>
  <nav class="acct-nav__list">
    <a href="/account" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg><span>Overview</span></a>
    <a href="/account/orders" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7h18l-2 13H5z"/><path d="M8 7V5a4 4 0 018 0v2"/></svg><span>Orders</span></a>
    <a href="/account/addresses" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2a7 7 0 017 7c0 5-7 13-7 13S5 14 5 9a7 7 0 017-7z"/><circle cx="12" cy="9" r="2.5"/></svg><span>Addresses</span></a>
    <a href="/account/wishlist" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><span>Wishlist</span></a>
    <a href="/account/profile" class="acct-nav__link is-active" aria-current="page"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg><span>Profile</span></a>
    <a href="/account/returns" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 11-9-9"/><path d="M21 4v5h-5"/></svg><span>Returns</span></a>
  </nav>
  <a href="/account/login" class="acct-nav__signout"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg><span>Sign out</span></a>
</aside>

    <main class="acct__main">

      <!-- Personal info -->
      <section class="acct-section acct-section--card">
        <header class="acct-section__head">
          <h2>Personal information</h2>
        </header>
        <form class="auth-form" onsubmit="event.preventDefault();">
          <div class="co-field-row">
            <div class="co-field"><input type="text" value="Anas" placeholder=" " /><label>First name</label></div>
            <div class="co-field"><input type="text" value="Al-Mutairi" placeholder=" " /><label>Last name</label></div>
          </div>
          <div class="co-field-row">
            <div class="co-field"><input type="date" value="1994-08-15" placeholder=" " /><label>Date of birth</label><span class="field__hint">For birthday gifts &amp; access</span></div>
            <div class="co-field"><select><option>Prefer not to say</option><option>Female</option><option>Male</option><option>Non-binary</option></select><label>Gender</label></div>
          </div>
          <button type="submit" class="btn btn--primary">Save changes</button>
        </form>
      </section>

      <!-- Email + phone -->
      <section class="acct-section acct-section--card">
        <header class="acct-section__head">
          <h2>Contact</h2>
        </header>
        <form class="auth-form" onsubmit="event.preventDefault();">
          <div class="co-field co-field--with-action">
            <input type="email" value="anas@@whitestiches.kw" placeholder=" " />
            <label>Email</label>
            <span class="acct-verified"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><polyline points="20 6 9 17 4 12"/></svg> Verified</span>
          </div>
          <div class="co-field co-field--phone">
            <span class="field__prefix"><span class="flag flag--kw"></span><span style="padding: 0 8px 0 4px; color: var(--c-text);">+965</span></span>
            <input type="tel" value="5xx xxxxx" placeholder=" " />
            <label>Mobile</label>
          </div>
          <button type="submit" class="btn btn--primary">Update contact</button>
        </form>
      </section>

      <!-- Password -->
      <section class="acct-section acct-section--card">
        <header class="acct-section__head">
          <h2>Password</h2>
        </header>
        <form class="auth-form" onsubmit="event.preventDefault();">
          <div class="co-field co-field--with-action">
            <input type="password" placeholder=" " />
            <label>Current password</label>
            <button type="button" class="co-field__action" aria-label="Show"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg></button>
          </div>
          <div class="co-field co-field--with-action">
            <input type="password" placeholder=" " />
            <label>New password</label>
            <button type="button" class="co-field__action" aria-label="Show"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg></button>
          </div>
          <button type="submit" class="btn btn--primary">Change password</button>
        </form>
      </section>

      <!-- Communication preferences -->
      <section class="acct-section acct-section--card">
        <header class="acct-section__head">
          <h2>Communication preferences</h2>
          <span class="acct-section__meta">You can unsubscribe any time</span>
        </header>
        <div class="acct-comms">
          <table class="acct-comms__table">
            <thead>
              <tr>
                <th></th>
                <th>Email</th>
                <th>WhatsApp</th>
                <th>SMS</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Order updates</strong><span>Confirmations, shipping, delivery</span></td>
                <td><label class="toggle"><input type="checkbox" checked disabled /><span></span></label></td>
                <td><label class="toggle"><input type="checkbox" checked /><span></span></label></td>
                <td><label class="toggle"><input type="checkbox" /><span></span></label></td>
              </tr>
              <tr>
                <td><strong>New arrivals</strong><span>1 a week, never more</span></td>
                <td><label class="toggle"><input type="checkbox" checked /><span></span></label></td>
                <td><label class="toggle"><input type="checkbox" /><span></span></label></td>
                <td><label class="toggle"><input type="checkbox" /><span></span></label></td>
              </tr>
              <tr>
                <td><strong>Private sales &amp; lookbooks</strong><span>Early access for members</span></td>
                <td><label class="toggle"><input type="checkbox" checked /><span></span></label></td>
                <td><label class="toggle"><input type="checkbox" checked /><span></span></label></td>
                <td><label class="toggle"><input type="checkbox" /><span></span></label></td>
              </tr>
              <tr>
                <td><strong>Wishlist alerts</strong><span>Restock &amp; sale notifications</span></td>
                <td><label class="toggle"><input type="checkbox" /><span></span></label></td>
                <td><label class="toggle"><input type="checkbox" checked /><span></span></label></td>
                <td><label class="toggle"><input type="checkbox" /><span></span></label></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Language & currency -->
      <section class="acct-section acct-section--card">
        <header class="acct-section__head">
          <h2>Language &amp; currency</h2>
        </header>
        <form class="auth-form" onsubmit="event.preventDefault();">
          <div class="co-field-row">
            <div class="co-field"><select><option>English</option><option>العربية (Arabic)</option></select><label>Language</label></div>
            <div class="co-field"><select><option>KWD · Kuwaiti Dinar</option><option>SAR · Saudi Riyal</option><option>AED · UAE Dirham</option><option>BHD · Bahraini Dinar</option><option>QAR · Qatari Riyal</option><option>OMR · Omani Rial</option></select><label>Currency</label></div>
          </div>
        </form>
      </section>

      <!-- Privacy / dangerous zone -->
      <section class="acct-section acct-section--card acct-section--danger">
        <header class="acct-section__head">
          <h2>Privacy &amp; data</h2>
        </header>
        <div class="acct-danger">
          <div class="acct-danger__row">
            <div>
              <strong>Download my data</strong>
              <span>Get a copy of everything we have on file (orders, addresses, preferences).</span>
            </div>
            <button type="button" class="btn btn--ghost btn--sm">Request export</button>
          </div>
          <div class="acct-danger__row">
            <div>
              <strong>Delete my account</strong>
              <span>Permanently remove your account and personal data. Orders are kept for legal compliance.</span>
            </div>
            <button type="button" class="btn btn--ghost btn--sm acct-danger__btn">Delete account</button>
          </div>
        </div>
      </section>

    </main>
  </div>
</section>

