@{
    ViewData["Title"] = "Addresses · White Stitches";
    ViewData["MetaDescription"] = "Manage your saved delivery and billing addresses.";
}

<section class="acct-head">
  <div class="acct-head__inner">
    <span class="eyebrow">Account · Addresses</span>
    <h1 class="acct-head__title">Saved addresses.</h1>
    <p class="acct-head__sub">Manage where we deliver and bill.</p>
  </div>
</section>

<section class="acct">
  <div class="acct__inner">
    <aside class="acct-nav" aria-label="Account navigation">
  <div class="acct-nav__head">
    <span class="eyebrow">Account</span>
    <strong class="acct-nav__name">Anas Al-Mutairi</strong>
    <span class="acct-nav__email">anas@@whitestiches.kw</span>
  </div>
  <nav class="acct-nav__list">
    <a href="/account" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg><span>Overview</span></a>
    <a href="/account/orders" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7h18l-2 13H5z"/><path d="M8 7V5a4 4 0 018 0v2"/></svg><span>Orders</span></a>
    <a href="/account/addresses" class="acct-nav__link is-active" aria-current="page"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2a7 7 0 017 7c0 5-7 13-7 13S5 14 5 9a7 7 0 017-7z"/><circle cx="12" cy="9" r="2.5"/></svg><span>Addresses</span></a>
    <a href="/account/wishlist" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><span>Wishlist</span></a>
    <a href="/account/profile" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg><span>Profile</span></a>
    <a href="/account/returns" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 11-9-9"/><path d="M21 4v5h-5"/></svg><span>Returns</span></a>
  </nav>
  <a href="/account/login" class="acct-nav__signout"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg><span>Sign out</span></a>
</aside>

    <main class="acct__main">

      <div class="acct-addresses">
        <!-- Default address -->
        <article class="addr-card addr-card--default">
          <header class="addr-card__head">
            <span class="addr-card__badge">Default · Shipping &amp; Billing</span>
            <div class="addr-card__menu">
              <button type="button" class="link-btn">Edit</button>
              <button type="button" class="link-btn">Set default</button>
            </div>
          </header>
          <address class="addr-card__body">
            <strong>Anas Al-Mutairi</strong><br>
            Block 4, Street 12, Building 8 · Floor 3, Apt 11<br>
            Salmiya, Hawalli<br>
            Kuwait<br>
            +965 5xx xxxxx
          </address>
        </article>

        <!-- Office -->
        <article class="addr-card">
          <header class="addr-card__head">
            <span class="addr-card__badge addr-card__badge--neutral">Office</span>
            <div class="addr-card__menu">
              <button type="button" class="link-btn">Edit</button>
              <button type="button" class="link-btn">Set default</button>
              <button type="button" class="link-btn link-btn--danger">Delete</button>
            </div>
          </header>
          <address class="addr-card__body">
            <strong>Anas Al-Mutairi · Codex Kuwait</strong><br>
            Block 3, Sharq Tower, Floor 12<br>
            Sharq, Al Asimah<br>
            Kuwait<br>
            +965 2xxx xxxx
          </address>
        </article>

        <!-- Add new -->
        <article class="addr-card addr-card--add" id="addAddressCard">
          <button type="button" class="addr-card__add-btn" id="openAddressForm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M12 8v8M8 12h8"/></svg>
            <span>Add a new address</span>
          </button>
        </article>
      </div>

      <!-- New address form (hidden by default, revealed on click) -->
      <section class="acct-section acct-section--card" id="addressForm" hidden>
        <header class="acct-section__head">
          <h2>New address</h2>
          <button type="button" class="link-btn" id="closeAddressForm">Cancel</button>
        </header>
        <form class="auth-form" onsubmit="event.preventDefault();">
          <div class="co-field">
            <input type="text" id="addrLabel" placeholder=" " />
            <label for="addrLabel">Label (e.g. Home, Office)</label>
          </div>
          <div class="co-field-row">
            <div class="co-field"><input type="text" id="addrFirst" placeholder=" " required /><label for="addrFirst">First name</label></div>
            <div class="co-field"><input type="text" id="addrLast" placeholder=" " required /><label for="addrLast">Last name</label></div>
          </div>
          <div class="co-field">
            <select id="addrCountry"><option>Kuwait</option><option>Saudi Arabia</option><option>UAE</option><option>Bahrain</option><option>Qatar</option><option>Oman</option></select>
            <label for="addrCountry">Country</label>
          </div>
          <div class="co-field-row">
            <div class="co-field"><select id="addrGov"><option>Al Asimah</option><option>Hawalli</option><option>Al Farwaniyah</option><option>Mubarak Al-Kabeer</option><option>Al Ahmadi</option><option>Al Jahra</option></select><label for="addrGov">Governorate</label></div>
            <div class="co-field"><input type="text" id="addrArea" placeholder=" " required /><label for="addrArea">Area</label></div>
          </div>
          <div class="co-field-row co-field-row--3">
            <div class="co-field"><input type="text" id="addrBlock" placeholder=" " required /><label for="addrBlock">Block</label></div>
            <div class="co-field"><input type="text" id="addrStreet" placeholder=" " required /><label for="addrStreet">Street</label></div>
            <div class="co-field"><input type="text" id="addrBuilding" placeholder=" " required /><label for="addrBuilding">Building</label></div>
          </div>
          <label class="check co-check"><input type="checkbox" id="addrDefault" /><span>Set as default address</span></label>
          <button type="submit" class="btn btn--primary">Save address</button>
        </form>
      </section>

    </main>
  </div>
</section>

