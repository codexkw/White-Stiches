@{
    ViewData["Title"] = "Account · White Stitches";
    ViewData["MetaDescription"] = "Your account overview — orders, addresses, wishlist.";
}

<!-- ============================ ACCOUNT PAGE HEAD ============================ -->
<section class="acct-head">
  <div class="acct-head__inner">
    <span class="eyebrow">My Account</span>
    <h1 class="acct-head__title">Hello, <em>Anas</em>.</h1>
    <p class="acct-head__sub">Member since March 2025 · Kuwait City</p>
  </div>
</section>

<!-- ============================ ACCOUNT GRID ============================ -->
<section class="acct">
  <div class="acct__inner">

    <aside class="acct-nav" aria-label="Account navigation">
  <div class="acct-nav__head">
    <span class="eyebrow">Account</span>
    <strong class="acct-nav__name">Anas Al-Mutairi</strong>
    <span class="acct-nav__email">anas@@whitestiches.kw</span>
  </div>
  <nav class="acct-nav__list">
    <a href="/account" class="acct-nav__link is-active" aria-current="page"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg><span>Overview</span></a>
    <a href="/account/orders" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7h18l-2 13H5z"/><path d="M8 7V5a4 4 0 018 0v2"/></svg><span>Orders</span></a>
    <a href="/account/addresses" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2a7 7 0 017 7c0 5-7 13-7 13S5 14 5 9a7 7 0 017-7z"/><circle cx="12" cy="9" r="2.5"/></svg><span>Addresses</span></a>
    <a href="/account/wishlist" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><span>Wishlist</span></a>
    <a href="/account/profile" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg><span>Profile</span></a>
    <a href="/account/returns" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 11-9-9"/><path d="M21 4v5h-5"/></svg><span>Returns</span></a>
  </nav>
  <a href="/account/login" class="acct-nav__signout"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg><span>Sign out</span></a>
</aside>

    <main class="acct__main">

      <!-- Snapshot cards row -->
      <div class="acct-stats">
        <div class="acct-stat">
          <span class="acct-stat__label">Open orders</span>
          <strong class="acct-stat__value">1</strong>
          <span class="acct-stat__hint">Arriving Tuesday</span>
        </div>
        <div class="acct-stat">
          <span class="acct-stat__label">Wishlist</span>
          <strong class="acct-stat__value">7</strong>
          <span class="acct-stat__hint">2 on sale</span>
        </div>
        <div class="acct-stat">
          <span class="acct-stat__label">Member tier</span>
          <strong class="acct-stat__value acct-stat__value--accent">Atelier</strong>
          <span class="acct-stat__hint">12 orders all-time</span>
        </div>
        <div class="acct-stat">
          <span class="acct-stat__label">Store credit</span>
          <strong class="acct-stat__value">15.000 <em>KWD</em></strong>
          <span class="acct-stat__hint">Expires 31 Dec 2026</span>
        </div>
      </div>

      <!-- Recent orders -->
      <section class="acct-section">
        <header class="acct-section__head">
          <h2>Recent orders</h2>
          <a href="/account/orders" class="link-arrow">View all <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </header>
        <ul class="acct-orders">
          <li>
            <div class="acct-order__main">
              <span class="acct-order__num">#WS-2026-08412</span>
              <span class="acct-order__date">18 May 2026</span>
            </div>
            <div class="acct-order__thumbs">
              <img src="~/assets/products/product-4.jpg" alt="" />
              <img src="~/assets/products/product-1.jpg" alt="" />
              <img src="~/assets/products/product-2.jpg" alt="" />
              <span class="acct-order__more">+0</span>
            </div>
            <span class="status-badge status-badge--in-transit">In transit</span>
            <span class="acct-order__total">186.500 KWD</span>
            <a href="/account/orders/detail" class="acct-order__action">View</a>
          </li>
          <li>
            <div class="acct-order__main">
              <span class="acct-order__num">#WS-2026-08197</span>
              <span class="acct-order__date">2 May 2026</span>
            </div>
            <div class="acct-order__thumbs">
              <img src="~/assets/products/product-3.jpg" alt="" />
              <img src="~/assets/products/product-4.jpg" alt="" />
            </div>
            <span class="status-badge status-badge--delivered">Delivered</span>
            <span class="acct-order__total">50.500 KWD</span>
            <a href="/account/orders/detail" class="acct-order__action">View</a>
          </li>
          <li>
            <div class="acct-order__main">
              <span class="acct-order__num">#WS-2026-07842</span>
              <span class="acct-order__date">14 April 2026</span>
            </div>
            <div class="acct-order__thumbs">
              <img src="~/assets/products/product-1.jpg" alt="" />
            </div>
            <span class="status-badge status-badge--delivered">Delivered</span>
            <span class="acct-order__total">38.500 KWD</span>
            <a href="/account/orders/detail" class="acct-order__action">View</a>
          </li>
        </ul>
      </section>

      <!-- Address + wishlist preview row -->
      <div class="acct-preview-row">
        <section class="acct-section acct-section--card">
          <header class="acct-section__head">
            <h2>Default address</h2>
            <a href="/account/addresses" class="link-arrow">Manage <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          </header>
          <address class="oc-address">
            <strong>Anas Al-Mutairi</strong><br>
            Block 4, Street 12, Building 8 · Floor 3, Apt 11<br>
            Salmiya, Hawalli<br>
            Kuwait
          </address>
        </section>

        <section class="acct-section acct-section--card">
          <header class="acct-section__head">
            <h2>Wishlist preview</h2>
            <a href="/account/wishlist" class="link-arrow">View all 7 <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          </header>
          <div class="acct-wishpreview">
            <a href="/product"><img src="~/assets/products/product-2.jpg" alt="" /></a>
            <a href="/product"><img src="~/assets/products/product-3.jpg" alt="" /></a>
            <a href="/product"><img src="~/assets/products/product-4.jpg" alt="" /></a>
            <a href="/product"><img src="~/assets/products/product-1.jpg" alt="" /></a>
          </div>
        </section>
      </div>

    </main>
  </div>
</section>

