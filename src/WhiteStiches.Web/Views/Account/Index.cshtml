@using WhiteStiches.Web.Models.Account
@model DashboardViewModel
@{
    ViewData["Title"] = "Account · White Stitches";
    ViewData["MetaDescription"] = "Your account overview — orders, addresses, wishlist.";
}

<!-- ============================ ACCOUNT PAGE HEAD ============================ -->
<section class="acct-head">
  <div class="acct-head__inner">
    <span class="eyebrow">@L["My Account"]</span>
    <h1 class="acct-head__title">@L["Hello,"] <em>@Model.FirstName</em>.</h1>
    <p class="acct-head__sub">@L["Member since"] @Model.MemberSinceText@(Model.DefaultAddress is not null ? $" · {Model.DefaultAddress.Area}" : "")</p>
  </div>
</section>

<!-- ============================ ACCOUNT GRID ============================ -->
<section class="acct">
  <div class="acct__inner">

    <aside class="acct-nav" aria-label="@L["Account navigation"]">
  <div class="acct-nav__head">
    <span class="eyebrow">@L["Account"]</span>
    <strong class="acct-nav__name">@Model.FullName</strong>
    <span class="acct-nav__email">@Model.Email</span>
  </div>
  <nav class="acct-nav__list">
    <a href="/account" class="acct-nav__link is-active" aria-current="page"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg><span>@L["Overview"]</span></a>
    <a href="/account/orders" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7h18l-2 13H5z"/><path d="M8 7V5a4 4 0 018 0v2"/></svg><span>@L["Orders"]</span></a>
    <a href="/account/addresses" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2a7 7 0 017 7c0 5-7 13-7 13S5 14 5 9a7 7 0 017-7z"/><circle cx="12" cy="9" r="2.5"/></svg><span>@L["Addresses"]</span></a>
    <a href="/account/wishlist" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><span>@L["Wishlist"]</span></a>
    <a href="/account/profile" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg><span>@L["Profile"]</span></a>
    <a href="/account/returns" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 11-9-9"/><path d="M21 4v5h-5"/></svg><span>@L["Returns"]</span></a>
  </nav>
  <form method="post" action="/account/logout" style="margin: 0;">
    @Html.AntiForgeryToken()
    <button type="submit" class="acct-nav__signout" style="background: none; border: 0; border-top: 1px solid var(--c-line); width: 100%; cursor: pointer; font-family: inherit; text-align: left;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg><span>@L["Sign out"]</span></button>
  </form>
</aside>

    <main class="acct__main">

      @if (TempData["AccountMessage"] is string flashOk)
      {
        <div role="status" style="padding: 12px 16px; border: 1px solid var(--c-line); border-left: 2px solid var(--c-accent); background: var(--c-ink-2); color: var(--c-paper); font-size: var(--t-sm); letter-spacing: var(--tr-wide);">@flashOk</div>
      }
      @if (TempData["AccountError"] is string flashErr)
      {
        <div role="alert" style="padding: 12px 16px; border: 1px solid var(--c-line); border-left: 2px solid #c87a3a; background: var(--c-ink-2); color: var(--c-paper); font-size: var(--t-sm); letter-spacing: var(--tr-wide);">@flashErr</div>
      }

      <!-- Snapshot cards row -->
      <div class="acct-stats">
        <div class="acct-stat">
          <span class="acct-stat__label">@L["Open orders"]</span>
          <strong class="acct-stat__value">@Model.OpenOrderCount</strong>
          <span class="acct-stat__hint">@(Model.OpenOrderCount > 0 ? L["In progress now"].Value : L["All caught up"].Value)</span>
        </div>
        <div class="acct-stat">
          <span class="acct-stat__label">@L["Wishlist"]</span>
          <strong class="acct-stat__value">@Model.WishlistCount</strong>
          <span class="acct-stat__hint">@(Model.WishlistOnSaleCount > 0 ? $"{Model.WishlistOnSaleCount} {L["on sale"].Value}" : L["Saved pieces"].Value)</span>
        </div>
        <div class="acct-stat">
          <span class="acct-stat__label">@L["Member tier"]</span>
          <strong class="acct-stat__value acct-stat__value--accent">@L["Atelier"]</strong>
          <span class="acct-stat__hint">@Model.TotalOrderCount @(Model.TotalOrderCount == 1 ? L["order"].Value : L["orders"].Value) @L["all-time"]</span>
        </div>
        <div class="acct-stat">
          <span class="acct-stat__label">@L["Store credit"]</span>
          <strong class="acct-stat__value">0.000 <em>KWD</em></strong>
          <span class="acct-stat__hint">@L["Available balance"]</span>
        </div>
      </div>

      <!-- Recent orders -->
      <section class="acct-section">
        <header class="acct-section__head">
          <h2>@L["Recent orders"]</h2>
          <a href="/account/orders" class="link-arrow">@L["View all"] <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </header>
        @if (Model.RecentOrders.Count == 0)
        {
          <p class="acct-section__meta">@L["No orders yet — your first order will appear here."] <a href="/collection" class="link-arrow link-arrow--inline">@L["Shop the edit"]</a></p>
        }
        else
        {
          <ul class="acct-orders">
            @foreach (var order in Model.RecentOrders)
            {
              var (badgeCss, badgeLabel) = AccountFormat.OrderBadge(order.Status);
              var thumbs = order.Items.Where(i => !string.IsNullOrEmpty(i.ImageUrl)).Take(3).ToList();
              <li>
                <div class="acct-order__main">
                  <span class="acct-order__num">#@order.OrderNumber</span>
                  <span class="acct-order__date">@AccountFormat.Date(order.PlacedAtUtc ?? order.CreatedAtUtc)</span>
                </div>
                <div class="acct-order__thumbs">
                  @foreach (var item in thumbs)
                  {
                    <img src="@item.ImageUrl" alt="" />
                  }
                  @if (order.Items.Count > 3)
                  {
                    <span class="acct-order__more">+@(order.Items.Count - 3)</span>
                  }
                </div>
                <span class="status-badge @badgeCss">@badgeLabel</span>
                <span class="acct-order__total">@AccountFormat.Money(order.Total)</span>
                <a href="/account/orders/@order.OrderNumber" class="acct-order__action">@L["View"]</a>
              </li>
            }
          </ul>
        }
      </section>

      <!-- Address + wishlist preview row -->
      <div class="acct-preview-row">
        <section class="acct-section acct-section--card">
          <header class="acct-section__head">
            <h2>@L["Default address"]</h2>
            <a href="/account/addresses" class="link-arrow">@L["Manage"] <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          </header>
          @if (Model.DefaultAddress is { } addr)
          {
            <address class="oc-address">
              <strong>@addr.FirstName @addr.LastName</strong><br>
              Block @addr.Block, Street @addr.Street, Building @addr.Building@(string.IsNullOrEmpty(addr.Floor) ? "" : $" · Floor {addr.Floor}")@(string.IsNullOrEmpty(addr.Apartment) ? "" : $", Apt {addr.Apartment}")<br>
              @addr.Area, @addr.Governorate<br>
              @(addr.Country == "KW" ? "Kuwait" : addr.Country)
            </address>
          }
          else
          {
            <p class="acct-section__meta">@L["No saved address yet — add one for faster checkout."]</p>
          }
        </section>

        <section class="acct-section acct-section--card">
          <header class="acct-section__head">
            <h2>@L["Wishlist preview"]</h2>
            <a href="/account/wishlist" class="link-arrow">@L["View all"] @Model.WishlistCount <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          </header>
          @if (Model.WishlistPreview.Count == 0)
          {
            <p class="acct-section__meta">@L["Nothing saved yet — tap the heart on any piece to keep it here."]</p>
          }
          else
          {
            <div class="acct-wishpreview">
              @foreach (var product in Model.WishlistPreview)
              {
                var image = product.Images.OrderBy(i => i.SortOrder).FirstOrDefault();
                <a href="/products/@product.Slug"><img src="@image?.Url" alt="@(image?.Alt() ?? product.Title())" /></a>
              }
            </div>
          }
        </section>
      </div>

    </main>
  </div>
</section>

<!-- ============================ FOOTER ============================ -->
