@using WhiteStiches.Web.Models.Account
@model OrdersViewModel
@{
    ViewData["Title"] = "Your orders · White Stitches";
    ViewData["MetaDescription"] = "Your order history at White Stitches.";

    var pageItems = Model.Orders.Items;
    var inTransitCount = pageItems.Count(o => o.Status is OrderStatus.Fulfilled or OrderStatus.Shipped);
    var deliveredCount = pageItems.Count(o => o.Status == OrderStatus.Delivered);
    var cancelledCount = pageItems.Count(o => o.Status == OrderStatus.Cancelled);
}

<section class="acct-head">
  <div class="acct-head__inner">
    <span class="eyebrow">Account · Orders</span>
    <h1 class="acct-head__title">Your orders.</h1>
    <p class="acct-head__sub">@Model.Orders.TotalCount @(Model.Orders.TotalCount == 1 ? "order" : "orders") since @Model.MemberSinceText</p>
  </div>
</section>

<section class="acct">
  <div class="acct__inner">
    <aside class="acct-nav" aria-label="Account navigation">
  <div class="acct-nav__head">
    <span class="eyebrow">Account</span>
    <strong class="acct-nav__name">@Model.FullName</strong>
    <span class="acct-nav__email">@Model.Email</span>
  </div>
  <nav class="acct-nav__list">
    <a href="/account" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg><span>Overview</span></a>
    <a href="/account/orders" class="acct-nav__link is-active" aria-current="page"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7h18l-2 13H5z"/><path d="M8 7V5a4 4 0 018 0v2"/></svg><span>Orders</span></a>
    <a href="/account/addresses" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2a7 7 0 017 7c0 5-7 13-7 13S5 14 5 9a7 7 0 017-7z"/><circle cx="12" cy="9" r="2.5"/></svg><span>Addresses</span></a>
    <a href="/account/wishlist" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><span>Wishlist</span></a>
    <a href="/account/profile" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg><span>Profile</span></a>
    <a href="/account/returns" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 11-9-9"/><path d="M21 4v5h-5"/></svg><span>Returns</span></a>
  </nav>
  <form method="post" action="/account/logout" style="margin: 0;">
    @Html.AntiForgeryToken()
    <button type="submit" class="acct-nav__signout" style="background: none; border: 0; border-top: 1px solid var(--c-line); width: 100%; cursor: pointer; font-family: inherit; text-align: left;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg><span>Sign out</span></button>
  </form>
</aside>

    <main class="acct__main">

      @if (TempData["AccountMessage"] is string flashOk)
      {
        <div role="status" style="padding: 12px 16px; border: 1px solid var(--c-line); border-left: 2px solid var(--c-accent); background: var(--c-ink-2); color: var(--c-paper); font-size: var(--t-sm); letter-spacing: var(--tr-wide);">@flashOk</div>
      }
      @if (TempData["AccountError"] is string flashErr)
      {
        <div role="alert" style="padding: 12px 16px; border: 1px solid var(--c-line); border-left: 2px solid #c87a3a; background: var(--c-ink-2); color: var(--c-paper); font-size: var(--t-sm); letter-spacing: var(--tr-wide);">@flashErr</div>
      }

      @if (Model.Orders.TotalCount == 0)
      {
        <section class="acct-section acct-section--card">
          <header class="acct-section__head">
            <h2>No orders yet</h2>
          </header>
          <p class="acct-section__meta">When you place your first order it will appear here. <a href="/collection" class="link-arrow link-arrow--inline">Shop new arrivals</a></p>
        </section>
      }
      else
      {
        <!-- Filter chips + search (visual filtering only) -->
        <div class="acct-orders-toolbar">
          <div class="acct-orders-toolbar__filters" role="tablist">
            <button class="filter-chip is-active" type="button" role="tab" aria-selected="true">All <em>@Model.Orders.TotalCount</em></button>
            <button class="filter-chip" type="button" role="tab">In transit <em>@inTransitCount</em></button>
            <button class="filter-chip" type="button" role="tab">Delivered <em>@deliveredCount</em></button>
            <button class="filter-chip" type="button" role="tab">Cancelled <em>@cancelledCount</em></button>
          </div>
          <div class="acct-orders-toolbar__search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            <input type="search" placeholder="Search by order # or product…" />
          </div>
        </div>

        <!-- Orders list -->
        <ul class="acct-orders acct-orders--full">
          @foreach (var order in Model.Orders.Items)
          {
            var (badgeCss, badgeLabel) = AccountFormat.OrderBadge(order.Status);
            var itemCount = order.Items.Sum(i => i.Quantity);
            var thumbs = order.Items.Where(i => !string.IsNullOrEmpty(i.ImageUrl)).Take(3).ToList();
            <li>
              <div class="acct-order__main">
                <span class="acct-order__num">#@order.OrderNumber</span>
                <span class="acct-order__date">@AccountFormat.Date(order.PlacedAtUtc ?? order.CreatedAtUtc)</span>
                <span class="acct-order__items-count">@itemCount @(itemCount == 1 ? "item" : "items")</span>
              </div>
              <div class="acct-order__thumbs">
                @foreach (var item in thumbs)
                {
                  <img src="@item.ImageUrl" alt="" />
                }
                @if (order.Items.Count > 3)
                {
                  <span class="acct-order__more">+@(order.Items.Count - 3)</span>
                }
              </div>
              <span class="status-badge @badgeCss">@badgeLabel</span>
              <span class="acct-order__total">@AccountFormat.Money(order.Total)</span>
              <div class="acct-order__actions">
                <a href="/account/orders/@order.OrderNumber" class="btn btn--ghost btn--sm">View</a>
                @if (order.Status == OrderStatus.Delivered)
                {
                  <a href="/account/returns/new?order=@order.OrderNumber" class="btn btn--ghost btn--sm">Return</a>
                }
              </div>
            </li>
          }
        </ul>

        @if (Model.Orders.TotalPages > 1)
        {
          <!-- Pagination -->
          <nav class="pagination" aria-label="Pagination">
            @if (Model.Orders.HasPrevious)
            {
              <a class="pagination__btn pagination__btn--prev" asp-action="Orders" asp-route-page="@(Model.Orders.Page - 1)" aria-label="Previous"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg></a>
            }
            else
            {
              <button class="pagination__btn pagination__btn--prev" disabled aria-label="Previous"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg></button>
            }
            <ol class="pagination__nums">
              @for (var p = 1; p <= Model.Orders.TotalPages; p++)
              {
                <li>
                  @if (p == Model.Orders.Page)
                  {
                    <a asp-action="Orders" asp-route-page="@p" class="is-active" aria-current="page">@p</a>
                  }
                  else
                  {
                    <a asp-action="Orders" asp-route-page="@p">@p</a>
                  }
                </li>
              }
            </ol>
            @if (Model.Orders.HasNext)
            {
              <a class="pagination__btn pagination__btn--next" asp-action="Orders" asp-route-page="@(Model.Orders.Page + 1)" aria-label="Next"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 6l6 6-6 6"/></svg></a>
            }
            else
            {
              <button class="pagination__btn pagination__btn--next" disabled aria-label="Next"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 6l6 6-6 6"/></svg></button>
            }
          </nav>
        }
      }

    </main>
  </div>
</section>

