@{
    ViewData["Title"] = "Your orders · White Stitches";
    ViewData["MetaDescription"] = "Your order history at White Stitches.";
}

<section class="acct-head">
  <div class="acct-head__inner">
    <span class="eyebrow">Account · Orders</span>
    <h1 class="acct-head__title">Your orders.</h1>
    <p class="acct-head__sub">12 orders since March 2025</p>
  </div>
</section>

<section class="acct">
  <div class="acct__inner">
    <aside class="acct-nav" aria-label="Account navigation">
  <div class="acct-nav__head">
    <span class="eyebrow">Account</span>
    <strong class="acct-nav__name">Anas Al-Mutairi</strong>
    <span class="acct-nav__email">anas@@whitestiches.kw</span>
  </div>
  <nav class="acct-nav__list">
    <a href="/account" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg><span>Overview</span></a>
    <a href="/account/orders" class="acct-nav__link is-active" aria-current="page"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7h18l-2 13H5z"/><path d="M8 7V5a4 4 0 018 0v2"/></svg><span>Orders</span></a>
    <a href="/account/addresses" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2a7 7 0 017 7c0 5-7 13-7 13S5 14 5 9a7 7 0 017-7z"/><circle cx="12" cy="9" r="2.5"/></svg><span>Addresses</span></a>
    <a href="/account/wishlist" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><span>Wishlist</span></a>
    <a href="/account/profile" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg><span>Profile</span></a>
    <a href="/account/returns" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 11-9-9"/><path d="M21 4v5h-5"/></svg><span>Returns</span></a>
  </nav>
  <a href="/account/login" class="acct-nav__signout"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg><span>Sign out</span></a>
</aside>

    <main class="acct__main">

      <!-- Filter chips + search -->
      <div class="acct-orders-toolbar">
        <div class="acct-orders-toolbar__filters" role="tablist">
          <button class="filter-chip is-active" type="button" role="tab" aria-selected="true">All <em>12</em></button>
          <button class="filter-chip" type="button" role="tab">In transit <em>1</em></button>
          <button class="filter-chip" type="button" role="tab">Delivered <em>10</em></button>
          <button class="filter-chip" type="button" role="tab">Cancelled <em>1</em></button>
        </div>
        <div class="acct-orders-toolbar__search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
          <input type="search" placeholder="Search by order # or product…" />
        </div>
      </div>

      <!-- Orders list -->
      <ul class="acct-orders acct-orders--full">
        <li>
          <div class="acct-order__main">
            <span class="acct-order__num">#WS-2026-08412</span>
            <span class="acct-order__date">18 May 2026</span>
            <span class="acct-order__items-count">3 items</span>
          </div>
          <div class="acct-order__thumbs">
            <img src="~/assets/products/product-4.jpg" alt="" />
            <img src="~/assets/products/product-1.jpg" alt="" />
            <img src="~/assets/products/product-2.jpg" alt="" />
          </div>
          <span class="status-badge status-badge--in-transit">In transit</span>
          <span class="acct-order__total">186.500 KWD</span>
          <div class="acct-order__actions">
            <a href="/account/orders/detail" class="btn btn--ghost btn--sm">View</a>
            <a href="#" class="btn btn--ghost btn--sm">Track</a>
          </div>
        </li>
        <li>
          <div class="acct-order__main">
            <span class="acct-order__num">#WS-2026-08197</span>
            <span class="acct-order__date">2 May 2026</span>
            <span class="acct-order__items-count">2 items</span>
          </div>
          <div class="acct-order__thumbs">
            <img src="~/assets/products/product-3.jpg" alt="" />
            <img src="~/assets/products/product-4.jpg" alt="" />
          </div>
          <span class="status-badge status-badge--delivered">Delivered</span>
          <span class="acct-order__total">50.500 KWD</span>
          <div class="acct-order__actions">
            <a href="/account/orders/detail" class="btn btn--ghost btn--sm">View</a>
            <a href="#" class="btn btn--ghost btn--sm">Re-order</a>
          </div>
        </li>
        <li>
          <div class="acct-order__main">
            <span class="acct-order__num">#WS-2026-07842</span>
            <span class="acct-order__date">14 April 2026</span>
            <span class="acct-order__items-count">1 item</span>
          </div>
          <div class="acct-order__thumbs">
            <img src="~/assets/products/product-1.jpg" alt="" />
          </div>
          <span class="status-badge status-badge--delivered">Delivered</span>
          <span class="acct-order__total">38.500 KWD</span>
          <div class="acct-order__actions">
            <a href="/account/orders/detail" class="btn btn--ghost btn--sm">View</a>
            <a href="#" class="btn btn--ghost btn--sm">Re-order</a>
          </div>
        </li>
        <li>
          <div class="acct-order__main">
            <span class="acct-order__num">#WS-2026-07621</span>
            <span class="acct-order__date">28 March 2026</span>
            <span class="acct-order__items-count">4 items</span>
          </div>
          <div class="acct-order__thumbs">
            <img src="~/assets/products/product-2.jpg" alt="" />
            <img src="~/assets/products/product-3.jpg" alt="" />
            <img src="~/assets/products/product-4.jpg" alt="" />
            <span class="acct-order__more">+1</span>
          </div>
          <span class="status-badge status-badge--cancelled">Cancelled</span>
          <span class="acct-order__total">142.000 KWD</span>
          <div class="acct-order__actions">
            <a href="/account/orders/detail" class="btn btn--ghost btn--sm">View</a>
          </div>
        </li>
        <li>
          <div class="acct-order__main">
            <span class="acct-order__num">#WS-2026-07105</span>
            <span class="acct-order__date">5 February 2026</span>
            <span class="acct-order__items-count">2 items</span>
          </div>
          <div class="acct-order__thumbs">
            <img src="~/assets/products/product-1.jpg" alt="" />
            <img src="~/assets/products/product-2.jpg" alt="" />
          </div>
          <span class="status-badge status-badge--delivered">Delivered</span>
          <span class="acct-order__total">64.500 KWD</span>
          <div class="acct-order__actions">
            <a href="/account/orders/detail" class="btn btn--ghost btn--sm">View</a>
            <a href="#" class="btn btn--ghost btn--sm">Re-order</a>
          </div>
        </li>
      </ul>

      <!-- Pagination -->
      <nav class="pagination" aria-label="Pagination">
        <button class="pagination__btn pagination__btn--prev" disabled aria-label="Previous"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg></button>
        <ol class="pagination__nums">
          <li><a href="#" class="is-active" aria-current="page">1</a></li>
          <li><a href="#">2</a></li>
          <li><a href="#">3</a></li>
        </ol>
        <button class="pagination__btn pagination__btn--next" aria-label="Next"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 6l6 6-6 6"/></svg></button>
      </nav>

    </main>
  </div>
</section>

