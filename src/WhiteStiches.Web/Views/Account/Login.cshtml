@{
    ViewData["Title"] = "Sign in · White Stitches";
    ViewData["MetaDescription"] = "Sign in to your White Stitches account or create one in 30 seconds.";
}

<!-- ============================ AUTH PAGE ============================ -->
<section class="auth">
  <div class="auth__inner">

    <!-- ── Left column: editorial side panel ─────────────────── -->
    <aside class="auth__aside" aria-hidden="true">
      <img src="~/assets/products/product-4.jpg" alt="" class="auth__aside-img" />
      <div class="auth__aside-overlay"></div>
      <div class="auth__aside-copy">
        <span class="eyebrow eyebrow--paper">The Atelier</span>
        <h2 class="auth__aside-title">Made in Kuwait. Designed for the GCC.</h2>
        <p class="auth__aside-sub">
          Save your pieces, track orders, and unlock first looks at our SS26 lookbook — exclusively for members.
        </p>
      </div>
    </aside>

    <!-- ── Right column: forms ───────────────────────────────── -->
    <div class="auth__main">

      <!-- Tab switcher -->
      <div class="auth-tabs" role="tablist">
        <button type="button" class="auth-tabs__tab is-active" id="tabSignin" role="tab" aria-selected="true" aria-controls="paneSignin">
          Sign in
        </button>
        <button type="button" class="auth-tabs__tab" id="tabRegister" role="tab" aria-selected="false" aria-controls="paneRegister">
          Create account
        </button>
      </div>

      <!-- ── SIGN IN ────────────────────────────────────────── -->
      <div class="auth-pane is-active" id="paneSignin" role="tabpanel" aria-labelledby="tabSignin">
        <header class="auth-pane__head">
          <h1 class="auth-pane__title">Welcome back.</h1>
          <p class="auth-pane__sub">Sign in to access your orders, wishlist and saved addresses.</p>
        </header>

        <form class="auth-form" id="signinForm" novalidate onsubmit="event.preventDefault(); window.handleSignin && window.handleSignin();">
          <div class="co-field">
            <input type="email" id="signinEmail" required autocomplete="email" placeholder=" " />
            <label for="signinEmail">Email</label>
          </div>

          <div class="co-field co-field--with-action">
            <input type="password" id="signinPassword" required autocomplete="current-password" placeholder=" " minlength="8" />
            <label for="signinPassword">Password</label>
            <button type="button" class="co-field__action" id="togglePwd" aria-label="Show password">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>

          <div class="auth-form__row">
            <label class="check"><input type="checkbox" id="rememberMe" /><span>Keep me signed in</span></label>
            <a href="#" class="link-arrow link-arrow--inline" id="forgotLink">Forgot password?</a>
          </div>

          <button type="submit" class="btn btn--primary btn--block">Sign in</button>

          <!-- Social/OTP options -->
          <div class="auth-divider"><em>or continue with</em></div>

          <div class="auth-social">
            <button type="button" class="auth-social__btn auth-social__btn--google">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.35 11.1H12v3.2h5.35c-.23 1.2-.92 2.2-1.96 2.88v2.4h3.16c1.85-1.7 2.92-4.2 2.92-7.2 0-.7-.06-1.4-.18-2.08zM12 22c2.66 0 4.9-.88 6.53-2.4l-3.16-2.4c-.88.6-2 .96-3.37.96-2.59 0-4.78-1.75-5.56-4.1H3.18v2.48A10 10 0 0 0 12 22zm-5.56-7.94A6 6 0 0 1 6.13 12c0-.71.12-1.4.31-2.06V7.46H3.18a10 10 0 0 0 0 9.08l3.26-2.48zM12 5.6c1.45 0 2.75.5 3.78 1.48l2.8-2.8C16.9 2.74 14.66 1.8 12 1.8a10 10 0 0 0-8.82 5.36l3.26 2.48C7.22 7.35 9.41 5.6 12 5.6z"/></svg>
              <span>Google</span>
            </button>
            <button type="button" class="auth-social__btn auth-social__btn--apple">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 12.04c-.01-2.04 1.66-3.02 1.74-3.07-.95-1.39-2.42-1.58-2.94-1.6-1.24-.13-2.43.74-3.06.74-.64 0-1.61-.72-2.66-.7-1.36.02-2.63.79-3.33 2.01-1.42 2.47-.36 6.12 1.02 8.12.68.98 1.49 2.08 2.55 2.04 1.03-.04 1.42-.66 2.66-.66 1.24 0 1.59.66 2.67.64 1.1-.02 1.8-1 2.47-1.99.78-1.14 1.1-2.24 1.12-2.3-.02-.01-2.15-.83-2.17-3.23zM15.07 5.91c.56-.69.95-1.64.84-2.59-.81.04-1.81.55-2.4 1.23-.52.6-.98 1.58-.86 2.51.91.07 1.85-.46 2.42-1.15z"/></svg>
              <span>Apple</span>
            </button>
            <button type="button" class="auth-social__btn auth-social__btn--whatsapp">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.92.55 3.78 1.6 5.4L2 22l4.83-1.26a9.93 9.93 0 0 0 5.21 1.43c5.46 0 9.9-4.44 9.9-9.9C21.94 6.45 17.5 2 12.04 2zm5.7 14.06c-.24.66-1.4 1.27-1.95 1.34-.5.07-1.13.1-1.83-.11-.42-.13-.96-.31-1.66-.61-2.92-1.26-4.82-4.2-4.97-4.39-.15-.2-1.18-1.56-1.18-2.98s.75-2.12 1.01-2.41a1 1 0 0 1 .72-.34c.18 0 .36 0 .51.01.16.01.39-.06.6.46.24.59.79 2 .86 2.14.07.14.12.32.02.51-.1.2-.15.32-.29.49-.15.17-.31.39-.45.52-.15.13-.3.28-.13.55s.76 1.26 1.64 2.04c1.13 1 2.08 1.31 2.35 1.46.27.15.42.13.59-.07.16-.2.66-.77.84-1.04.18-.27.36-.22.6-.13.25.08 1.55.73 1.81.87.27.13.45.2.51.31.07.11.07.61-.17 1.27z"/></svg>
              <span>WhatsApp OTP</span>
            </button>
          </div>
        </form>
      </div>

      <!-- ── REGISTER ───────────────────────────────────────── -->
      <div class="auth-pane" id="paneRegister" role="tabpanel" aria-labelledby="tabRegister" hidden>
        <header class="auth-pane__head">
          <h1 class="auth-pane__title">Join the atelier.</h1>
          <p class="auth-pane__sub">Create your account in 30 seconds — never miss an edit.</p>
        </header>

        <form class="auth-form" id="registerForm" novalidate onsubmit="event.preventDefault(); window.handleRegister && window.handleRegister();">
          <div class="co-field-row">
            <div class="co-field">
              <input type="text" id="regFirstName" required autocomplete="given-name" placeholder=" " />
              <label for="regFirstName">First name</label>
            </div>
            <div class="co-field">
              <input type="text" id="regLastName" required autocomplete="family-name" placeholder=" " />
              <label for="regLastName">Last name</label>
            </div>
          </div>

          <div class="co-field">
            <input type="email" id="regEmail" required autocomplete="email" placeholder=" " />
            <label for="regEmail">Email</label>
          </div>

          <div class="co-field co-field--phone">
            <span class="field__prefix">
              <span class="flag flag--kw" aria-hidden="true"></span>
              <select id="regPhoneCountry" aria-label="Country code">
                <option value="+965" selected>+965</option>
                <option value="+966">+966</option>
                <option value="+971">+971</option>
                <option value="+973">+973</option>
                <option value="+974">+974</option>
                <option value="+968">+968</option>
              </select>
            </span>
            <input type="tel" id="regPhone" required autocomplete="tel" placeholder=" " inputmode="tel" />
            <label for="regPhone">Mobile</label>
          </div>

          <div class="co-field co-field--with-action">
            <input type="password" id="regPassword" required autocomplete="new-password" placeholder=" " minlength="8" />
            <label for="regPassword">Password</label>
            <button type="button" class="co-field__action" aria-label="Show password" data-toggle="regPassword">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <span class="field__hint">8+ characters · mix letters &amp; numbers</span>
            <!-- Password strength -->
            <div class="pwd-strength" id="pwdStrength" aria-live="polite">
              <div class="pwd-strength__bar"><span></span></div>
              <span class="pwd-strength__label">Strength</span>
            </div>
          </div>

          <label class="check auth-form__consent">
            <input type="checkbox" id="regMarketing" />
            <span>Send me styling notes &amp; new arrivals via email and WhatsApp · I can unsubscribe any time</span>
          </label>

          <label class="check auth-form__consent">
            <input type="checkbox" id="regTerms" required />
            <span>I agree to the <a href="#" class="link-inline">Terms of Sale</a> and <a href="#" class="link-inline">Privacy Policy</a>.</span>
          </label>

          <button type="submit" class="btn btn--primary btn--block">Create account</button>

          <p class="auth-form__signin-link">
            Already have an account? <button type="button" class="link-arrow link-arrow--inline" id="goToSignin">Sign in instead</button>
          </p>
        </form>
      </div>

      <!-- ── FORGOT PASSWORD ───────────────────────────────── -->
      <div class="auth-pane" id="paneForgot" role="tabpanel" hidden>
        <header class="auth-pane__head">
          <button type="button" class="auth-pane__back" id="backFromForgot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg>
            <span>Back to sign in</span>
          </button>
          <h1 class="auth-pane__title">Reset your password.</h1>
          <p class="auth-pane__sub">Enter the email on your account and we&rsquo;ll send a reset link.</p>
        </header>

        <form class="auth-form" id="forgotForm" novalidate onsubmit="event.preventDefault(); window.handleForgot && window.handleForgot();">
          <div class="co-field">
            <input type="email" id="forgotEmail" required autocomplete="email" placeholder=" " />
            <label for="forgotEmail">Email</label>
          </div>
          <button type="submit" class="btn btn--primary btn--block">Send reset link</button>

          <!-- Success state — hidden by default -->
          <div class="auth-success" id="forgotSuccess" hidden>
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="32" cy="32" r="28"/>
              <path d="M22 32l8 8 14-16"/>
            </svg>
            <h2>Check your inbox.</h2>
            <p>We&rsquo;ve sent a reset link to <strong id="forgotSentTo"></strong>. The link expires in 30 minutes.</p>
            <p class="auth-success__small">No email? Check your spam folder, or <button type="button" class="link-arrow link-arrow--inline">try again</button>.</p>
          </div>
        </form>
      </div>

      <!-- Help link -->
      <p class="auth-help">
        Trouble signing in? <a href="#" class="link-arrow link-arrow--inline">Chat with the atelier on WhatsApp</a>.
      </p>
    </div>

  </div>
</section>

<!-- ============================ FOOTER ============================ -->
