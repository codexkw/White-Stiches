@model WhiteStiches.Web.Models.Auth.AuthPageViewModel
@{
    ViewData["Title"] = "Sign in · White Stitches";
    ViewData["MetaDescription"] = "Sign in to your White Stitches account or create one in 30 seconds.";

    var errors = ViewData.ModelState.Values
        .SelectMany(v => v.Errors)
        .Select(e => e.ErrorMessage)
        .Where(m => !string.IsNullOrWhiteSpace(m))
        .Distinct()
        .ToList();
}

<!-- ============================ AUTH PAGE ============================ -->
<style>
  /* Server-side validation message box — matches the site's #c87a3a danger tone */
  .auth-form__error {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 16px;
    border: 1px solid rgba(200, 122, 58, 0.4);
    background: rgba(200, 122, 58, 0.08);
  }
  .auth-form__error p {
    margin: 0;
    font-size: var(--t-xs);
    letter-spacing: var(--tr-wide);
    line-height: var(--lh-loose);
    color: #c87a3a;
  }
</style>
<section class="auth">
  <div class="auth__inner">

    <!-- ── Left column: editorial side panel ─────────────────── -->
    <aside class="auth__aside" aria-hidden="true">
      <img src="~/assets/products/product-4.jpg" alt="" class="auth__aside-img" />
      <div class="auth__aside-overlay"></div>
      <div class="auth__aside-copy">
        <span class="eyebrow eyebrow--paper">@L["The Atelier"]</span>
        <h2 class="auth__aside-title">@L["Made in Kuwait. Designed for the GCC."]</h2>
        <p class="auth__aside-sub">
          @L["Save your pieces, track orders, and unlock first looks at our SS26 lookbook — exclusively for members."]
        </p>
      </div>
    </aside>

    <!-- ── Right column: forms ───────────────────────────────── -->
    <div class="auth__main">

      <!-- Tab switcher -->
      <div class="auth-tabs" role="tablist">
        <button type="button" class="auth-tabs__tab is-active" id="tabSignin" role="tab" aria-selected="true" aria-controls="paneSignin">
          @L["Sign in"]
        </button>
        <button type="button" class="auth-tabs__tab" id="tabRegister" role="tab" aria-selected="false" aria-controls="paneRegister">
          @L["Create account"]
        </button>
      </div>

      <!-- ── SIGN IN ────────────────────────────────────────── -->
      <div class="auth-pane is-active" id="paneSignin" role="tabpanel" aria-labelledby="tabSignin">
        <header class="auth-pane__head">
          <h1 class="auth-pane__title">@L["Welcome back."]</h1>
          <p class="auth-pane__sub">@L["Sign in to access your orders, wishlist and saved addresses."]</p>
        </header>

        <form class="auth-form" method="post" asp-controller="CustomerAuth" asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">
          @if (Model.ActivePane == "signin" && errors.Count > 0)
          {
            <div class="auth-form__error" role="alert">
              @foreach (var msg in errors)
              {
                <p>@msg</p>
              }
            </div>
          }

          <div class="co-field">
            <input asp-for="SignIn.Email" type="email" required autocomplete="email" placeholder=" " />
            <label asp-for="SignIn.Email">@L["Email"]</label>
          </div>

          <div class="co-field co-field--with-action">
            <input asp-for="SignIn.Password" type="password" required autocomplete="current-password" placeholder=" " minlength="8" />
            <label asp-for="SignIn.Password">@L["Password"]</label>
            <button type="button" class="co-field__action" id="togglePwd" aria-label="@L["Show password"]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>

          <div class="auth-form__row">
            <label class="check"><input asp-for="SignIn.RememberMe" type="checkbox" /><span>@L["Keep me signed in"]</span></label>
            <a href="#" class="link-arrow link-arrow--inline" id="forgotLink">@L["Forgot password?"]</a>
          </div>

          <button type="submit" class="btn btn--primary btn--block">@L["Sign in"]</button>
        </form>
      </div>

      <!-- ── REGISTER ───────────────────────────────────────── -->
      <div class="auth-pane" id="paneRegister" role="tabpanel" aria-labelledby="tabRegister" hidden>
        <header class="auth-pane__head">
          <h1 class="auth-pane__title">@L["Join the atelier."]</h1>
          <p class="auth-pane__sub">@L["Create your account in 30 seconds — never miss an edit."]</p>
        </header>

        <form class="auth-form" method="post" asp-controller="CustomerAuth" asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl">
          @if (Model.ActivePane == "register" && errors.Count > 0)
          {
            <div class="auth-form__error" role="alert">
              @foreach (var msg in errors)
              {
                <p>@msg</p>
              }
            </div>
          }

          <div class="co-field-row">
            <div class="co-field">
              <input asp-for="Register.FirstName" type="text" required autocomplete="given-name" placeholder=" " />
              <label asp-for="Register.FirstName">@L["First name"]</label>
            </div>
            <div class="co-field">
              <input asp-for="Register.LastName" type="text" required autocomplete="family-name" placeholder=" " />
              <label asp-for="Register.LastName">@L["Last name"]</label>
            </div>
          </div>

          <div class="co-field">
            <input asp-for="Register.Email" type="email" required autocomplete="email" placeholder=" " />
            <label asp-for="Register.Email">@L["Email"]</label>
          </div>

          <div class="co-field co-field--phone">
            <span class="field__prefix">
              <span class="flag flag--kw" aria-hidden="true"></span>
              <select asp-for="Register.PhoneCountryCode" aria-label="@L["Country code"]">
                <option value="+965">+965</option>
                <option value="+966">+966</option>
                <option value="+971">+971</option>
                <option value="+973">+973</option>
                <option value="+974">+974</option>
                <option value="+968">+968</option>
              </select>
            </span>
            <input asp-for="Register.Phone" type="tel" required autocomplete="tel" placeholder=" " inputmode="tel" />
            <label asp-for="Register.Phone">@L["Mobile"]</label>
          </div>

          <div class="co-field co-field--with-action">
            <input asp-for="Register.Password" type="password" id="regPassword" required autocomplete="new-password" placeholder=" " minlength="8" />
            <label for="regPassword">@L["Password"]</label>
            <button type="button" class="co-field__action" aria-label="@L["Show password"]" data-toggle="regPassword">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <span class="field__hint">@L["8+ characters · mix letters & numbers"]</span>
            <!-- Password strength -->
            <div class="pwd-strength" id="pwdStrength" aria-live="polite">
              <div class="pwd-strength__bar"><span></span></div>
              <span class="pwd-strength__label">@L["Strength"]</span>
            </div>
          </div>

          <label class="check auth-form__consent">
            <input asp-for="Register.EmailOptIn" type="checkbox" id="regMarketing" />
            <span>@L["Send me styling notes & new arrivals via email and WhatsApp · I can unsubscribe any time"]</span>
          </label>
          <input type="hidden" id="regMarketingWhatsApp" name="Register.WhatsAppOptIn" value="@(Model.Register.WhatsAppOptIn ? "true" : "false")" />

          <label class="check auth-form__consent">
            <input asp-for="Register.AcceptTerms" type="checkbox" id="regTerms" required />
            <span>@L["I agree to the"] <a asp-controller="Pages" asp-action="Terms" class="link-inline">@L["Terms of Sale"]</a> @L["and"] <a asp-controller="Pages" asp-action="Privacy" class="link-inline">@L["Privacy Policy"]</a>.</span>
          </label>

          <button type="submit" class="btn btn--primary btn--block">@L["Create account"]</button>

          <p class="auth-form__signin-link">
            @L["Already have an account?"] <button type="button" class="link-arrow link-arrow--inline" id="goToSignin">@L["Sign in instead"]</button>
          </p>
        </form>
      </div>

      <!-- ── FORGOT PASSWORD ───────────────────────────────── -->
      <div class="auth-pane" id="paneForgot" role="tabpanel" hidden>
        <header class="auth-pane__head">
          <button type="button" class="auth-pane__back" id="backFromForgot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg>
            <span>@L["Back to sign in"]</span>
          </button>
          <h1 class="auth-pane__title">@L["Reset your password."]</h1>
          <p class="auth-pane__sub">@L["Enter the email on your account and we'll send a reset link."]</p>
        </header>

        @if (Model.ForgotSuccess)
        {
          <!-- Success state -->
          <div class="auth-success" role="status">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="32" cy="32" r="28"/>
              <path d="M22 32l8 8 14-16"/>
            </svg>
            <h2>@L["Check your inbox."]</h2>
            <p>@L["We've sent a reset link to"] <strong>@Model.ForgotSentTo</strong>. @L["The link expires in 30 minutes."]</p>
            <p class="auth-success__small">@L["No email? Check your spam folder, or"] <a asp-controller="CustomerAuth" asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl" class="link-arrow link-arrow--inline">@L["try again"]</a>.</p>
          </div>
        }
        else
        {
          <form class="auth-form" method="post" asp-controller="CustomerAuth" asp-action="Forgot" asp-route-returnUrl="@Model.ReturnUrl">
            @if (Model.ActivePane == "forgot" && errors.Count > 0)
            {
              <div class="auth-form__error" role="alert">
                @foreach (var msg in errors)
                {
                  <p>@msg</p>
                }
              </div>
            }

            <div class="co-field">
              <input asp-for="Forgot.Email" type="email" required autocomplete="email" placeholder=" " />
              <label asp-for="Forgot.Email">@L["Email"]</label>
            </div>
            <button type="submit" class="btn btn--primary btn--block">@L["Send reset link"]</button>
          </form>
        }
      </div>

    </div>

  </div>
</section>

@section Scripts {
<script>
  document.addEventListener('DOMContentLoaded', function () {
    // The single consent checkbox covers both email and WhatsApp opt-ins.
    var regMarketing = document.getElementById('regMarketing');
    var regWhatsApp = document.getElementById('regMarketingWhatsApp');
    if (regMarketing && regWhatsApp) {
      var syncOptIns = function () { regWhatsApp.value = regMarketing.checked ? 'true' : 'false'; };
      regMarketing.addEventListener('change', syncOptIns);
      syncOptIns();
    }

    // Server round-trip: activate the pane that was submitted (mirrors site.js showPane).
    var activePane = '@Model.ActivePane';
    if (activePane !== 'signin') {
      var panes = {
        signin: document.getElementById('paneSignin'),
        register: document.getElementById('paneRegister'),
        forgot: document.getElementById('paneForgot')
      };
      var tabs = {
        signin: document.getElementById('tabSignin'),
        register: document.getElementById('tabRegister')
      };
      var target = panes[activePane];
      if (target) {
        Object.keys(panes).forEach(function (key) {
          var p = panes[key];
          if (!p) return;
          p.hidden = (p !== target);
          p.classList.toggle('is-active', p === target);
        });
        Object.keys(tabs).forEach(function (key) {
          var t = tabs[key];
          if (!t) return;
          var active = (key === activePane);
          t.classList.toggle('is-active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
        });
      }
    }
  });
</script>
}

