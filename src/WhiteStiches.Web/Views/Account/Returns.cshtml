@{
    ViewData["Title"] = "Returns & exchanges · White Stitches";
    ViewData["MetaDescription"] = "Initiate and track returns at White Stitches.";
}

<section class="acct-head">
  <div class="acct-head__inner">
    <span class="eyebrow">Account · Returns</span>
    <h1 class="acct-head__title">Returns &amp; exchanges.</h1>
    <p class="acct-head__sub">14-day window from the day you receive your order.</p>
  </div>
</section>

<section class="acct">
  <div class="acct__inner">
    <aside class="acct-nav" aria-label="Account navigation">
  <div class="acct-nav__head">
    <span class="eyebrow">Account</span>
    <strong class="acct-nav__name">Anas Al-Mutairi</strong>
    <span class="acct-nav__email">anas@@whitestiches.kw</span>
  </div>
  <nav class="acct-nav__list">
    <a href="/account" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg><span>Overview</span></a>
    <a href="/account/orders" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7h18l-2 13H5z"/><path d="M8 7V5a4 4 0 018 0v2"/></svg><span>Orders</span></a>
    <a href="/account/addresses" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2a7 7 0 017 7c0 5-7 13-7 13S5 14 5 9a7 7 0 017-7z"/><circle cx="12" cy="9" r="2.5"/></svg><span>Addresses</span></a>
    <a href="/account/wishlist" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><span>Wishlist</span></a>
    <a href="/account/profile" class="acct-nav__link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg><span>Profile</span></a>
    <a href="/account/returns" class="acct-nav__link is-active" aria-current="page"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 11-9-9"/><path d="M21 4v5h-5"/></svg><span>Returns</span></a>
  </nav>
  <a href="/account/login" class="acct-nav__signout"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg><span>Sign out</span></a>
</aside>

    <main class="acct__main">

      <!-- Start a return CTA -->
      <section class="acct-section acct-section--card acct-section--cta">
        <div class="acct-return-cta">
          <div>
            <h2>Start a return</h2>
            <p>Select an eligible order to begin. Most refunds land in 3–5 working days.</p>
          </div>
          <button type="button" class="btn btn--primary" id="startReturnBtn">Start a return</button>
        </div>
      </section>

      <!-- Filter chips -->
      <div class="acct-orders-toolbar">
        <div class="acct-orders-toolbar__filters">
          <button class="filter-chip is-active" type="button">All <em>3</em></button>
          <button class="filter-chip" type="button">Pending <em>1</em></button>
          <button class="filter-chip" type="button">Approved <em>1</em></button>
          <button class="filter-chip" type="button">Refunded <em>1</em></button>
        </div>
      </div>

      <!-- Returns list -->
      <ul class="acct-returns">
        <li>
          <div class="acct-return__head">
            <div>
              <span class="acct-return__num">#RT-2026-0193</span>
              <span class="acct-return__date">Initiated 17 May 2026 · for order #WS-2026-08197</span>
            </div>
            <span class="status-badge status-badge--pending">Pending review</span>
          </div>
          <div class="acct-return__body">
            <a href="/product" class="acct-return__media"><img src="~/assets/products/product-4.jpg" alt="" /></a>
            <div class="acct-return__info">
              <strong>Heritage Silk Scarf</strong>
              <span class="acct-return__meta">Reason: Wrong size</span>
              <span class="acct-return__refund">Refund: 22.000 KWD to KNET · debit ending 4421</span>
            </div>
            <div class="acct-return__actions">
              <a href="#" class="btn btn--ghost btn--sm">View detail</a>
            </div>
          </div>
        </li>
        <li>
          <div class="acct-return__head">
            <div>
              <span class="acct-return__num">#RT-2026-0181</span>
              <span class="acct-return__date">Initiated 10 May 2026 · for order #WS-2026-07842</span>
            </div>
            <span class="status-badge status-badge--approved">Approved · ship to us</span>
          </div>
          <div class="acct-return__body">
            <a href="/product" class="acct-return__media"><img src="~/assets/products/product-1.jpg" alt="" /></a>
            <div class="acct-return__info">
              <strong>Sahar Wide-Leg Trouser</strong>
              <span class="acct-return__meta">Reason: Didn&rsquo;t fit · exchange for size M</span>
              <span class="acct-return__refund">Refund: 38.500 KWD pending receipt</span>
            </div>
            <div class="acct-return__actions">
              <a href="#" class="btn btn--ghost btn--sm">Print label</a>
              <a href="#" class="btn btn--ghost btn--sm">View detail</a>
            </div>
          </div>
        </li>
        <li>
          <div class="acct-return__head">
            <div>
              <span class="acct-return__num">#RT-2026-0149</span>
              <span class="acct-return__date">Initiated 20 April 2026 · for order #WS-2026-07621</span>
            </div>
            <span class="status-badge status-badge--delivered">Refunded</span>
          </div>
          <div class="acct-return__body">
            <a href="/product" class="acct-return__media"><img src="~/assets/products/product-2.jpg" alt="" /></a>
            <div class="acct-return__info">
              <strong>Atelier Tailored Blazer</strong>
              <span class="acct-return__meta">Reason: Defective · pulled thread</span>
              <span class="acct-return__refund">Refunded 68.000 KWD · 22 April 2026</span>
            </div>
            <div class="acct-return__actions">
              <a href="#" class="btn btn--ghost btn--sm">View detail</a>
            </div>
          </div>
        </li>
      </ul>

      <!-- Policy reminder -->
      <section class="acct-section acct-section--card acct-section--policy">
        <header class="acct-section__head">
          <h2>Our returns policy in brief</h2>
          <a href="#" class="link-arrow">Read full policy <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </header>
        <ul class="acct-policy">
          <li><strong>14 days</strong> from the day you receive the order</li>
          <li>Pieces must be <strong>unworn</strong>, with original tags and packaging</li>
          <li>Sale items can be returned for <strong>store credit only</strong></li>
          <li>Refunds land in <strong>3–5 working days</strong> to your original payment method</li>
          <li>Final-sale pieces, swimwear and earrings cannot be returned</li>
        </ul>
      </section>

    </main>
  </div>
</section>

