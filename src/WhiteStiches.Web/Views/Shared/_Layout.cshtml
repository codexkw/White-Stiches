@using System.Globalization
@{
    var ci = CultureInfo.CurrentUICulture;
    var dir = ci.TextInfo.IsRightToLeft ? "rtl" : "ltr";
    var lang = ci.TwoLetterISOLanguageName;
    var otherLang = lang == "ar" ? "en" : "ar";
    var langLabel = lang == "ar" ? "EN" : "ع";
    var returnPath = Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString);
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>@ViewData["Title"]</title>
<meta name="description" content="@ViewData["MetaDescription"]" />

<link rel="icon" type="image/svg+xml" href="~/assets/logo-mark.svg">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter+Tight:wght@@300;400;500;600&family=Tajawal:wght@@300;400;500;700&display=swap" rel="stylesheet">

<!-- ═══════════════════════════════════════════════════════════════════════
     CRITICAL INLINE CSS — guarantees correct layout even if external CSS
     is cached, fails to load, or is replaced by an old version. Do not
     remove these rules — they are the safety net for the entire site.
     ═══════════════════════════════════════════════════════════════════════ -->
<style>
  /* Hide the hidden SVG <symbol> defs block at the bottom of the page —
     belt-and-braces because some browsers/configs render symbols visibly */
  .ws-svg-defs {
    position: absolute !important;
    width: 0 !important;
    height: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
    visibility: hidden !important;
  }

  /* Critical header layout — guarantees the 3-column header even if
     site.css fails to load */
  .hdr {
    position: sticky;
    top: 0;
    z-index: 200;
    background: #0a0a0a;
    border-bottom: 1px solid #2a2a2a;
    height: 132px;
  }
  .hdr__inner {
    max-width: 1400px;
    height: 100%;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
  }
  .hdr__nav { display: flex; align-items: center; gap: 32px; }
  .hdr__nav--right { justify-content: flex-end; }
  .hdr__logo { display: flex; align-items: center; justify-content: center; margin: -10px 0; }
  .hdr__logo-img { height: 150px; width: auto; display: block; }
  body { background: #0a0a0a; margin: 0; }

  /* Mobile header layout — burger left, logo center, icons right */
  @@media (max-width: 900px) {
    .hdr { height: 92px; }
    .hdr__nav--left { display: none; }
    .hdr__inner { grid-template-columns: auto 1fr auto; padding: 0 16px; }
    .hdr__logo-img { height: 108px; }
    .hdr__burger { display: inline-flex !important; }
  }
</style>

<link rel="stylesheet" href="~/css/design-system.css?v=2.6" />
<link rel="stylesheet" href="~/css/site.css?v=2.7" />
<link rel="stylesheet" href="~/css/rtl.css?v=2.6" />
</head>
<body>

@await Component.InvokeAsync("SiteChrome", new { section = "Announcement" })

<!-- ============================ HEADER + MEGA MENU ============================ -->
<header class="hdr" id="hdr">
  <div class="hdr__inner">

    <button class="hdr__burger" id="hdr-burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-drawer">
      <span></span>
      <span></span>
      <span></span>
    </button>

    @await Component.InvokeAsync("NavMenu", new { section = "HeaderNav" })

    <a href="/" class="hdr__logo" aria-label="White Stitches home">
      <img src="~/assets/logo-full.png" alt="White Stitches" class="hdr__logo-img" />
    </a>

    <nav class="hdr__nav hdr__nav--right" aria-label="Utility">
      <button type="button" class="hdr__icon" id="hdrSearchBtn" aria-label="@L["Search"]">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </button>
      <a class="hdr__lang" href="/set-culture?culture=@otherLang&returnUrl=@returnPath" aria-label="@L["Switch language"]">@langLabel</a>
      <a href="/account/login" class="hdr__icon" aria-label="@L["Account"]">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>
      </a>
      <button class="hdr__icon" aria-label="@L["Wishlist"]">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>
      <button type="button" class="hdr__cart" id="hdrCartBtn" aria-label="Open cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 7h14l-1.4 11.2a2 2 0 0 1-2 1.8h-7.2a2 2 0 0 1-2-1.8L5 7Z"/><path d="M9 7V5a3 3 0 1 1 6 0v2"/></svg>
        @await Component.InvokeAsync("CartBadge")
      </button>
    </nav>

  </div>

  @await Component.InvokeAsync("NavMenu", new { section = "MegaMenu" })

</header>

<!-- ── MOBILE DRAWER (outside header so position:fixed isn't constrained by sticky header) ── -->
<div class="drawer-overlay" id="drawer-overlay" aria-hidden="true"></div>
<aside class="drawer" id="mobile-drawer" aria-label="Mobile navigation" aria-hidden="true">
  <div class="drawer__head">
    <a href="/" class="drawer__logo" aria-label="White Stitches home">
        <img src="~/assets/logo-full.png" alt="White Stitches" />
      </a>
      <button class="drawer__close" id="drawer-close" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>

    <nav class="drawer__nav" aria-label="Mobile primary">

      @await Component.InvokeAsync("NavMenu", new { section = "Drawer" })

    </nav>

    <div class="drawer__foot">
      <a href="/account/login" class="drawer__util">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>
        @L["Account"]
      </a>
      <a href="/account/wishlist" class="drawer__util">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        @L["Wishlist"]
      </a>
      <a href="/search" class="drawer__util">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        @L["Search"]
      </a>
      <div class="drawer__lang-row">
        <a class="drawer__lang @(lang == "ar" ? null : "is-active")" href="/set-culture?culture=en&returnUrl=@returnPath">English</a>
        <span>|</span>
        <a class="drawer__lang @(lang == "ar" ? "is-active" : null)" href="/set-culture?culture=ar&returnUrl=@returnPath">العربية</a>
      </div>
    </div>
  </aside>

<!-- ============================ HERO ============================ -->
@RenderBody()

<footer class="ftr">
  <div class="ftr__inner">

    <div class="ftr__brand">
      <img src="~/assets/logo-full.png" alt="White Stitches" class="ftr__logo-img" />
      <p class="ftr__tagline">A Kuwait fashion house.<br>Designed for the GCC, finished by hand.</p>
      @await Component.InvokeAsync("SiteChrome", new { section = "FooterSocial" })
    </div>

    @await Component.InvokeAsync("NavMenu", new { section = "Footer" })

    <div class="ftr__col">
      <h5>@L["Help"]</h5>
      <a href="/contact">@L["Contact"]</a>
      <a href="/size-guide">@L["Size Guide"]</a>
      <a href="/track">@L["Track Order"]</a>
      <a href="/faq">@L["FAQ"]</a>
      <a href="/privacy">@L["Privacy Policy"]</a>
      <a href="/terms">@L["Terms and Conditions"]</a>
    </div>

    <div class="ftr__col">
      <h5>@L["About"]</h5>
      <a href="/about">@L["About Us"]</a>
    </div>

    <div class="ftr__col ftr__col--prefs">
      <h5>@L["Preferences"]</h5>
      <div class="ftr__pref">
        <span class="ftr__pref-lbl">@L["Country"]</span>
        <select aria-label="@L["Country"]">
          <option>Kuwait (KWD)</option>
          <option>Saudi Arabia (SAR)</option>
          <option>UAE (AED)</option>
          <option>Bahrain (BHD)</option>
          <option>Qatar (QAR)</option>
          <option>Oman (OMR)</option>
        </select>
      </div>
      <div class="ftr__pref">
        <span class="ftr__pref-lbl">@L["Language"]</span>
        <div class="ftr__lang-switch">
          <a href="/set-culture?culture=en&returnUrl=@returnPath" class="@(lang == "ar" ? null : "is-active")">English</a>
          <span aria-hidden="true">·</span>
          <a href="/set-culture?culture=ar&returnUrl=@returnPath" class="@(lang == "ar" ? "is-active" : null)">العربية</a>
        </div>
      </div>
    </div>

  </div>

  <div class="ftr__bottom">
    <span>© 2026 White Stitches Fashion W.L.L · CR 123456</span>
    <div class="ftr__pay">
      <span>KNET</span><span>VISA</span><span>MC</span><span>APPLE PAY</span><span>TABBY</span><span>TAMARA</span>
    </div>
    <div class="ftr__legal">
      <a href="/privacy">@L["Privacy"]</a>
      <a href="/terms">@L["Terms"]</a>
      <a href="/cookies">@L["Cookies"]</a>
    </div>
  </div>
</footer>

@await Component.InvokeAsync("SiteChrome", new { section = "WhatsAppFloat" })

<!-- ============================ SVG SYMBOLS (LOGO MARK) ============================ -->
<svg class="ws-svg-defs" width="0" height="0" style="position:absolute;width:0;height:0;overflow:hidden;visibility:hidden" aria-hidden="true" focusable="false">
  <defs>
    <symbol id="ws-mark" viewBox="0 0 200 200">
      <g fill="currentColor" fill-rule="evenodd">
        <path d="M40 20 L80 20 L60 60 Z"/>
        <path d="M120 20 L160 20 L140 60 Z"/>
        <path d="M85 30 L100 50 L85 65 Z"/>
        <path d="M115 30 L100 50 L115 65 Z"/>
        <path d="M20 50 L40 70 L40 130 L20 150 Z"/>
        <path d="M180 50 L160 70 L160 130 L180 150 Z"/>
        <path d="M100 60 L130 100 L100 140 L70 100 Z"/>
        <path d="M100 80 L115 100 L100 120 L85 100 Z" fill="#0a0a0a"/>
        <path d="M40 180 L80 180 L60 140 Z"/>
        <path d="M120 180 L160 180 L140 140 Z"/>
        <path d="M85 170 L100 150 L85 135 Z"/>
        <path d="M115 170 L100 150 L115 135 Z"/>
      </g>
    </symbol>
  </defs>
</svg>

<script src="~/js/site.js?v=2.7"></script>

<!-- ============================ MINI-CART DRAWER (global) ============================ -->
<aside class="mc-drawer" id="miniCart" aria-label="Cart" aria-hidden="true">
  <button type="button" class="mc-drawer__backdrop" id="miniCartBackdrop" aria-label="Close cart"></button>
  <div class="mc-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="miniCartTitle">
    @await Component.InvokeAsync("MiniCart")
  </div>
</aside>

<!-- ============================ SEARCH OVERLAY (global) ============================ -->
<div class="search-overlay" id="searchOverlay" aria-hidden="true">
  <button type="button" class="search-overlay__backdrop" id="searchOverlayBackdrop" aria-label="@L["Close search"]"></button>
  <div class="search-overlay__panel" role="dialog" aria-modal="true" aria-labelledby="searchOverlayTitle">
    <header class="search-overlay__head">
      <div class="search-overlay__input-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="search-overlay__icon"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        <input type="search" id="searchOverlayInput" class="search-overlay__input" placeholder="@L["Search pieces, collections, journal…"]" autocomplete="off" />
        <button type="button" class="search-overlay__clear" id="searchOverlayClear" aria-label="@L["Clear"]" hidden>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M9 9l6 6M15 9l-6 6"/></svg>
        </button>
      </div>
      <button type="button" class="search-overlay__close" id="searchOverlayClose">
        <span>@L["Close"]</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </header>

    <div class="search-overlay__body">

      <!-- Idle state (when nothing typed) -->
      <div class="search-overlay__idle" id="searchOverlayIdle">
        <div class="so-col">
          <span class="eyebrow">@L["Popular searches"]</span>
          <ul class="so-chips">
            <li><button type="button" data-q="Silk dresses">@L["Silk dresses"]</button></li>
            <li><button type="button" data-q="Linen trousers">@L["Linen trousers"]</button></li>
            <li><button type="button" data-q="Eid edit">@L["Eid edit"]</button></li>
            <li><button type="button" data-q="Black-tie">@L["Black-tie"]</button></li>
            <li><button type="button" data-q="Atelier blazer">@L["Atelier blazer"]</button></li>
            <li><button type="button" data-q="Heritage scarves">@L["Heritage scarves"]</button></li>
          </ul>
        </div>
        <div class="so-col" id="searchOverlayRecentCol" hidden>
          <span class="eyebrow">@L["Recent searches"]</span>
          <ul class="so-recent" id="searchOverlayRecent"></ul>
        </div>
        @await Component.InvokeAsync("SearchTrending")
      </div>

      <!-- Live results (typing state) — populated by site.js via /search/suggest -->
      <div class="search-overlay__results" id="searchOverlayResults" hidden></div>

      <!-- Empty/no results -->
      <div class="search-overlay__noresults" id="searchOverlayNoResults" hidden>
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="28" cy="28" r="20"/><path d="m44 44 12 12"/></svg>
        <h3>@L["No results."]</h3>
        <p>@L["Try a different word, or"] <button type="button" class="link-arrow link-arrow--inline">@L["WhatsApp the atelier"]</button> @L["— we’ll find it."]</p>
      </div>

    </div>

    <footer class="search-overlay__foot">
      <span class="search-overlay__hint">@L["Press"] <kbd>Esc</kbd> @L["to close"] · <kbd>↵</kbd> @L["for full results"]</span>
      <a href="/search" class="link-arrow" id="searchOverlayAll">@L["View all results"] <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </footer>
  </div>
</div>

<!-- ============================ COOKIE CONSENT BANNER (global) ============================ -->
<div class="cookie-banner" id="cookieBanner" aria-label="Cookie consent" hidden>
  <div class="cookie-banner__inner">
    <div class="cookie-banner__copy">
      <strong>We use cookies to deliver this site.</strong>
      <p>Essential cookies keep checkout and sign-in working. Analytics and marketing cookies are optional. See our <a href="/cookies">Cookies Policy</a>.</p>
    </div>
    <div class="cookie-banner__actions">
      <button type="button" class="btn btn--ghost btn--sm" id="cookieCustomize">Customize</button>
      <button type="button" class="btn btn--ghost btn--sm" id="cookieReject">Reject all</button>
      <button type="button" class="btn btn--primary btn--sm" id="cookieAccept">Accept all</button>
    </div>
  </div>
</div>

<!-- Cookie customize modal -->
<div class="cookie-modal" id="cookieModal" aria-hidden="true">
  <button type="button" class="cookie-modal__backdrop" id="cookieModalBackdrop" aria-label="Close"></button>
  <div class="cookie-modal__panel" role="dialog" aria-modal="true">
    <header class="cookie-modal__head">
      <h2>Cookie preferences</h2>
      <button type="button" class="cookie-modal__close" id="cookieModalClose" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </header>
    <div class="cookie-modal__body">
      <p class="cookie-modal__lede">Choose which cookies you’re happy for us to use. Essential cookies are always on; you can toggle the rest. See <a href="/cookies">Cookies Policy</a> for details.</p>

      <div class="cookie-row">
        <div>
          <strong>Strictly necessary</strong>
          <span>Sign-in, cart, checkout, security. Cannot be disabled.</span>
        </div>
        <label class="toggle"><input type="checkbox" checked disabled /><span></span></label>
      </div>
      <div class="cookie-row">
        <div>
          <strong>Functional</strong>
          <span>Remember language, currency, recently viewed.</span>
        </div>
        <label class="toggle"><input type="checkbox" checked data-cookie="functional" /><span></span></label>
      </div>
      <div class="cookie-row">
        <div>
          <strong>Analytics</strong>
          <span>Help us understand what works — anonymised.</span>
        </div>
        <label class="toggle"><input type="checkbox" data-cookie="analytics" /><span></span></label>
      </div>
      <div class="cookie-row">
        <div>
          <strong>Marketing</strong>
          <span>Show relevant pieces on Instagram and Google.</span>
        </div>
        <label class="toggle"><input type="checkbox" data-cookie="marketing" /><span></span></label>
      </div>
    </div>
    <footer class="cookie-modal__foot">
      <button type="button" class="btn btn--ghost" id="cookieModalReject">Reject all</button>
      <button type="button" class="btn btn--primary" id="cookieModalSave">Save preferences</button>
    </footer>
  </div>
</div>

<!-- Small re-open button (bottom-left, after consent is set) -->
<button type="button" class="cookie-reopen" id="cookieReopen" aria-label="Manage cookie preferences" hidden>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><circle cx="9" cy="10" r="0.7" fill="currentColor"/><circle cx="14" cy="9" r="0.7" fill="currentColor"/><circle cx="15" cy="14" r="0.7" fill="currentColor"/><circle cx="10" cy="15" r="0.7" fill="currentColor"/></svg>
</button>

@RenderSection("Scripts", required: false)
</body>
</html>
