@using System.Globalization
@model WhiteStiches.Web.Models.Content.JournalPostViewModel
@{
    var post = Model.Post;
    ViewData["Title"] = $"{post.Title()} · White Stitches Journal";
    ViewData["MetaDescription"] = string.IsNullOrWhiteSpace(post.Excerpt())
        ? "Notes from the White Stitches atelier."
        : post.Excerpt();

    string PostDate(JournalPost p) => (p.PublishAtUtc ?? p.CreatedAtUtc).ToString("d MMM yyyy", CultureInfo.InvariantCulture);
    string PostImage(JournalPost p) => string.IsNullOrWhiteSpace(p.HeroImageUrl)
        ? Url.Content("~/assets/products/product-4.jpg")
        : Url.Content(p.HeroImageUrl);
}

<!-- Hero image with title overlay -->
<section class="journal-post-hero">
  <div class="journal-post-hero__media">
    <img src="@PostImage(post)" alt="@post.Title()" />
    <div class="journal-post-hero__overlay"></div>
  </div>
  <div class="journal-post-hero__inner">
    <a href="/journal" class="acct-back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg>
      <span>@L["Back to journal"]</span>
    </a>
    @if (post.Category is not null)
    {
      <span class="journal-tag">@post.Category.Name()</span>
    }
    <h1 class="journal-post-hero__title">@post.Title()</h1>
    <div class="journal-post-hero__meta">
      <span>By <strong>@post.AuthorName</strong></span>
      <span>·</span>
      <time>@PostDate(post)</time>
      @if (post.ReadingTimeMinutes is int minutes)
      {
        <span>·</span>
        <span>@minutes @L["min read"]</span>
      }
    </div>
  </div>
</section>

<article class="journal-post">
  <div class="journal-post__inner">

    @Html.Raw(post.Body())

    <!-- Share -->
    <footer class="journal-post__share">
      <span class="eyebrow">@L["Share this piece"]</span>
      <div class="journal-post__share-buttons">
        <a href="#" aria-label="@L["Share on Instagram"]"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg></a>
        <a href="#" aria-label="@L["Share on WhatsApp"]"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 11.5a8.4 8.4 0 0 1-8.4 8.4 8.4 8.4 0 0 1-4-1L3 20l1.1-5.6a8.4 8.4 0 0 1-1-4A8.4 8.4 0 0 1 11.5 2 8.4 8.4 0 0 1 21 11.5z"/></svg></a>
        <a href="#" aria-label="@L["Share on Pinterest"]"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M11 22c.5-3 .8-4 1.2-5.5"/><path d="M8 9.5C8 7 10 5 12.5 5S17 7 17 9.5c0 3-2 5-4 5-1 0-1.7-.5-2-1.2"/></svg></a>
        <a href="#" aria-label="@L["Copy link"]"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M10 13a5 5 0 0 0 7 0l4-4a5 5 0 1 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-4 4a5 5 0 1 0 7 7l1-1"/></svg></a>
      </div>
    </footer>

    <!-- Author bio -->
    <section class="journal-post__author">
      <div class="journal-post__author-avatar"></div>
      <div>
        <span class="eyebrow">@L["Written by"]</span>
        <strong>@post.AuthorName</strong>
        <p>@L["Writes here about the pieces we make and the people we make them with."]</p>
      </div>
    </section>

  </div>
</article>

@if (Model.Related.Count > 0)
{
<!-- Related articles -->
<section class="journal-related">
  <div class="journal-related__inner">
    <header class="section-head section-head--center">
      <span class="eyebrow">@L["Read next"]</span>
      <h2 class="section-title">@L["More from the journal."]</h2>
    </header>
    <div class="journal-grid__inner" style="padding: 0;">
      @foreach (var rel in Model.Related)
      {
      <article class="journal-card">
        <a href="/journal/@rel.Slug" class="journal-card__media"><img src="@PostImage(rel)" alt="@rel.Title()" /></a>
        <div class="journal-card__body">
          @if (rel.Category is not null)
          {
            <span class="journal-tag">@rel.Category.Name()</span>
          }
          <h3 class="journal-card__title"><a href="/journal/@rel.Slug">@rel.Title()</a></h3>
          <span class="journal-meta"><time>@PostDate(rel)</time></span>
        </div>
      </article>
      }
    </div>
  </div>
</section>
}

