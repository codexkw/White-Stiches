@using System.Globalization
@model WhiteStiches.Web.Models.Checkout.ConfirmationViewModel
@{
    Layout = "_CheckoutLayout";
    ViewData["Title"] = "Order Confirmed · White Stitches";
    ViewData["MetaDescription"] = "Your order is confirmed. Thank you.";

    var order = Model.Order;
    var placedAt = order.PlacedAtUtc?.ToString("dddd, d MMMM yyyy 'at' h:mm tt", CultureInfo.InvariantCulture);

    // "Block 4, Street 12, Building 8 · Floor 3, Apt 11"
    var addressLine = $"Block {order.ShipBlock}, Street {order.ShipStreet}, Building {order.ShipBuilding}";
    var unitParts = new List<string>();
    if (!string.IsNullOrWhiteSpace(order.ShipFloor)) { unitParts.Add($"Floor {order.ShipFloor}"); }
    if (!string.IsNullOrWhiteSpace(order.ShipApartment)) { unitParts.Add($"Apt {order.ShipApartment}"); }
    if (unitParts.Count > 0) { addressLine += " · " + string.Join(", ", unitParts); }

    var countryName = order.ShipCountry == "KW" ? "Kuwait" : order.ShipCountry;
}

<header class="co-hdr">  <div class="co-hdr__inner">
    <a href="/" class="co-hdr__back" aria-label="@L["Continue shopping"]">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg>
      <span>@L["Continue shopping"]</span>
    </a>
    <a href="/" class="co-hdr__logo" aria-label="@L["White Stitches home"]">
      <img src="~/assets/logo-full.png" alt="White Stitches" class="co-hdr__logo-img" />
    </a>
    <a href="/account" class="co-hdr__secure" aria-label="@L["Account"]">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>
      <span>@L["Account"]</span>
    </a>
  </div>
</header>

<!-- ============================ STEP INDICATOR ============================ -->
<div class="co-steps">
  <div class="co-steps__inner">
    <ol>
      <li class="is-done"><span class="co-steps__num">1</span> @L["Bag"]</li>
      <li class="is-done"><span class="co-steps__num">2</span> @L["Checkout"]</li>
      <li class="is-active"><span class="co-steps__num">3</span> @L["Confirmation"]</li>
    </ol>
  </div>
</div>

<!-- ============================ CONFIRMATION HERO ============================ -->
<section class="oc-hero">
  <div class="oc-hero__inner">
    <div class="oc-hero__mark" aria-hidden="true">
      <svg viewBox="0 0 80 80" fill="none">
        <circle cx="40" cy="40" r="38" stroke="currentColor" stroke-width="1" opacity="0.4"/>
        <circle cx="40" cy="40" r="30" stroke="currentColor" stroke-width="1" opacity="0.2"/>
        <path d="M28 40l9 9 17-19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <span class="eyebrow">@L["Thank you,"] <span>@order.ShipFirstName</span></span>
    <h1 class="oc-hero__title">@L["Your order is confirmed."]</h1>
    <p class="oc-hero__sub">
      @L["Order"] <strong>#@order.OrderNumber</strong> · @L["placed"] @placedAt
    </p>
    <p class="oc-hero__meta">
      @L["A confirmation is on its way to"] <strong>@order.Email</strong>. @L["We've also sent you a WhatsApp update on"] <strong>@order.Phone</strong>.
    </p>
  </div>
</section>

<!-- ============================ TWO-COL GRID ============================ -->
<main class="oc">
  <div class="oc__inner">

    <!-- ── LEFT column: order details ──────────────────────────── -->
    <div class="oc__main">

      <!-- ETA card -->
      <section class="oc-card oc-card--eta">
        <div class="oc-card__head">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
            <path d="M3 7h13v9H3zM16 10h3l2 3v3h-5zM7 19a2 2 0 100-4 2 2 0 000 4zM18 19a2 2 0 100-4 2 2 0 000 4z"/>
          </svg>
          <h2>@L["Arriving"] <strong>@L["within 2–3 working days"]</strong></h2>
          <span class="oc-card__chip">@Model.ShippingMethodShort · @Model.ShippingPriceLabel</span>
        </div>
        <div class="oc-card__body">
          <p>
            Your pieces will leave our Kuwait atelier within 24 hours, hand-folded in our signature tissue with the wax-marked closure. Tracking arrives by WhatsApp once they&rsquo;re on the way.
          </p>
          <div class="oc-tracker">
            <div class="oc-tracker__bar"><span style="width: 25%"></span></div>
            <ol class="oc-tracker__steps">
              <li class="is-done"><span></span>@L["Confirmed"]</li>
              <li><span></span>@L["Atelier"]</li>
              <li><span></span>@L["In transit"]</li>
              <li><span></span>@L["Delivered"]</li>
            </ol>
          </div>
        </div>
      </section>

      <!-- Delivery address -->
      <section class="oc-card">
        <div class="oc-card__head">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
            <path d="M12 2a7 7 0 017 7c0 5-7 13-7 13S5 14 5 9a7 7 0 017-7z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
          <h2>@L["Delivery address"]</h2>
        </div>
        <div class="oc-card__body">
          <address class="oc-address">
            <strong>@order.ShipFirstName @order.ShipLastName</strong><br>
            @addressLine<br>
            @order.ShipArea, @order.ShipGovernorate<br>
            @countryName<br>
            @order.ShipPhone
          </address>
        </div>
      </section>

      <!-- Payment summary -->
      <section class="oc-card">
        <div class="oc-card__head">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
            <rect x="3" y="6" width="18" height="13" rx="1"/>
            <path d="M3 10h18"/>
          </svg>
          <h2>@L["Payment"]</h2>
        </div>
        <div class="oc-card__body">
          <div class="oc-pay">
            @switch (Model.PaymentMethodKey)
            {
              case "card":
                <span class="pay-card__brand pay-card__brand--visa">VISA</span>
                break;
              case "applepay":
                <span class="pay-card__brand pay-card__brand--apple">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 12.04c-.01-2.04 1.66-3.02 1.74-3.07-.95-1.39-2.42-1.58-2.94-1.6-1.24-.13-2.43.74-3.06.74-.64 0-1.61-.72-2.66-.7-1.36.02-2.63.79-3.33 2.01-1.42 2.47-.36 6.12 1.02 8.12.68.98 1.49 2.08 2.55 2.04 1.03-.04 1.42-.66 2.66-.66 1.24 0 1.59.66 2.67.64 1.1-.02 1.8-1 2.47-1.99.78-1.14 1.1-2.24 1.12-2.3-.02-.01-2.15-.83-2.17-3.23zM15.07 5.91c.56-.69.95-1.64.84-2.59-.81.04-1.81.55-2.4 1.23-.52.6-.98 1.58-.86 2.51.91.07 1.85-.46 2.42-1.15z"/></svg>
                </span>
                break;
              case "cod":
                <span class="pay-card__brand pay-card__brand--cod">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="6" width="18" height="13" rx="1"/><path d="M3 10h18"/><path d="M7 15h3"/></svg>
                </span>
                break;
              case "knet":
                <span class="pay-card__brand pay-card__brand--knet">KNET</span>
                break;
              default:
                @* Tap (and any gateway-reported method without a dedicated brand badge) — neutral secure icon. *@
                <span class="pay-card__brand" aria-hidden="true" style="display:inline-flex;align-items:center;justify-content:center;min-width:44px">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" style="width:20px;height:20px"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V8a5 5 0 0110 0v3"/></svg>
                </span>
                break;
            }
            <div>
              <strong>@Model.PaymentMethodLabel</strong>
              @if (Model.PaymentMethodKey == "cod")
              {
                <span class="oc-pay__meta">@L["Pay the courier in cash on arrival"] · @order.Total.ToString("0.000") KWD</span>
              }
              else
              {
                <span class="oc-pay__meta oc-pay__meta--@Model.PaymentStatusModifier">@L[Model.PaymentStatusLabel] · @order.Total.ToString("0.000") KWD</span>
              }
            </div>
          </div>
        </div>
      </section>

      @if (Model.IsPaymentPending)
      {
      <!-- Pending payment notice — shown only while the bank confirmation is genuinely outstanding -->
      <section class="oc-card oc-card--pending">
        <div class="oc-card__head">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          <h2>@L["Payment pending confirmation"]</h2>
        </div>
        <div class="oc-card__body">
          <p>
            @L["We're still waiting for your bank to confirm the transaction. This usually takes a few seconds, but can take up to 30 minutes. We'll email and WhatsApp you the moment it's confirmed."]
          </p>
        </div>
      </section>
      }

      <!-- Items detail -->
      <section class="oc-card oc-card--items">
        <div class="oc-card__head">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
            <path d="M3 7h18l-2 13H5z"/>
            <path d="M8 7V5a4 4 0 018 0v2"/>
          </svg>
          <h2>@L["Your pieces"]</h2>
          <span class="oc-card__chip">@Model.ItemCount @(Model.ItemCount == 1 ? L["item"].Value : L["items"].Value)</span>
        </div>
        <div class="oc-card__body">
          <ul class="oc-items">
            @foreach (var item in order.Items)
            {
              var variantParts = (item.VariantDescription ?? string.Empty)
                  .Split(" / ", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
              <li>
                <span class="oc-item__media">
                  @if (!string.IsNullOrEmpty(item.ImageUrl))
                  {
                    <img src="@item.ImageUrl" alt="@item.Title()" />
                  }
                </span>
                <div class="oc-item__body">
                  <h3 class="oc-item__title">@item.Title()</h3>
                  <ul class="oc-item__meta">
                    @if (variantParts.Length >= 2)
                    {
                      <li><span>@L["Colour"]</span> @variantParts[1]</li>
                    }
                    @if (variantParts.Length >= 1)
                    {
                      <li><span>@L["Size"]</span> @variantParts[0]</li>
                    }
                    <li><span>@L["Qty"]</span> @item.Quantity</li>
                  </ul>
                </div>
                <span class="oc-item__price">@item.LineTotal.ToString("0.000") KWD</span>
              </li>
            }
          </ul>
        </div>
      </section>

      <!-- Help / support strip -->
      <section class="oc-help">
        <div class="oc-help__col">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 11.5a8.4 8.4 0 0 1-8.4 8.4 8.4 8.4 0 0 1-4-1L3 20l1.1-5.6a8.4 8.4 0 0 1-1-4A8.4 8.4 0 0 1 11.5 2 8.4 8.4 0 0 1 21 11.5z"/></svg>
          <strong>@L["WhatsApp the atelier"]</strong>
          <span>@L["Sat–Thu · 9 AM – 9 PM Kuwait"]</span>
          <a href="/contact" class="btn btn--ghost btn--sm">@L["Open WhatsApp"]</a>
        </div>
        <div class="oc-help__col">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7l9 6 9-6"/><rect x="3" y="5" width="18" height="14" rx="1"/></svg>
          <strong>@L["Need to change something?"]</strong>
          <span>@L["You have 1 hour to update size, address, or cancel."]</span>
          <a href="/contact" class="btn btn--ghost btn--sm">@L["Manage order"]</a>
        </div>
      </section>

      @if (Model.ShowCreateAccount)
      {
        <!-- Create-account prompt (shown only to guest checkouts) -->
        <section class="oc-card oc-card--account">
          <div class="oc-card__head">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>
            <h2>@L["Create your account"]</h2>
            <span class="oc-card__chip">@L["Optional · 30 seconds"]</span>
          </div>
          <div class="oc-card__body">
            <p>@L["Save this address, track future orders, and unlock early access to lookbooks & private sales."]</p>
            <form class="oc-account" action="/account/register" method="get">
              <div class="co-field">
                <input type="email" id="ocAccountEmail" value="@order.Email" placeholder=" " readonly />
                <label for="ocAccountEmail">@L["Email"]</label>
                <span class="field__hint">@L["We'll use the email from your order"]</span>
              </div>
              <button type="submit" class="btn btn--primary">@L["Create account"]</button>
            </form>
          </div>
        </section>
      }

    </div>

    <!-- ── RIGHT column: totals ──────────────────────────────── -->
    <aside class="oc__totals">
      <div class="oc-totals">
        <h2 class="oc-totals__title">@L["Order Summary"]</h2>
        <ul class="cart-totals">
          <li><span>@L["Subtotal"] · @Model.ItemCount @(Model.ItemCount == 1 ? L["item"].Value : L["items"].Value)</span><span class="cart-totals__val">@order.Subtotal.ToString("0.000") KWD</span></li>
          @if (order.DiscountAmount > 0)
          {
            <li class="cart-totals__discount"><span>Promo · <em>@order.DiscountCodeSnapshot</em></span><span class="cart-totals__val cart-totals__val--accent">−@order.DiscountAmount.ToString("0.000") KWD</span></li>
          }
          @if (order.GiftWrapFee > 0)
          {
            <li><span>@L["Gift wrap"]</span><span class="cart-totals__val">@order.GiftWrapFee.ToString("0.000") KWD</span></li>
          }
          <li>
            <span>@L["Delivery"] · @Model.ShippingMethodShort</span>
            @if (order.ShippingAmount == 0)
            {
              <span class="cart-totals__val cart-totals__val--accent">@L["Free"]</span>
            }
            else
            {
              <span class="cart-totals__val">@order.ShippingAmount.ToString("0.000") KWD</span>
            }
          </li>
          <li><span>@L["VAT"]</span><span class="cart-totals__val">@L["Included"]</span></li>
        </ul>
        <div class="cart-totals__grand">
          <span>@L["Total"]</span>
          <span>@order.Total.ToString("0.000") <span class="cart-totals__currency">KWD</span></span>
        </div>

        <div class="oc-totals__actions">
          <a href="#" class="btn btn--ghost btn--sm btn--block">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 4v16M4 12h16"/></svg>
            <span>@L["Download invoice (PDF)"]</span>
          </a>
          <a href="/track" class="btn btn--ghost btn--sm btn--block">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 12h18M15 6l6 6-6 6"/></svg>
            <span>@L["Track order"]</span>
          </a>
        </div>

        <ul class="cart-trust">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V8a5 5 0 0110 0v3"/></svg><span>@L["Paid securely via Tap Payments"]</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 11-9-9"/><path d="M21 4v5h-5"/></svg><span>@L["14-day easy returns"]</span></li>
        </ul>
      </div>
    </aside>
  </div>
</main>

@if (Model.CrossSell.Count > 0)
{
<!-- ============================ CROSS-SELL ============================ -->
<section class="products products--oc">
  <div class="section-head section-head--center">
    <span class="eyebrow">@L["While you wait"]</span>
    <h2 class="section-title">@L["You may also like."]</h2>
  </div>
  <div class="products__grid">
    @foreach (var product in Model.CrossSell)
    {
      var images = product.Images.OrderBy(i => i.SortOrder).ToList();
      var front = images.FirstOrDefault();
      var back = images.Skip(1).FirstOrDefault();
      var price = product.Variants.Count > 0 ? product.Variants.Min(v => v.Price) : 0m;
      <article class="product">
        <a href="/products/@product.Slug" class="product__media">
          @if (front is not null)
          {
            <img src="@front.Url" alt="@(front.Alt() ?? product.Title())" class="product__img product__img--front" />
          }
          @if (back is not null)
          {
            <img src="@back.Url" alt="" class="product__img product__img--back" />
          }
        </a>
        <div class="product__info">
          <h3 class="product__title"><a href="/products/@product.Slug">@product.Title()</a></h3>
          <div class="product__price"><span>@price.ToString("0.000") KWD</span></div>
        </div>
      </article>
    }
  </div>
</section>
}

<!-- ============================ MINIMAL FOOTER ============================ -->
