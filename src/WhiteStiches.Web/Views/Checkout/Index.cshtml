@model WhiteStiches.Web.Models.Checkout.CheckoutViewModel
@{
    Layout = "_CheckoutLayout";
    ViewData["Title"] = "Checkout · White Stitches";
    ViewData["MetaDescription"] = "Secure checkout — pay with KNET, Apple Pay, or your card via Tap Payments.";
    var governorates = new[] { "Al Asimah (Capital)", "Hawalli", "Al Farwaniyah", "Mubarak Al-Kabeer", "Al Ahmadi", "Al Jahra" };
}
@functions {
    private string Err(string key) =>
        ViewData.ModelState.TryGetValue(key, out var entry) && entry.Errors.Count > 0 ? "is-invalid" : "";
}

<style>
  .co-field input.is-invalid,
  .co-field select.is-invalid,
  .co-field textarea.is-invalid { border-color: #c87a3a; }
  .co-check.is-invalid span { color: #c87a3a; }
  .co-errors { border: 1px solid #c87a3a; padding: 14px 16px; margin-bottom: 18px; font-size: 0.85rem; color: #c87a3a; }
  .co-errors ul { margin: 0; padding-left: 18px; }
  .co-errors li + li { margin-top: 4px; }
  .co-note-muted { font-size: 0.8rem; opacity: 0.65; margin: 10px 0 0; }
  .express-btn[disabled] { opacity: 0.45; cursor: not-allowed; }
</style>

<header class="co-hdr">  <div class="co-hdr__inner">
    <a href="/cart" class="co-hdr__back" aria-label="Back to bag">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M15 6l-6 6 6 6"/></svg>
      <span>Back to bag</span>
    </a>
    <a href="/" class="co-hdr__logo" aria-label="White Stitches home">
      <img src="~/assets/logo-full.png" alt="White Stitches" class="co-hdr__logo-img" />
    </a>
    <div class="co-hdr__secure" aria-label="Secure checkout">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V8a5 5 0 0110 0v3"/></svg>
      <span>Secure</span>
    </div>
  </div>
</header>

<!-- ============================ STEP INDICATOR ============================ -->
<div class="co-steps">
  <div class="co-steps__inner">
    <ol>
      <li class="is-done"><span class="co-steps__num">1</span> Bag</li>
      <li class="is-active"><span class="co-steps__num">2</span> Checkout</li>
      <li><span class="co-steps__num">3</span> Confirmation</li>
    </ol>
  </div>
</div>

<!-- ============================ CHECKOUT GRID ============================ -->
<main class="co">
  <div class="co__inner">

    <!-- ── FORM column ─────────────────────────────────────────────── -->
    <form class="co__form" method="post" asp-controller="Checkout" asp-action="Place">

      @if (TempData["CheckoutError"] is string checkoutError)
      {
        <div class="co-errors" role="alert"><ul><li>@checkoutError</li></ul></div>
      }

      <!-- Express checkout row (top) — placeholders until Tap Payments (Phase 1C) -->
      <div class="co-section co-section--express">
        <span class="co-express__label">Express checkout</span>
        <div class="co-express__row">
          <button type="button" class="express-btn express-btn--apple" aria-label="Pay with Apple Pay" disabled>
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 12.04c-.01-2.04 1.66-3.02 1.74-3.07-.95-1.39-2.42-1.58-2.94-1.6-1.24-.13-2.43.74-3.06.74-.64 0-1.61-.72-2.66-.7-1.36.02-2.63.79-3.33 2.01-1.42 2.47-.36 6.12 1.02 8.12.68.98 1.49 2.08 2.55 2.04 1.03-.04 1.42-.66 2.66-.66 1.24 0 1.59.66 2.67.64 1.1-.02 1.8-1 2.47-1.99.78-1.14 1.1-2.24 1.12-2.3-.02-.01-2.15-.83-2.17-3.23zM15.07 5.91c.56-.69.95-1.64.84-2.59-.81.04-1.81.55-2.4 1.23-.52.6-.98 1.58-.86 2.51.91.07 1.85-.46 2.42-1.15z"/></svg>
            <span>Apple Pay</span>
          </button>
          <button type="button" class="express-btn express-btn--google" disabled><span>G Pay</span></button>
        </div>
        <span class="co-express__divider"><em>or fill in your details</em></span>
      </div>

      <!-- ── 1 · CONTACT ───────────────────────────────────────────── -->
      <section class="co-section">
        <header class="co-section__head">
          <span class="co-section__num">1</span>
          <h2>Contact</h2>
          @if (!(User.Identity?.IsAuthenticated ?? false))
          {
            <a href="/account/login" class="co-section__link">Already have an account? <strong>Sign in</strong></a>
          }
        </header>

        <div class="co-section__body">
          <div class="co-field">
            <input type="email" id="email" name="email" value="@Model.Form.Email" required autocomplete="email" placeholder=" " class="@Err("Email")" />
            <label for="email">Email</label>
            <span class="field__hint">For order confirmation &amp; tracking</span>
          </div>

          <div class="co-field co-field--phone">
            <span class="field__prefix" id="phonePrefix">
              <span class="flag flag--kw" aria-hidden="true"></span>
              <select id="phoneCountry" aria-label="Country code">
                <option value="+965" selected>+965</option>
                <option value="+966">+966</option>
                <option value="+971">+971</option>
                <option value="+973">+973</option>
                <option value="+974">+974</option>
                <option value="+968">+968</option>
              </select>
            </span>
            <input type="tel" id="phone" name="phone" value="@Model.Form.Phone" required autocomplete="tel" placeholder=" " inputmode="tel" class="@Err("Phone")" />
            <label for="phone">Mobile</label>
            <span class="field__hint">We&rsquo;ll WhatsApp delivery updates</span>
          </div>

          <label class="check co-check">
            <input type="checkbox" id="marketingOptIn" />
            <span>Send me styling notes &amp; new arrivals · 1 email a week, never more</span>
          </label>
        </div>
      </section>

      <!-- ── 2 · DELIVERY ──────────────────────────────────────────── -->
      <section class="co-section">
        <header class="co-section__head">
          <span class="co-section__num">2</span>
          <h2>Delivery address</h2>
        </header>

        <div class="co-section__body">
          <div class="co-field">
            <select id="country" required>
              <option value="KW" selected>Kuwait</option>
            </select>
            <label for="country">Country / region</label>
          </div>

          <div class="co-field-row">
            <div class="co-field">
              <input type="text" id="firstName" name="firstName" value="@Model.Form.FirstName" required autocomplete="given-name" placeholder=" " class="@Err("FirstName")" />
              <label for="firstName">First name</label>
            </div>
            <div class="co-field">
              <input type="text" id="lastName" name="lastName" value="@Model.Form.LastName" required autocomplete="family-name" placeholder=" " class="@Err("LastName")" />
              <label for="lastName">Last name</label>
            </div>
          </div>

          <div class="co-field-row" id="kwAddressFields">
            <div class="co-field">
              <select id="governorate" name="governorate" required class="@Err("Governorate")">
                <option value="" disabled hidden selected="@(string.IsNullOrEmpty(Model.Form.Governorate))"></option>
                @foreach (var gov in governorates)
                {
                  <option selected="@(Model.Form.Governorate == gov)">@gov</option>
                }
              </select>
              <label for="governorate">Governorate</label>
            </div>
            <div class="co-field">
              <input type="text" id="area" name="area" value="@Model.Form.Area" required autocomplete="address-level2" placeholder=" " class="@Err("Area")" />
              <label for="area">Area</label>
            </div>
          </div>

          <div class="co-field-row co-field-row--3">
            <div class="co-field">
              <input type="text" id="block" name="block" value="@Model.Form.Block" required placeholder=" " class="@Err("Block")" />
              <label for="block">Block</label>
            </div>
            <div class="co-field">
              <input type="text" id="street" name="street" value="@Model.Form.Street" required placeholder=" " class="@Err("Street")" />
              <label for="street">Street</label>
            </div>
            <div class="co-field">
              <input type="text" id="building" name="building" value="@Model.Form.Building" required placeholder=" " class="@Err("Building")" />
              <label for="building">Building / house</label>
            </div>
          </div>

          <div class="co-field-row">
            <div class="co-field">
              <input type="text" id="floor" name="floor" value="@Model.Form.Floor" placeholder=" " />
              <label for="floor">Floor</label>
              <span class="field__hint">Optional</span>
            </div>
            <div class="co-field">
              <input type="text" id="apartment" name="apartment" value="@Model.Form.Apartment" placeholder=" " />
              <label for="apartment">Apartment</label>
              <span class="field__hint">Optional</span>
            </div>
          </div>

          <div class="co-field">
            <textarea id="directions" name="directions" rows="2" placeholder=" ">@Model.Form.Directions</textarea>
            <label for="directions">Additional directions</label>
            <span class="field__hint">e.g. landmark, gate code · optional</span>
          </div>

          <label class="check co-check">
            <input type="checkbox" id="saveAddress" />
            <span>Save this address for next time</span>
          </label>

          <label class="check co-check">
            <input type="checkbox" id="billingSame" checked />
            <span>Billing address is the same</span>
          </label>
        </div>
      </section>

      <!-- ── 3 · DELIVERY METHOD ───────────────────────────────────── -->
      <section class="co-section">
        <header class="co-section__head">
          <span class="co-section__num">3</span>
          <h2>Delivery method</h2>
        </header>

        <div class="co-section__body">
          @foreach (var method in Model.ShippingMethods)
          {
            <label class="radio-card">
              <input type="radio" name="shippingMethod" value="@method.Value" checked="@(Model.Form.ShippingMethod == method.Value)" />
              <span class="radio-card__inner">
                <span class="radio-card__title">@method.Title</span>
                <span class="radio-card__meta">@method.Meta</span>
                <span class="radio-card__price">@(method.IsFree ? "Free" : method.Price.ToString("0.000") + " KWD")</span>
              </span>
            </label>
          }
        </div>
      </section>

      <!-- ── 4 · PAYMENT ───────────────────────────────────────────── -->
      <section class="co-section">
        <header class="co-section__head">
          <span class="co-section__num">4</span>
          <h2>Payment</h2>
          <span class="co-section__secure">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V8a5 5 0 0110 0v3"/></svg>
            All payments processed by Tap Payments
          </span>
        </header>

        <div class="co-section__body">

          <!-- KNET (default for Kuwait) -->
          <label class="pay-card">
            <input type="radio" name="paymentMethod" value="knet" checked="@(Model.Form.PaymentMethod == "knet")" />
            <span class="pay-card__inner">
              <span class="pay-card__head">
                <span class="pay-card__brand pay-card__brand--knet">KNET</span>
                <span class="pay-card__title">KNET</span>
                <span class="pay-card__meta">Direct debit · most-used in Kuwait</span>
              </span>
              <span class="pay-card__body">
                You will be redirected to KNET&rsquo;s secure page to authenticate this payment.
              </span>
            </span>
          </label>

          <!-- Card -->
          <label class="pay-card">
            <input type="radio" name="paymentMethod" value="card" checked="@(Model.Form.PaymentMethod == "card")" />
            <span class="pay-card__inner">
              <span class="pay-card__head">
                <span class="pay-card__brands">
                  <span class="pay-card__brand pay-card__brand--visa">VISA</span>
                  <span class="pay-card__brand pay-card__brand--mc"><i></i><i></i></span>
                  <span class="pay-card__brand pay-card__brand--amex">AMEX</span>
                </span>
                <span class="pay-card__title">Credit / debit card</span>
                <span class="pay-card__meta">Visa · Mastercard · AmEx · with 3D Secure</span>
              </span>
            </span>
          </label>

          <!-- Apple Pay -->
          <label class="pay-card">
            <input type="radio" name="paymentMethod" value="applepay" checked="@(Model.Form.PaymentMethod == "applepay")" />
            <span class="pay-card__inner">
              <span class="pay-card__head">
                <span class="pay-card__brand pay-card__brand--apple">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 12.04c-.01-2.04 1.66-3.02 1.74-3.07-.95-1.39-2.42-1.58-2.94-1.6-1.24-.13-2.43.74-3.06.74-.64 0-1.61-.72-2.66-.7-1.36.02-2.63.79-3.33 2.01-1.42 2.47-.36 6.12 1.02 8.12.68.98 1.49 2.08 2.55 2.04 1.03-.04 1.42-.66 2.66-.66 1.24 0 1.59.66 2.67.64 1.1-.02 1.8-1 2.47-1.99.78-1.14 1.1-2.24 1.12-2.3-.02-.01-2.15-.83-2.17-3.23zM15.07 5.91c.56-.69.95-1.64.84-2.59-.81.04-1.81.55-2.4 1.23-.52.6-.98 1.58-.86 2.51.91.07 1.85-.46 2.42-1.15z"/></svg>
                </span>
                <span class="pay-card__title">Apple Pay</span>
                <span class="pay-card__meta">Confirm with Face ID or Touch ID</span>
              </span>
            </span>
          </label>

          <!-- COD -->
          <label class="pay-card">
            <input type="radio" name="paymentMethod" value="cod" checked="@(Model.Form.PaymentMethod == "cod")" />
            <span class="pay-card__inner">
              <span class="pay-card__head">
                <span class="pay-card__brand pay-card__brand--cod">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="6" width="18" height="13" rx="1"/><path d="M3 10h18"/><path d="M7 15h3"/></svg>
                </span>
                <span class="pay-card__title">Cash on delivery</span>
                <span class="pay-card__meta">Pay the courier in KWD on arrival · + 1.500 KWD fee</span>
              </span>
            </span>
          </label>

          <p class="co-note-muted">KNET, card &amp; Apple Pay are processed securely by Tap Payments — you’ll be redirected to complete your payment. Cash on delivery is paid to the courier on arrival.</p>

        </div>
      </section>

      <!-- ── Terms + Place order -->
      <section class="co-section co-section--final">
        <label class="check co-check co-check--required @Err("TermsAccepted")">
          <input type="checkbox" id="termsAccept" name="termsAccepted" value="true" checked="@Model.Form.TermsAccepted" required />
          <span>
            I&rsquo;ve read and agree to the <a href="/terms" class="link-inline">Terms of Sale</a>, <a href="/privacy" class="link-inline">Privacy Policy</a>, and <a href="/returns-policy" class="link-inline">Returns Policy</a>.
          </span>
        </label>

        @if (!ViewData.ModelState.IsValid)
        {
          <div class="co-errors" role="alert">
            <ul>
              @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
              {
                <li>@error.ErrorMessage</li>
              }
            </ul>
          </div>
        }

        <button type="submit" class="btn btn--primary co-place">
          <span>Place order · <strong>@Model.Summary.Total.ToString("0.000") KWD</strong></span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>

        <p class="co-disclaimer">
          By placing this order you authorise White Stitches via Tap Payments to charge the amount above. Your card details are tokenised; we never store them.
        </p>
      </section>

    </form>

    <!-- ── SUMMARY column ─────────────────────────────────────────── -->
    <aside class="co__summary" aria-label="Order summary">

      <!-- Mobile-only collapsible header -->
      <button type="button" class="co-summary-toggle" id="coSummaryToggle" aria-expanded="false" aria-controls="coSummaryBody">
        <span class="co-summary-toggle__left">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 7h13v9H3zM16 10h3l2 3v3h-5zM7 19a2 2 0 100-4 2 2 0 000 4zM18 19a2 2 0 100-4 2 2 0 000 4z"/></svg>
          <span>Show order summary</span>
          <svg class="co-summary-toggle__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 9l6 6 6-6"/></svg>
        </span>
        <strong>@Model.Summary.Total.ToString("0.000") KWD</strong>
      </button>

      <div class="co-summary" id="coSummaryBody">
        <h2 class="co-summary__title">Order Summary</h2>

        <ul class="co-items">
          @foreach (var item in Model.Items)
          {
            <li>
              <a href="/products/@item.Slug" class="co-item__media">
                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                  <img src="@item.ImageUrl" alt="@item.ImageAlt" />
                }
                <span class="co-item__qty">@item.Quantity</span>
              </a>
              <div class="co-item__body">
                <h3 class="co-item__title">@item.Title</h3>
                @if (!string.IsNullOrEmpty(item.VariantLabel))
                {
                  <p class="co-item__meta">@item.VariantLabel</p>
                }
              </div>
              <span class="co-item__price">@item.LineTotal.ToString("0.000") KWD</span>
            </li>
          }
        </ul>

        <!-- Discount code — posts to Unit B's cart discount endpoint -->
        <form class="cart-discount" method="post" action="/cart/discount">
          @Html.AntiForgeryToken()
          <input type="hidden" name="returnUrl" value="/checkout" />
          <div class="cart-discount__row">
            <input type="text" name="code" class="cart-discount__input" placeholder="Promo or gift code" autocomplete="off" />
            <button type="submit" class="cart-discount__btn">Apply</button>
          </div>
          @if (Model.Summary.DiscountAmount > 0 && Model.DiscountCode is not null)
          {
            <div class="cart-discount__msg is-success">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" style="width:14px;height:14px"><polyline points="20 6 9 17 4 12"/></svg>
              @Model.DiscountCode applied · @Model.Summary.DiscountAmount.ToString("0.000") KWD off
            </div>
          }
          else if (TempData["DiscountError"] is string discountError)
          {
            <div class="cart-discount__msg is-error">@discountError</div>
          }
        </form>

        <ul class="cart-totals">
          <li>
            <span>Subtotal</span>
            <span class="cart-totals__val">@Model.Summary.Subtotal.ToString("0.000") KWD</span>
          </li>
          @if (Model.Summary.DiscountAmount > 0)
          {
            <li class="cart-totals__discount">
              <span>Promo · <em>@Model.DiscountCode</em></span>
              <span class="cart-totals__val cart-totals__val--accent">−@Model.Summary.DiscountAmount.ToString("0.000") KWD</span>
            </li>
          }
          @if (Model.Summary.GiftWrapFee > 0)
          {
            <li>
              <span>Gift wrap</span>
              <span class="cart-totals__val">@Model.Summary.GiftWrapFee.ToString("0.000") KWD</span>
            </li>
          }
          <li>
            <span>Delivery</span>
            @if (Model.Summary.EstimatedShipping == 0)
            {
              <span class="cart-totals__val cart-totals__val--accent">Free</span>
            }
            else
            {
              <span class="cart-totals__val">@Model.Summary.EstimatedShipping.ToString("0.000") KWD</span>
            }
          </li>
          <li>
            <span>VAT</span>
            <span class="cart-totals__val">Included</span>
          </li>
        </ul>

        <div class="cart-totals__grand">
          <span>Total</span>
          <span>@Model.Summary.Total.ToString("0.000") <span class="cart-totals__currency">KWD</span></span>
        </div>

        <ul class="cart-trust">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V8a5 5 0 0110 0v3"/></svg>
            <span>Encrypted &amp; PCI DSS Level 1</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 12a9 9 0 11-9-9"/><path d="M21 4v5h-5"/></svg>
            <span>14-day easy returns</span>
          </li>
        </ul>
      </div>
    </aside>

  </div>
</main>

<!-- ============================ MINIMAL FOOTER ============================ -->

@section Scripts {
<script>
  // Mobile order-summary toggle (pure UI — re-bound here because the demo
  // checkout module in site.js is intentionally disabled on this page).
  (function () {
    var toggle = document.getElementById('coSummaryToggle');
    var wrap = document.querySelector('.co__summary');
    if (!toggle || !wrap) return;
    toggle.addEventListener('click', function () {
      var open = wrap.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      var label = toggle.querySelector('span:nth-child(1) span:nth-child(2)');
      if (label) label.textContent = open ? 'Hide order summary' : 'Show order summary';
    });
  })();
</script>
}
